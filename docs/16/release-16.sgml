      避免在分区索引上执行<command>REINDEX INDEX</command>时，
      如果子索引被同时删除而导致失败 (Fei Changhong)
      <ulink url="&commit_baseurl;c030e263e">&sect;</ulink>
      <ulink url="&commit_baseurl;7ce65c6f7">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=aa73a90c3e2224f904f87cfd69179bc5 -->
    </listitem>

