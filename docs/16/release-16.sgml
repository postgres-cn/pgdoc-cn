<!-- pgdoc-cn_start sig_en=f82f6eced7ecdda46dcf8e567874fc2e sig_cn_org=43d6b85b4e441904e8dc034a4c217817 source=16.8 
     <para>
      Allow inspection of sequence relations in relevant functions
      of <filename>contrib/pageinspect</filename>
      and <filename>contrib/pgstattuple</filename> (Nathan Bossart, Ayush
      Vatsa)
      <ulink url="&commit_baseurl;2bd4c06bb">&sect;</ulink>
      <ulink url="&commit_baseurl;0938a4ecd">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      允许检查<filename>contrib/pageinspect</filename>和<filename>contrib/pgstattuple</filename>
      中相关函数的序列关系 (Nathan Bossart, Ayush Vatsa)
      <ulink url="&commit_baseurl;2bd4c06bb">&sect;</ulink>
      <ulink url="&commit_baseurl;0938a4ecd">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=f82f6eced7ecdda46dcf8e567874fc2e -->

<!-- pgdoc-cn_start sig_en=0d4fad710c320d6b3e2e338dfd0ebd33 sig_cn_org=a677a61c198434fd5ef0820404d5eae9 source=16.8 
     <para>
      This had been allowed in the past, but it got broken during the
      introduction of non-default access methods for tables.
     </para>
________________________________________________________-->
     <para>
      这在过去是被允许的，但在为表引入非默认访问方法时被破坏了。
     </para>
<!-- pgdoc-cn_end sig_en=0d4fad710c320d6b3e2e338dfd0ebd33 -->
    </listitem>

    <listitem>
<!--
