<!-- pgdoc-cn_start sig_en=9042017472f0b1c53bca3ed72ecce022 sig_cn_org=957c5b76c4818fa1324d4a4f88bf88fe source=16.8 
     <para>
      Update time zone data files to <application>tzdata</application>
      release 2024b (Tom Lane)
      <ulink url="&commit_baseurl;a0c8d600b">&sect;</ulink>
      <ulink url="&commit_baseurl;2abc88958">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      更新时区数据文件到<application>tzdata</application>
      版本2024b（Tom Lane）
      <ulink url="&commit_baseurl;a0c8d600b">&sect;</ulink>
      <ulink url="&commit_baseurl;2abc88958">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=9042017472f0b1c53bca3ed72ecce022 -->

<!-- pgdoc-cn_start sig_en=7969f381afc1b2e1669a1c2de8be1905 sig_cn_org=b29c772b4e6a5bc6648651b5fd19c4f4 source=16.8 
     <para>
      This <application>tzdata</application> release changes the old
      System-V-compatibility zone names to duplicate the corresponding
      geographic zones; for example <literal>PST8PDT</literal> is now an
      alias for <literal>America/Los_Angeles</literal>.  The main visible
      consequence is that for timestamps before the introduction of
      standardized time zones, the zone is considered to represent local
      mean solar time for the named location.  For example,
      in <literal>PST8PDT</literal>, <type>timestamptz</type> input such
      as <literal>1801-01-01 00:00</literal> would previously have been
      rendered as <literal>1801-01-01 00:00:00-08</literal>, but now it is
      rendered as <literal>1801-01-01 00:00:00-07:52:58</literal>.
     </para>
________________________________________________________-->
     <para>
      此次<application>tzdata</application>版本更新将旧的System-V兼容时区名称更改为
      对应地理时区的副本；例如<literal>PST8PDT</literal>现在是
      <literal>America/Los_Angeles</literal>的别名。主要的可见后果是，
      对于标准化时区引入之前的时间戳，该时区被认为代表命名位置的当地
      平均太阳时间。例如，在<literal>PST8PDT</literal>中，
      <type>timestamptz</type>输入如<literal>1801-01-01 00:00</literal>之前
      会被渲染为<literal>1801-01-01 00:00:00-08</literal>，但现在
      渲染为<literal>1801-01-01 00:00:00-07:52:58</literal>。
</para>
<!-- pgdoc-cn_end sig_en=7969f381afc1b2e1669a1c2de8be1905 -->

<!-- pgdoc-cn_start sig_en=dacff18931de95ca4ae06d37f045a484 sig_cn_org=3a6b8591603412338c7ad31a8fa36baf source=16.8 
     <para>
      Also, historical corrections for Mexico, Mongolia, and Portugal.
      Notably, <literal>Asia/Choibalsan</literal> is now an alias
      for <literal>Asia/Ulaanbaatar</literal> rather than being a separate
      zone, mainly because the differences between those zones were found to
      be based on untrustworthy data.
     </para>
________________________________________________________-->
     <para>
      此外，对墨西哥、蒙古和葡萄牙进行了历史修正。
      值得注意的是，<literal>Asia/Choibalsan</literal>现在是
      <literal>Asia/Ulaanbaatar</literal>的别名，而不是一个单独的
      时区，主要是因为发现这些时区之间的差异基于不可靠的数据。
     </para>
<!-- pgdoc-cn_end sig_en=dacff18931de95ca4ae06d37f045a484 -->
    </listitem>

   </itemizedlist>

  </sect2>
 </sect1>

 <sect1 id="release-16-4">
<!-- pgdoc-cn_start sig_en=81b60f14e7faa200e0caa851c3164754 sig_cn_org=0e4a635755af83894c3bfc6a78032786 source=16.8 
  <title>Release 16.4</title>
________________________________________________________-->
  <title>发布 16.4</title>
<!-- pgdoc-cn_end sig_en=81b60f14e7faa200e0caa851c3164754 -->

  <formalpara>
<!-- pgdoc-cn_start sig_en=c45e8127eac45f2347bf1713afaeffda sig_cn_org=253305b4c6dff5b87ef36e3c2d95e52e source=15.7 
  <title>Release date:</title>
________________________________________________________-->
  <title>发布日期：</title>
<!-- pgdoc-cn_end sig_en=c45e8127eac45f2347bf1713afaeffda -->
<!-- pgdoc-cn_start sig_en=f027419d43e51878505648467f975cd3 sig_cn_org=f027419d43e51878505648467f975cd3 source=16.8 
  <para>2024-08-08</para>
________________________________________________________-->
  <para>2024-08-08</para>
<!-- pgdoc-cn_end sig_en=f027419d43e51878505648467f975cd3 -->
  </formalpara>

<!-- pgdoc-cn_start sig_en=4c6384d297dc4b8371fd90ed13063789 sig_cn_org=fbd65b97099871c85ff87787c6836e4b source=16.8 
  <para>
   This release contains a variety of fixes from 16.3.
   For information about new features in major release 16, see
   <xref linkend="release-16"/>.
  </para>
________________________________________________________-->
  <para>
   此版本包含从16.3修复的各种问题。
   有关16的主要版本中新功能的信息，请参阅
   <xref linkend="release-16"/>。
</para>
<!-- pgdoc-cn_end sig_en=4c6384d297dc4b8371fd90ed13063789 -->

  <sect2 id="release-16-4-migration">
<!-- pgdoc-cn_start sig_en=ad8d33b5ff3be9e8a8f91da77582c53a sig_cn_org=c7c2efd19687171f7c0044e37c53ff09 source=16.8 
   <title>Migration to Version 16.4</title>
________________________________________________________-->
   <title>迁移到版本16.4</title>
<!-- pgdoc-cn_end sig_en=ad8d33b5ff3be9e8a8f91da77582c53a -->

<!-- pgdoc-cn_start sig_en=ab87a2b9a562c1c18cc090d4910f7109 sig_cn_org=ecf94fca947a20bacd9abb4942dbe5d7 source=16.8 
   <para>
    A dump/restore is not required for those running 16.X.
   </para>
________________________________________________________-->
   <para>
    对于运行16.X的用户，不需要进行转储/恢复。
</para>
<!-- pgdoc-cn_end sig_en=ab87a2b9a562c1c18cc090d4910f7109 -->

<!-- pgdoc-cn_start sig_en=17c350218bf54fa73d02a4fee749bb5b sig_cn_org=bab24d1d16ae21debb5a21f15f78a3b2 source=16.8 
   <para>
    However, if you are upgrading from a version earlier than 16.3,
    see <xref linkend="release-16-3"/>.
   </para>
________________________________________________________-->
   <para>
    但是，如果您正在从早于16.3的版本升级，请参阅
    <xref linkend="release-16-3"/>。
</para>
<!-- pgdoc-cn_end sig_en=17c350218bf54fa73d02a4fee749bb5b -->
  </sect2>

  <sect2 id="release-16-4-changes">
<!-- pgdoc-cn_start sig_en=e161fef38e54e54458e215e5f978ef9b sig_cn_org=f104d50dd9d4dd802f94229ebe5bc097 source=15.7 
   <title>Changes</title>
________________________________________________________-->
   <title>变更</title>
<!-- pgdoc-cn_end sig_en=e161fef38e54e54458e215e5f978ef9b -->

   <itemizedlist>

    <listitem>
<!--
Author: Masahiko Sawada <msawada@postgresql.org>
Branch: master [66e94448a] 2024-08-05 06:05:33 -0700
Branch: REL_17_STABLE [fdf218f1d] 2024-08-05 06:05:30 -0700
Branch: REL_16_STABLE [6aba85a4b] 2024-08-05 06:05:28 -0700
Branch: REL_15_STABLE [e81e53a0c] 2024-08-05 06:05:25 -0700
Branch: REL_14_STABLE [72ef1675e] 2024-08-05 06:05:23 -0700
