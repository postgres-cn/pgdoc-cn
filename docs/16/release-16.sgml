<!--
Author: Fujii Masao <fujii@postgresql.org>
2022-07-12 [3b00a944a] Support TRUNCATE triggers on foreign tables.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=91d6d6ae031d6b7dbde84c9c6d26e6cb sig_cn_org=35c1344e2b9624aac7c361ebc774e637 source=16.8 
      <para>
       Allow <link linkend="sql-createtrigger">truncate triggers</link>
       on foreign tables (Yugo Nagata)
       <ulink url="&commit_baseurl;3b00a944a">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许在外部表上使用
       <link linkend="sql-createtrigger">截断触发器</link>
       （Yugo Nagata）
       <ulink url="&commit_baseurl;3b00a944a">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=91d6d6ae031d6b7dbde84c9c6d26e6cb -->
     </listitem>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2023-03-06 [4211fbd84] Add PROCESS_MAIN to VACUUM
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=3f475b0d5329451dc4da4e497f0215e0 sig_cn_org=ce8e9be7f242114ca0aec3dd16e0e96c source=16.8 
      <para>
       Allow <link
       linkend="sql-vacuum"><command>VACUUM</command></link> and <link
       linkend="app-vacuumdb"><application>vacuumdb</application></link>
       to only process <link
       linkend="storage-toast"><literal>TOAST</literal></link> tables
       (Nathan Bossart)
       <ulink url="&commit_baseurl;4211fbd84">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许<link
       linkend="sql-vacuum"><command>VACUUM</command></link>和<link
       linkend="app-vacuumdb"><application>vacuumdb</application></link>
       仅处理<link
       linkend="storage-toast"><literal>TOAST</literal></link>表
       （Nathan Bossart）
       <ulink url="&commit_baseurl;4211fbd84">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=3f475b0d5329451dc4da4e497f0215e0 -->

<!-- pgdoc-cn_start sig_en=1983d0d75d752653b741acfdec4d18af sig_cn_org=de0fad2769b34da34dcdbee329467582 source=16.8 
      <para>
       This is accomplished by having <link
       linkend="sql-vacuum"><command>VACUUM</command></link>
       turn off <literal>PROCESS_MAIN</literal> or by <link
       linkend="app-vacuumdb"><application>vacuumdb</application></link>
       using the <option>-&minus;no-process-main</option> option.
      </para>
________________________________________________________-->
      <para>
       这是通过让<link
       linkend="sql-vacuum"><command>VACUUM</command></link>
       关闭<literal>PROCESS_MAIN</literal>，或者通过<link
       linkend="app-vacuumdb"><application>vacuumdb</application></link>
       使用<option>--no-process-main</option>选项来实现的。
      </para>
<!-- pgdoc-cn_end sig_en=1983d0d75d752653b741acfdec4d18af -->
     </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-01-06 [a46a7011b] Add options to control whether VACUUM runs vac_update_da
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=9c492ece16c0306c84961d52e08c276e sig_cn_org=b90dbfd2b6604c5b55e47239c2a16b73 source=16.8 
      <para>
       Add <link linkend="sql-vacuum"><command>VACUUM</command></link>
       options to skip or update all <link
       linkend="vacuum-for-wraparound">frozen</link> statistics (Tom Lane,
       Nathan Bossart)
       <ulink url="&commit_baseurl;a46a7011b">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       添加<link linkend="sql-vacuum"><command>VACUUM</command></link>
       选项以跳过或更新所有<link
       linkend="vacuum-for-wraparound">冻结</link>统计信息（Tom Lane，
       Nathan Bossart）
       <ulink url="&commit_baseurl;a46a7011b">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=9c492ece16c0306c84961d52e08c276e -->

<!-- pgdoc-cn_start sig_en=7402095b299bf5a06065057f2b9e5af6 sig_cn_org=786573ca4b845daaf827f5bdeb2fab34 source=16.8 
      <para>
       The options are <literal>SKIP_DATABASE_STATS</literal> and
       <literal>ONLY_DATABASE_STATS</literal>.
      </para>
________________________________________________________-->
      <para>
       选项是<literal>SKIP_DATABASE_STATS</literal>和
       <literal>ONLY_DATABASE_STATS</literal>。
</para>
<!-- pgdoc-cn_end sig_en=7402095b299bf5a06065057f2b9e5af6 -->
     </listitem>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2022-07-19 [2cbc3c17a] Rework logic and simplify syntax of REINDEX DATABASE/SYS
Author: Michael Paquier <michael@paquier.xyz>
2022-07-26 [0a5f06b84] Fix a few issues with REINDEX grammar
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=205b3da90e99578d21fc1bcc6b7c1906 sig_cn_org=1766d6f563fe1a3d9d662cf2fb01889d source=16.8 
      <para>
       Change <link linkend="sql-reindex"><command>REINDEX
       DATABASE</command></link> and <link
       linkend="sql-reindex"><command>REINDEX SYSTEM</command></link>
       to no longer require an argument (Simon Riggs)
       <ulink url="&commit_baseurl;2cbc3c17a">&sect;</ulink>
       <ulink url="&commit_baseurl;0a5f06b84">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       将<link linkend="sql-reindex"><command>REINDEX
       DATABASE</command></link>和<link
       linkend="sql-reindex"><command>REINDEX SYSTEM</command></link>
       修改为不再需要参数（Simon Riggs）
       <ulink url="&commit_baseurl;2cbc3c17a">&sect;</ulink>
       <ulink url="&commit_baseurl;0a5f06b84">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=205b3da90e99578d21fc1bcc6b7c1906 -->

<!-- pgdoc-cn_start sig_en=c4e7b561a16ed868cae561e9747439ae sig_cn_org=603d0c1ad4328382eb0acf0e5974d850 source=16.8 
      <para>
       Previously the database name had to be specified.
      </para>
________________________________________________________-->
      <para>
       之前必须指定数据库名称。
</para>
<!-- pgdoc-cn_end sig_en=c4e7b561a16ed868cae561e9747439ae -->
     </listitem>

<!--
Author: Dean Rasheed <dean.a.rasheed@gmail.com>
2022-07-21 [624aa2a13] Make the name optional in CREATE STATISTICS.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=da5a1cd753945e1a8061ffd290ed9fc0 sig_cn_org=78dd1eeeff9dd0fd55f212c05e6701c6 source=16.8 
      <para>
       Allow <link linkend="sql-createstatistics"><command>CREATE
       STATISTICS</command></link> to generate a statistics name if none
       is specified (Simon Riggs)
       <ulink url="&commit_baseurl;624aa2a13">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许<link linkend="sql-createstatistics"><command>CREATE
       STATISTICS</command></link>在未指定名称时生成统计信息名称
       (Simon Riggs)
       <ulink url="&commit_baseurl;624aa2a13">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=da5a1cd753945e1a8061ffd290ed9fc0 -->
     </listitem>

    </itemizedlist>

   </sect3>

   <sect3 id="release-16-datatypes">
<!-- pgdoc-cn_start sig_en=4db1c7313abae97c18199af614e269c9 sig_cn_org=None source=14.1 
    <title>Data Types</title>
________________________________________________________-->
    <title>数据类型</title>
<!-- pgdoc-cn_end sig_en=4db1c7313abae97c18199af614e269c9 -->

    <itemizedlist>

<!--
Author: Peter Eisentraut <peter@eisentraut.org>
2022-12-14 [6fcda9aba] Non-decimal integer literals
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=65a4d4b8eac7ea7bddd0f73b62f62913 sig_cn_org=f700c79a5384c5e638a4499fe8c7f2de source=16.8 
      <para>
       Allow non-decimal <link linkend="sql-syntax-bit-strings">integer
       literals</link> (Peter Eisentraut)
       <ulink url="&commit_baseurl;6fcda9aba">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许非十进制的<link linkend="sql-syntax-bit-strings">整数字面量</link>
       （Peter Eisentraut）
       <ulink url="&commit_baseurl;6fcda9aba">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=65a4d4b8eac7ea7bddd0f73b62f62913 -->

<!-- pgdoc-cn_start sig_en=9332510a5b41e2265d00378f14c9e49f sig_cn_org=b0d32b6b41a4239ac3f0f169491e246f source=16.8 
      <para>
       For example, <literal>0x42F</literal>, <literal>0o273</literal>,
       and <literal>0b100101</literal>.
      </para>
________________________________________________________-->
      <para>
       例如，<literal>0x42F</literal>、<literal>0o273</literal>和
       <literal>0b100101</literal>。
</para>
<!-- pgdoc-cn_end sig_en=9332510a5b41e2265d00378f14c9e49f -->
     </listitem>

<!--
Author: Dean Rasheed <dean.a.rasheed@gmail.com>
2023-01-23 [6dfacbf72] Add non-decimal integer support to type numeric.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=7263b97e69a8b24554df49bee2c0dc0a sig_cn_org=48144db0762bffa5c6572a5ae937174c source=16.8 
      <para>
       Allow <link linkend="datatype-numeric"><type>NUMERIC</type></link>
       to process hexadecimal, octal, and binary integers of any size
       (Dean Rasheed)
       <ulink url="&commit_baseurl;6dfacbf72">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许<link linkend="datatype-numeric"><type>NUMERIC</type></link>
       处理任意大小的十六进制、八进制和二进制整数
       （Dean Rasheed）
       <ulink url="&commit_baseurl;6dfacbf72">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=7263b97e69a8b24554df49bee2c0dc0a -->

<!-- pgdoc-cn_start sig_en=9ca288fc1704a688d5f5b12909e0e9b5 sig_cn_org=4607a8b3d044d8772fc4428226b67950 source=16.8 
      <para>
       Previously only unquoted eight-byte integers were supported with
       these non-decimal bases.
      </para>
________________________________________________________-->
      <para>
       以前，这些非十进制基数仅支持未加引号的八字节整数。
</para>
<!-- pgdoc-cn_end sig_en=9ca288fc1704a688d5f5b12909e0e9b5 -->
     </listitem>

<!--
Author: Dean Rasheed <dean.a.rasheed@gmail.com>
2023-02-04 [faff8f8e4] Allow underscores in integer and numeric constants.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=60d6a36b0345955b6c1f170ed87c751f sig_cn_org=963858c2395a34d1831afdeed22d2f3c source=16.8 
      <para>
       Allow underscores in integer and numeric <link
       linkend="sql-syntax-bit-strings">constants</link> (Peter Eisentraut,
       Dean Rasheed)
       <ulink url="&commit_baseurl;faff8f8e4">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许在整数和数字<link
       linkend="sql-syntax-bit-strings">常量</link>中使用下划线
       (Peter Eisentraut, Dean Rasheed)
       <ulink url="&commit_baseurl;faff8f8e4">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=60d6a36b0345955b6c1f170ed87c751f -->

<!-- pgdoc-cn_start sig_en=b72fe20796cfbdd16bb4ae2de154a3c1 sig_cn_org=7214b69f358b8781d6caf05142b46fc6 source=16.8 
      <para>
       This can improve readability for long strings of digits.
      </para>
________________________________________________________-->
      <para>
       这可以提高长数字串的可读性。
</para>
<!-- pgdoc-cn_end sig_en=b72fe20796cfbdd16bb4ae2de154a3c1 -->
     </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-01-01 [2ceea5adb] Accept "+infinity" in date and timestamp[tz] input.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=58f36d064ac316c33132041b10beb0ad sig_cn_org=522c9a07d516a772ab565f3298bef0fe source=16.8 
      <para>
       Accept the spelling <literal>+infinity</literal> in datetime input
       (Vik Fearing)
       <ulink url="&commit_baseurl;2ceea5adb">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       接受日期时间输入中的拼写<literal>+infinity</literal>
       （Vik Fearing）
       <ulink url="&commit_baseurl;2ceea5adb">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=58f36d064ac316c33132041b10beb0ad -->
     </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-03-09 [bcc704b52] Reject combining "epoch" and "infinity" with other datet
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=4e1393393328069ce8a3c2d2cfe51f00 sig_cn_org=45484f9a9bd80590c21225285e4651a4 source=16.8 
      <para>
       Prevent the specification of <literal>epoch</literal> and
       <literal>infinity</literal> together with other fields in datetime
       strings (Joseph Koshakow)
       <ulink url="&commit_baseurl;bcc704b52">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       防止在日期时间字符串中同时指定<literal>epoch</literal>和
       <literal>infinity</literal>以及其他字段（Joseph Koshakow）
       <ulink url="&commit_baseurl;bcc704b52">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=4e1393393328069ce8a3c2d2cfe51f00 -->
     </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-03-16 [5b3c59535] Tighten error checks in datetime input, and remove bogus
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=c17327760146b5c9a794f6195342e5db sig_cn_org=ae90b72dbe293982dfc731913aa719cc source=16.8 
      <para>
       Remove undocumented support for date input in the form
       <literal>Y<replaceable>year</replaceable>M<replaceable>month</replaceable>D<replaceable>day</replaceable></literal>
       (Joseph Koshakow)
       <ulink url="&commit_baseurl;5b3c59535">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       移除以<literal>Y<replaceable>年</replaceable>M<replaceable>月</replaceable>D<replaceable>日</replaceable></literal>
       形式输入日期的未记录支持
       （Joseph Koshakow）
       <ulink url="&commit_baseurl;5b3c59535">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=c17327760146b5c9a794f6195342e5db -->
     </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2022-12-09 [1939d2628] Add test scaffolding for soft error reporting from input
Author: Michael Paquier <michael@paquier.xyz>
2023-02-28 [b8da37b3a] Rework pg_input_error_message(), now renamed pg_input_er
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=dec15da8f38b5ab1681e6ffab64d511f sig_cn_org=612dc16e5a5ac1e6b16a8c601fecc0c7 source=16.8 
      <para>
       Add functions <link
       linkend="functions-info-validity-table"><function>pg_input_is_valid()</function></link>
       and <function>pg_input_error_info()</function> to check for type
       conversion errors (Tom Lane)
       <ulink url="&commit_baseurl;1939d2628">&sect;</ulink>
       <ulink url="&commit_baseurl;b8da37b3a">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       添加函数<link
       linkend="functions-info-validity-table"><function>pg_input_is_valid()</function></link>
       和<function>pg_input_error_info()</function>以检查类型转换错误（Tom Lane）
       <ulink url="&commit_baseurl;1939d2628">&sect;</ulink>
       <ulink url="&commit_baseurl;b8da37b3a">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=dec15da8f38b5ab1681e6ffab64d511f -->
     </listitem>

    </itemizedlist>

   </sect3>

   <sect3 id="release-16-general">
<!-- pgdoc-cn_start sig_en=77bd1bf7bbb42c60afaea82f9af5fd5c sig_cn_org=fabe6734178194e30570930ca0ceb254 source=16.8 
    <title>General Queries</title>
