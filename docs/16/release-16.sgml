2023-02-13 [b16259b3c] Remove obsolete pgindent options - -code-base and - -build
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=44c93c3002cfab840bdac7163f60efe4 sig_cn_org=933da2e63a1d6628f10ef58d54a6eace source=16.8 
      <para>
       Add <link
       linkend="source"><application>pgindent</application></link> options
       (Andrew Dunstan)
       <ulink url="&commit_baseurl;b90f0b574">&sect;</ulink>
       <ulink url="&commit_baseurl;62e1e28bf">&sect;</ulink>
       <ulink url="&commit_baseurl;124937163">&sect;</ulink>
       <ulink url="&commit_baseurl;a1c4cd6f2">&sect;</ulink>
       <ulink url="&commit_baseurl;068a243b7">&sect;</ulink>
       <ulink url="&commit_baseurl;dab07e8c6">&sect;</ulink>
       <ulink url="&commit_baseurl;b16259b3c">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       添加<link
       linkend="source"><application>pgindent</application></link>选项
       (Andrew Dunstan)
       <ulink url="&commit_baseurl;b90f0b574">&sect;</ulink>
       <ulink url="&commit_baseurl;62e1e28bf">&sect;</ulink>
       <ulink url="&commit_baseurl;124937163">&sect;</ulink>
       <ulink url="&commit_baseurl;a1c4cd6f2">&sect;</ulink>
       <ulink url="&commit_baseurl;068a243b7">&sect;</ulink>
       <ulink url="&commit_baseurl;dab07e8c6">&sect;</ulink>
       <ulink url="&commit_baseurl;b16259b3c">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=44c93c3002cfab840bdac7163f60efe4 -->

<!-- pgdoc-cn_start sig_en=26b5aa8f3cc42582aad51116581c9d5b sig_cn_org=136c2fdc71ad70e29c3f68e16af014f6 source=16.8 
      <para>
       The new options are <option>-&minus;show-diff</option>,
       <option>-&minus;silent-diff</option>, <option>-&minus;commit</option>,
       and <option>-&minus;help</option>, and allow multiple
       <option>-&minus;exclude</option> options.  Also require the typedef file
       to be explicitly specified.  Options <option>-&minus;code-base</option>
       and <option>-&minus;build</option> were also removed.
      </para>
________________________________________________________-->
      <para>
       新的选项是<option>--show-diff</option>、
       <option>--silent-diff</option>、<option>--commit</option>和
       <option>--help</option>，并允许多个<option>--exclude</option>
       选项。同时要求显式指定typedef文件。选项<option>--code-base</option>
       和<option>--build</option>也被移除了。
</para>
<!-- pgdoc-cn_end sig_en=26b5aa8f3cc42582aad51116581c9d5b -->
     </listitem>

