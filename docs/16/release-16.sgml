   <sect3 id="release-16-libpq">
<!-- pgdoc-cn_start sig_en=e0b13fc5380eb77df1be0e8f962da355 sig_cn_org=c5cd5b0417f691c04dfd3be0ce282cdb source=15.7 
    <title><link linkend="libpq">libpq</link></title>
________________________________________________________-->
    <title><link linkend="libpq">libpq</link></title>
<!-- pgdoc-cn_end sig_en=e0b13fc5380eb77df1be0e8f962da355 -->

    <itemizedlist>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2023-03-14 [3a465cc67] libpq: Add support for require_auth to control authorize
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=40f71838ffe11ee575696e6e0249a713 sig_cn_org=f04f31404c1d9f52735e3e2d657ba740 source=16.8 
      <para>
       Add <application>libpq</application> connection option <link
       linkend="libpq-connect-require-auth"><option>require_auth</option></link>
       to specify a list of acceptable authentication methods (Jacob
       Champion)
       <ulink url="&commit_baseurl;3a465cc67">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       添加<application>libpq</application>连接选项<link
       linkend="libpq-connect-require-auth"><option>require_auth</option></link>
       以指定可接受的身份验证方法列表（Jacob Champion）
       <ulink url="&commit_baseurl;3a465cc67">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=40f71838ffe11ee575696e6e0249a713 -->

<!-- pgdoc-cn_start sig_en=a3a94be9097fb20462b432021db796aa sig_cn_org=1da7b4ff54efd848fc4b3635a93ff0fd source=16.8 
      <para>
       This can also be used to disallow certain authentication methods.
      </para>
________________________________________________________-->
      <para>
       这也可以用来禁止某些身份验证方法。
</para>
<!-- pgdoc-cn_end sig_en=a3a94be9097fb20462b432021db796aa -->
     </listitem>

<!--
Author: Daniel Gustafsson <dgustafsson@postgresql.org>
2023-03-29 [7f5b19817] Support connection load balancing in libpq
Author: Fujii Masao <fujii@postgresql.org>
2023-04-21 [0a16512d4] doc: Add documentation for PGLOADBALANCEHOSTS environmen
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=271ff4e8c7a91d449644f70d38d05274 sig_cn_org=39cbd174c0eb67d6022b1f6520ce2d5d source=16.8 
      <para>
       Allow multiple <application>libpq</application>-specified hosts
       to be randomly selected (Jelte Fennema)
       <ulink url="&commit_baseurl;7f5b19817">&sect;</ulink>
       <ulink url="&commit_baseurl;0a16512d4">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许随机选择多个由<application>libpq</application>指定的主机
       (Jelte Fennema)
       <ulink url="&commit_baseurl;7f5b19817">&sect;</ulink>
       <ulink url="&commit_baseurl;0a16512d4">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=271ff4e8c7a91d449644f70d38d05274 -->

<!-- pgdoc-cn_start sig_en=7878414ca95561ade490c5fd01858209 sig_cn_org=c0407ff8edb19f3df1b34a158a620e6c source=16.8 
      <para>
       This is enabled with <link
       linkend="libpq-connect-load-balance-hosts"><literal>load_balance_hosts=random</literal></link>
       and can be used for load balancing.
      </para>
________________________________________________________-->
      <para>
       通过启用<link
       linkend="libpq-connect-load-balance-hosts"><literal>load_balance_hosts=random</literal></link>
       可以实现负载均衡。
      </para>
<!-- pgdoc-cn_end sig_en=7878414ca95561ade490c5fd01858209 -->
     </listitem>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2023-03-24 [36f40ce2d] libpq: Add sslcertmode option to control client certific
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=4b35f311174deff54400babc9bdd18de sig_cn_org=34575e3fbc9f9999a6730d38ebf52662 source=16.8 
      <para>
       Add <application>libpq</application> option <link
       linkend="libpq-connect-sslcertmode"><option>sslcertmode</option></link>
       to control transmission of the client certificate (Jacob Champion)
       <ulink url="&commit_baseurl;36f40ce2d">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       添加<application>libpq</application>选项<link
       linkend="libpq-connect-sslcertmode"><option>sslcertmode</option></link>
       来控制客户端证书的传输（Jacob Champion）
       <ulink url="&commit_baseurl;36f40ce2d">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=4b35f311174deff54400babc9bdd18de -->

<!-- pgdoc-cn_start sig_en=7a10b38e0a2cdd676d728874b6a6b9d3 sig_cn_org=65a461061f32d88e371582ee633b1947 source=16.8 
      <para>
       The option values are <literal>disable</literal>,
       <literal>allow</literal>, and <literal>require</literal>.
      </para>
________________________________________________________-->
      <para>
       选项值是<literal>disable</literal>、<literal>allow</literal>和<literal>require</literal>。
      </para>
<!-- pgdoc-cn_end sig_en=7a10b38e0a2cdd676d728874b6a6b9d3 -->
     </listitem>

<!--
Author: Daniel Gustafsson <dgustafsson@postgresql.org>
2023-04-05 [8eda73146] Allow to use system CA pool for certificate verification
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=46dbaa8cd15bff891d4d2da0f9fe06f3 sig_cn_org=a1b2b9624dbe9f177f1117e5edc931ef source=16.8 
      <para>
       Allow <application>libpq</application> to use the system certificate
       pool for certificate verification (Jacob Champion, Thomas Habets)
       <ulink url="&commit_baseurl;8eda73146">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许<application>libpq</application>使用系统证书池进行证书验证
       （Jacob Champion，Thomas Habets）
       <ulink url="&commit_baseurl;8eda73146">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=46dbaa8cd15bff891d4d2da0f9fe06f3 -->

<!-- pgdoc-cn_start sig_en=efdaf76c505d3e8f35042a40cec59de6 sig_cn_org=954b9334a38aae7ac28cb1a9fd47019a source=16.8 
      <para>
       This is enabled with <link
       linkend="libpq-connect-sslrootcert"><literal>sslrootcert=system</literal></link>,
       which also enables <link
       linkend="libpq-connect-sslmode"><literal>sslmode=verify-full</literal></link>.
      </para>
________________________________________________________-->
      <para>
       通过使用<link
       linkend="libpq-connect-sslrootcert"><literal>sslrootcert=system</literal></link>
       启用，这也启用了<link
       linkend="libpq-connect-sslmode"><literal>sslmode=verify-full</literal></link>。
      </para>
<!-- pgdoc-cn_end sig_en=efdaf76c505d3e8f35042a40cec59de6 -->
     </listitem>

    </itemizedlist>

   </sect3>

   <sect3 id="release-16-client-apps">
<!-- pgdoc-cn_start sig_en=a0fec79636e7958867d23932d63e6c9e sig_cn_org=None source=14.1 
    <title>Client Applications</title>
________________________________________________________-->
    <title>客户端应用</title>
<!-- pgdoc-cn_end sig_en=a0fec79636e7958867d23932d63e6c9e -->

    <itemizedlist>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2022-07-12 [83f1c7b74] Fix ECPG's handling of type names that match SQL keyword
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=fae6d3687edca59bf3094ea27b877711 sig_cn_org=68d94b2ccf4b96eb6608b44508843466 source=16.8 
      <para>
       Allow <link linkend="ecpg"><command>ECPG</command></link>
       variable declarations to use typedef names that match unreserved
       <acronym>SQL</acronym> keywords (Tom Lane)
       <ulink url="&commit_baseurl;83f1c7b74">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许<link linkend="ecpg"><command>ECPG</command></link>
       变量声明使用与未保留的<acronym>SQL</acronym>关键字匹配的typedef名称
       （Tom Lane）
       <ulink url="&commit_baseurl;83f1c7b74">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=fae6d3687edca59bf3094ea27b877711 -->

<!-- pgdoc-cn_start sig_en=4fcad2cd18c544a8206576d4d1ba4f82 sig_cn_org=d4a021a0f5e9a8619f1366c70aff20dd source=16.8 
      <para>
       This change does prevent keywords which match C typedef names from
       being processed as keywords in later <command>EXEC SQL</command>
       blocks.
      </para>
________________________________________________________-->
      <para>
       此更改确实阻止了与C typedef名称匹配的关键字在后续
       <command>EXEC SQL</command>块中被处理为关键字。
</para>
<!-- pgdoc-cn_end sig_en=4fcad2cd18c544a8206576d4d1ba4f82 -->
     </listitem>

    </itemizedlist>

    <sect4 id="release-16-psql">
     <title><xref linkend="app-psql"/></title>

     <itemizedlist>

