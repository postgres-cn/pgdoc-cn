<!--
Author: Michael Paquier <michael@paquier.xyz>
2022-07-06 [d4bfe4128] autho_explain: Add GUC to log query parameters
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=73dbc4c64b48e2438bc98b92e5bae067 sig_cn_org=dab5c69a4c3db6dc004d2a8b811c6b8d source=16.8 
      <para>
       Allow <link
       linkend="auto-explain"><application>auto_explain</application></link>
       to log values passed to parameterized statements (Dagfinn Ilmari
       Mannsåker)
       <ulink url="&commit_baseurl;d4bfe4128">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许<link
       linkend="auto-explain"><application>auto_explain</application></link>
       记录传递给参数化语句的值（Dagfinn Ilmari
       Mannsåker）
       <ulink url="&commit_baseurl;d4bfe4128">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=73dbc4c64b48e2438bc98b92e5bae067 -->

<!-- pgdoc-cn_start sig_en=5b75dcd9f50e0f637b303687700e32a9 sig_cn_org=69d0231a779ea2cbbb9785c3e7369a3d source=16.8 
      <para>
       This affects queries using server-side <link
       linkend="sql-prepare"><command>PREPARE</command></link>/<link
       linkend="sql-execute"><command>EXECUTE</command></link>
       and client-side parse/bind.  Logging is controlled by <link
       linkend="auto-explain-configuration-parameters-log-parameter-max-length"><literal>auto_explain.log_parameter_max_length</literal></link>;
       by default query parameters will be logged with no length
       restriction.
      </para>
________________________________________________________-->
      <para>
       这会影响使用服务器端<link
       linkend="sql-prepare"><command>PREPARE</command></link>/<link
       linkend="sql-execute"><command>EXECUTE</command></link>
       和客户端解析/绑定的查询。日志记录由<link
       linkend="auto-explain-configuration-parameters-log-parameter-max-length"><literal>auto_explain.log_parameter_max_length</literal></link>
       控制；默认情况下，查询参数将被记录且没有长度限制。
      </para>
<!-- pgdoc-cn_end sig_en=5b75dcd9f50e0f637b303687700e32a9 -->
     </listitem>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2023-01-26 [9d2d9728b] Make auto_explain print the query identifier in verbose
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=ae0c4aedd269694013e939edcbafacf6 sig_cn_org=ace1b48bb16b012a9fb313597ad256c7 source=16.8 
      <para>
       Have <link
       linkend="auto-explain"><application>auto_explain</application></link>'s
       <option>log_verbose</option> mode honor the value of <link
       linkend="guc-compute-query-id"><varname>compute_query_id</varname></link>
       (Atsushi Torikoshi)
       <ulink url="&commit_baseurl;9d2d9728b">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       让<link
       linkend="auto-explain"><application>auto_explain</application></link>的
       <option>log_verbose</option>模式遵循<link
       linkend="guc-compute-query-id"><varname>compute_query_id</varname></link>
       的值（Atsushi Torikoshi）
       <ulink url="&commit_baseurl;9d2d9728b">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=ae0c4aedd269694013e939edcbafacf6 -->

<!-- pgdoc-cn_start sig_en=34e83a7225f343eefd33a4e0b29fa376 sig_cn_org=a6308ac017ad829e8c61f990f86183da source=16.8 
      <para>
       Previously even if
       <varname>compute_query_id</varname> was enabled, <link
       linkend="auto-explain-configuration-parameters-log-verbose"><option>log_verbose</option></link>
       was not showing the query identifier.
      </para>
________________________________________________________-->
      <para>
       以前，即使<varname>compute_query_id</varname>已启用，<link
       linkend="auto-explain-configuration-parameters-log-verbose"><option>log_verbose</option></link>
       也不会显示查询标识符。
      </para>
<!-- pgdoc-cn_end sig_en=34e83a7225f343eefd33a4e0b29fa376 -->
     </listitem>

<!--
Author: Andrew Dunstan <andrew@dunslane.net>
2023-01-06 [b1665bf01] Allow hyphens in ltree labels
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=665b11ec5d789c4c792b3709ddac1c1e sig_cn_org=e5f7bb7875119ccfdecb04f295af28ca source=16.8 
