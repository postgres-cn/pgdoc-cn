 <sect1 id="release-16-6">
<!-- pgdoc-cn_start sig_en=4b26b90ee397fc327c1210d1f88bc47d sig_cn_org=6962503d7231cf12b6e75d7cdfca577c source=16.8 
  <title>Release 16.6</title>
________________________________________________________-->
  <title>发布 16.6</title>
<!-- pgdoc-cn_end sig_en=4b26b90ee397fc327c1210d1f88bc47d -->

  <formalpara>
<!-- pgdoc-cn_start sig_en=c45e8127eac45f2347bf1713afaeffda sig_cn_org=253305b4c6dff5b87ef36e3c2d95e52e source=15.7 
  <title>Release date:</title>
________________________________________________________-->
  <title>发布日期：</title>
<!-- pgdoc-cn_end sig_en=c45e8127eac45f2347bf1713afaeffda -->
<!-- pgdoc-cn_start sig_en=9623ee7da57a7cfde1aa88a8bfb209f7 sig_cn_org=9623ee7da57a7cfde1aa88a8bfb209f7 source=16.8 
  <para>2024-11-21</para>
________________________________________________________-->
  <para>2024-11-21</para>
<!-- pgdoc-cn_end sig_en=9623ee7da57a7cfde1aa88a8bfb209f7 -->
  </formalpara>

<!-- pgdoc-cn_start sig_en=cbcc68ee28b9d8c5e2547a9f5f588094 sig_cn_org=8bef15c0441b6db41a51ad8c00a4ad32 source=16.8 
  <para>
   This release contains a few fixes from 16.5.
   For information about new features in major release 16, see
   <xref linkend="release-16"/>.
  </para>
________________________________________________________-->
  <para>
   此版本包含一些来自16.5的修复。
   有关16的主要版本中新功能的信息，请参见
   <xref linkend="release-16"/>。
</para>
<!-- pgdoc-cn_end sig_en=cbcc68ee28b9d8c5e2547a9f5f588094 -->

  <sect2 id="release-16-6-migration">
<!-- pgdoc-cn_start sig_en=be01de52f7c86845bad27da4b23fd2dc sig_cn_org=8a6f5b64f164f48c14119afb175ba109 source=16.8 
   <title>Migration to Version 16.6</title>
________________________________________________________-->
   <title>迁移到版本16.6</title>
<!-- pgdoc-cn_end sig_en=be01de52f7c86845bad27da4b23fd2dc -->

<!-- pgdoc-cn_start sig_en=ab87a2b9a562c1c18cc090d4910f7109 sig_cn_org=ecf94fca947a20bacd9abb4942dbe5d7 source=16.8 
   <para>
    A dump/restore is not required for those running 16.X.
   </para>
________________________________________________________-->
   <para>
    对于运行16.X的用户，不需要进行转储/恢复。
</para>
<!-- pgdoc-cn_end sig_en=ab87a2b9a562c1c18cc090d4910f7109 -->

<!-- pgdoc-cn_start sig_en=ac1592656cbc8f491a55c67b3a0d45c3 sig_cn_org=1b66098b862d30a923d7db8d6943085a source=16.8 
   <para>
    However, if you are upgrading from a version earlier than 16.5,
    see <xref linkend="release-16-5"/>.
   </para>
________________________________________________________-->
   <para>
    但是，如果您正在从早于16.5的版本升级，请参阅
    <xref linkend="release-16-5"/>。
</para>
<!-- pgdoc-cn_end sig_en=ac1592656cbc8f491a55c67b3a0d45c3 -->
  </sect2>

  <sect2 id="release-16-6-changes">
<!-- pgdoc-cn_start sig_en=e161fef38e54e54458e215e5f978ef9b sig_cn_org=f104d50dd9d4dd802f94229ebe5bc097 source=15.7 
   <title>Changes</title>
________________________________________________________-->
   <title>变更</title>
<!-- pgdoc-cn_end sig_en=e161fef38e54e54458e215e5f978ef9b -->

   <itemizedlist>

    <listitem>
<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
Branch: REL_17_STABLE [6bfacd368] 2024-11-16 12:58:26 -0500
Branch: REL_16_STABLE [ee33d5847] 2024-11-16 12:58:26 -0500
Branch: REL_15_STABLE [17db248f3] 2024-11-16 12:58:26 -0500
Branch: REL_14_STABLE [099e711b7] 2024-11-16 12:58:26 -0500
-->
<!-- pgdoc-cn_start sig_en=40362b66795af93157df799b86892d22 sig_cn_org=d7e862df785eb7c6247e45c4362e8075 source=16.8 
     <para>
      Repair ABI break for extensions that work with
      struct <structname>ResultRelInfo</structname> (Tom Lane)
      <ulink url="&commit_baseurl;ee33d5847">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      修复与结构体<structname>ResultRelInfo</structname>相关的扩展的ABI中断
      (Tom Lane)
      <ulink url="&commit_baseurl;ee33d5847">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=40362b66795af93157df799b86892d22 -->

<!-- pgdoc-cn_start sig_en=3be1d604e5cff5f261d7a0208c51109b sig_cn_org=ab23a50c526b471bb73a0e38a4000033 source=16.8 
     <para>
      Last week's minor releases unintentionally broke binary
      compatibility with <application>timescaledb</application> and
      several other extensions.  Restore the affected structure to its
      previous size, so that such extensions need not be rebuilt.
     </para>
________________________________________________________-->
     <para>
      上周的小版本更新无意中破坏了与<application>timescaledb</application>和
      其他几个扩展的二进制兼容性。恢复受影响的结构到之前的大小，
      这样这些扩展就不需要重新构建。
</para>
<!-- pgdoc-cn_end sig_en=3be1d604e5cff5f261d7a0208c51109b -->
    </listitem>

    <listitem>
<!--
Author: Noah Misch <noah@leadboat.com>
Branch: master [7b88529f4] 2024-11-15 20:39:56 -0800
Branch: REL_17_STABLE [1c05004a8] 2024-11-15 20:39:59 -0800
Branch: REL_16_STABLE [b0918c128] 2024-11-15 20:39:59 -0800
Branch: REL_15_STABLE [edf80895f] 2024-11-15 20:39:59 -0800
Branch: REL_14_STABLE [be062bfa5] 2024-11-15 20:40:00 -0800
Branch: REL_13_STABLE [07c6e0f61] 2024-11-15 20:40:00 -0800
Branch: REL_12_STABLE [c46333865] 2024-11-15 20:40:00 -0800
-->
<!-- pgdoc-cn_start sig_en=861d03fcb496acb1bb35a71f52d21fe0 sig_cn_org=ecf6f598f3d1e81670d633bfe52b01b5 source=16.8 
     <para>
      Restore functionality of <command>ALTER {ROLE|DATABASE} SET
      role</command> (Tom Lane, Noah Misch)
      <ulink url="&commit_baseurl;b0918c128">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      恢复<command>ALTER {ROLE|DATABASE} SET role</command>的功能
      （Tom Lane, Noah Misch）
      <ulink url="&commit_baseurl;b0918c128">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=861d03fcb496acb1bb35a71f52d21fe0 -->

<!-- pgdoc-cn_start sig_en=b5422140b81be45e356ea5775cd4bb06 sig_cn_org=9d40dc48d397d2b21bb50bbb2f1d2625 source=16.8 
     <para>
      The fix for CVE-2024-10978 accidentally caused settings
      for <varname>role</varname> to not be applied if they come from
      non-interactive sources, including previous <command>ALTER
      {ROLE|DATABASE}</command> commands and
      the <varname>PGOPTIONS</varname> environment variable.
     </para>
________________________________________________________-->
     <para>
      修复 CVE-2024-10978 的补丁意外导致来自非交互式来源的
      <varname>role</varname> 设置未被应用，包括之前的
      <command>ALTER {ROLE|DATABASE}</command> 命令和
      <varname>PGOPTIONS</varname> 环境变量。
     </para>
<!-- pgdoc-cn_end sig_en=b5422140b81be45e356ea5775cd4bb06 -->
    </listitem>

    <listitem>
<!--
Author: Masahiko Sawada <msawada@postgresql.org>
Branch: master [e5ed873b1] 2024-11-15 17:06:11 -0800
Branch: REL_17_STABLE [568e78a65] 2024-11-15 17:06:08 -0800
Branch: REL_16_STABLE [f35391133] 2024-11-15 17:06:05 -0800
Branch: REL_15_STABLE [91771b3fb] 2024-11-15 17:06:02 -0800
Branch: REL_14_STABLE [26c4e8968] 2024-11-15 17:06:00 -0800
Branch: REL_13_STABLE [15dc1abb1] 2024-11-15 17:05:57 -0800
-->
<!-- pgdoc-cn_start sig_en=b5190bcc0fd507ddf722ca6e1b3a1140 sig_cn_org=33b3293858cbaf354ee526238fd0d38b source=16.8 
     <para>
      Fix cases where a logical replication
      slot's <structfield>restart_lsn</structfield> could go backwards
      (Masahiko Sawada)
      <ulink url="&commit_baseurl;f35391133">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      修复逻辑复制槽的<structfield>restart_lsn</structfield>可能倒退的情况
      （Masahiko Sawada）
      <ulink url="&commit_baseurl;f35391133">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=b5190bcc0fd507ddf722ca6e1b3a1140 -->

<!-- pgdoc-cn_start sig_en=f9328b2d064f3ac69949d77e9c30a68c sig_cn_org=c44cd2eec914e4bb6deea5cfc36ef7e8 source=16.8 
     <para>
      Previously, restarting logical replication could sometimes cause the
      slot's restart point to be recomputed as an older value than had
      previously been advertised
      in <structname>pg_replication_slots</structname>.  This is bad,
      since for example WAL files might have been removed on the basis of
      the later <structfield>restart_lsn</structfield> value, in which
      case replication would fail to restart.
     </para>
________________________________________________________-->
     <para>
      以前，重新启动逻辑复制有时可能会导致槽的重启点被重新计算为比
      之前在<structname>pg_replication_slots</structname>中公布的值更旧的值。
      这是不好的，因为例如WAL文件可能已经基于较新的
      <structfield>restart_lsn</structfield>值被删除，在这种情况下，
      复制将无法重新启动。
</para>
<!-- pgdoc-cn_end sig_en=f9328b2d064f3ac69949d77e9c30a68c -->
    </listitem>

    <listitem>
<!--
Author: Álvaro Herrera <alvherre@alvh.no-ip.org>
Branch: master [90bcc7c2d] 2024-11-15 12:53:12 +0100
Branch: REL_17_STABLE [cb844d66b] 2024-11-15 12:53:12 +0100
Branch: REL_16_STABLE [ea1649c35] 2024-11-15 12:53:12 +0100
Branch: REL_15_STABLE [e28cf2fbc] 2024-11-15 12:53:12 +0100
Branch: REL_14_STABLE [ba2535841] 2024-11-15 12:53:12 +0100
-->
<!-- pgdoc-cn_start sig_en=7559d2ee0c2e8de423055753a600e001 sig_cn_org=0d396373c2e0ad38c40949d770a25937 source=16.8 
     <para>
      Avoid deleting still-needed WAL files
      during <application>pg_rewind</application>
      (Polina Bungina, Alexander Kukushkin)
      <ulink url="&commit_baseurl;ea1649c35">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      避免在<application>pg_rewind</application>期间删除仍然需要的WAL文件
      （Polina Bungina，Alexander Kukushkin）
      <ulink url="&commit_baseurl;ea1649c35">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=7559d2ee0c2e8de423055753a600e001 -->

<!-- pgdoc-cn_start sig_en=d2078b0c09258ff02387942685dd8a44 sig_cn_org=075d0dc0be6c3c5843364ee0bc25fd7b source=16.8 
     <para>
      Previously, in unlucky cases, it was possible
      for <application>pg_rewind</application> to remove important WAL
      files from the rewound demoted primary.  In particular this happens
      if those files have been marked for archival (i.e.,
      their <filename>.ready</filename> files were created) but not yet
      archived.  Then the newly promoted node no longer has such files
      because of them having been recycled, but likely they are needed
      for recovery in the demoted node.
      If <application>pg_rewind</application> removes them, recovery is
      not possible anymore.
     </para>
________________________________________________________-->
     <para>
      以前，在不幸的情况下，<application>pg_rewind</application>可能会从降级的主节点中
      删除重要的WAL文件。特别是当这些文件已被标记为归档（即，它们的
      <filename>.ready</filename>文件已创建）但尚未归档时，就会发生这种情况。
      然后，新提升的节点由于这些文件已被回收而不再拥有这些文件，但它们可能
      是降级节点恢复所需要的。
      如果<application>pg_rewind</application>删除了它们，则恢复将不再可能。
</para>
<!-- pgdoc-cn_end sig_en=d2078b0c09258ff02387942685dd8a44 -->
    </listitem>

    <listitem>
<!--
Author: Michael Paquier <michael@paquier.xyz>
Branch: master [818119afc] 2024-11-15 11:31:58 +0900
Branch: REL_17_STABLE [1d6a03ea4] 2024-11-15 11:32:13 +0900
Branch: REL_16_STABLE [afa20845d] 2024-11-15 11:32:16 +0900
Branch: REL_15_STABLE [154c5b42a] 2024-11-15 11:32:18 +0900
-->
<!-- pgdoc-cn_start sig_en=06bde56149b16d1197c748fa1e4f450b sig_cn_org=eb6919ada88aaac7cb5ba83b49ecd1c7 source=16.8 
     <para>
      Fix race conditions associated with dropping shared statistics
      entries (Kyotaro Horiguchi, Michael Paquier)
      <ulink url="&commit_baseurl;afa20845d">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      修复与删除共享统计条目相关的竞争条件
      (Kyotaro Horiguchi, Michael Paquier)
      <ulink url="&commit_baseurl;afa20845d">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=06bde56149b16d1197c748fa1e4f450b -->

<!-- pgdoc-cn_start sig_en=dee0f21275f6f54ab09f3c46c31aae15 sig_cn_org=055188401e51a478419230650d6eccc1 source=16.8 
     <para>
      These bugs could lead to loss of statistics data, assertion
      failures, or <quote>can only drop stats once</quote> errors.
     </para>
________________________________________________________-->
     <para>
      这些错误可能导致统计数据丢失、断言失败，或出现
      <quote>只能删除统计一次</quote>的错误。
</para>
<!-- pgdoc-cn_end sig_en=dee0f21275f6f54ab09f3c46c31aae15 -->
    </listitem>

    <listitem>
<!--
Author: Peter Geoghegan <pg@bowt.ie>
