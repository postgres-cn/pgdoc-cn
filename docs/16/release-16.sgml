<!-- pgdoc-cn_start sig_en=a97dff99e57400f2c0ea577d1e5cc378 sig_cn_org=7c385861b6de7edef577db53471afa5d source=16.8 
     <para>
      Disallow <command>ALTER TABLE ATTACH PARTITION</command> if the
      table to be attached has a foreign key referencing the partitioned
      table (Álvaro Herrera)
      <ulink url="&commit_baseurl;ada34d714">&sect;</ulink>
      <ulink url="&commit_baseurl;57c8b8726">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      禁止<command>ALTER TABLE ATTACH PARTITION</command>，如果要附加的表具有
      外键引用分区表（Álvaro Herrera）
      <ulink url="&commit_baseurl;ada34d714">&sect;</ulink>
      <ulink url="&commit_baseurl;57c8b8726">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=a97dff99e57400f2c0ea577d1e5cc378 -->

<!-- pgdoc-cn_start sig_en=8a1200cb8252e5067dc8d51f91d1ef82 sig_cn_org=1d84e0415e8947bcf7a14db5dec62a84 source=16.8 
     <para>
      This arrangement is not supported, and other ways of creating it
      already fail.
     </para>
________________________________________________________-->
     <para>
      此安排不受支持，并且其他创建它的方法已经失败。
     </para>
<!-- pgdoc-cn_end sig_en=8a1200cb8252e5067dc8d51f91d1ef82 -->
    </listitem>

    <listitem>
