<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2022-12-02 [b23cd185f] Remove logic for converting a table to a view.
-->

    <listitem>
<!-- pgdoc-cn_start sig_en=7a54e4adfd7d0fb9a4132f4dae27d56c sig_cn_org=b480df0b99c7b35f3fd5406a4adbb5c9 source=16.8 
     <para>
      Remove the ability to <link linkend="sql-createview">create
      views</link> manually with <literal>ON SELECT</literal> rules
      (Tom Lane)
      <ulink url="&commit_baseurl;b23cd185f">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      移除手动<literal>ON SELECT</literal>规则创建
      <link linkend="sql-createview">视图</link>的能力
      （Tom Lane）
      <ulink url="&commit_baseurl;b23cd185f">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=7a54e4adfd7d0fb9a4132f4dae27d56c -->
    </listitem>

<!--
Author: Andres Freund <andres@anarazel.de>
2023-04-24 [1118cd37e] Remove vacuum_defer_cleanup_age
-->

    <listitem>
<!-- pgdoc-cn_start sig_en=8a2b7cb51ed6814590172904b958f74d sig_cn_org=ff7674d189cb8c2b4dc275f1ff711521 source=16.8 
     <para>
      Remove the server variable
      <varname>vacuum_defer_cleanup_age</varname> (Andres Freund)
      <ulink url="&commit_baseurl;1118cd37e">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      移除服务器变量
      <varname>vacuum_defer_cleanup_age</varname>（Andres Freund）
      <ulink url="&commit_baseurl;1118cd37e">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=8a2b7cb51ed6814590172904b958f74d -->

<!-- pgdoc-cn_start sig_en=8bad75d2f348f00a08d9203dfdddb266 sig_cn_org=d38fbda7720e0b94d231dc2173b12ace source=16.8 
     <para>
      This has been unnecessary since <link
      linkend="guc-hot-standby-feedback"><varname>hot_standby_feedback</varname></link>
      and <link linkend="streaming-replication-slots">replication
      slots</link> were added.
     </para>
________________________________________________________-->
     <para>
      自从添加了<link
      linkend="guc-hot-standby-feedback"><varname>热备反馈</varname></link>
      和<link linkend="streaming-replication-slots">复制槽</link>以来，这已经不再
      必要。
     </para>
<!-- pgdoc-cn_end sig_en=8bad75d2f348f00a08d9203dfdddb266 -->
    </listitem>

<!--
Author: Thomas Munro <tmunro@postgresql.org>
2022-11-29 [cd4329d93] Remove promote_trigger_file.
-->

    <listitem>
<!-- pgdoc-cn_start sig_en=d5914f34d9f0c0864a7f5b97cebab7ca sig_cn_org=2c2d7b80b49e4a67f8d4b36d0a06772a source=16.8 
     <para>
      Remove server variable <varname>promote_trigger_file</varname>
      (Simon Riggs)
      <ulink url="&commit_baseurl;cd4329d93">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      移除服务器变量<varname>promote_trigger_file</varname>
      （Simon Riggs）
      <ulink url="&commit_baseurl;cd4329d93">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=d5914f34d9f0c0864a7f5b97cebab7ca -->

<!-- pgdoc-cn_start sig_en=ca85fa58105d23db531e75c2c44adfd1 sig_cn_org=63bb1dff8742270dc8efde877b3df1f5 source=16.8 
     <para>
      This was used to promote a standby to primary, but is now more easily
      accomplished with <link linkend="app-pg-ctl"><literal>pg_ctl
      promote</literal></link> or <link
      linkend="functions-recovery-control-table"><function>pg_promote()</function></link>.
     </para>
________________________________________________________-->
     <para>
      这曾被用来将备用服务器提升为主服务器，但现在可以更轻松地通过
      <link linkend="app-pg-ctl"><literal>pg_ctl promote</literal></link> 或
      <link linkend="functions-recovery-control-table"><function>pg_promote()</function></link>
      来完成。
</para>
<!-- pgdoc-cn_end sig_en=ca85fa58105d23db531e75c2c44adfd1 -->
    </listitem>

<!--
Author: Peter Eisentraut <peter@eisentraut.org>
2023-06-07 [b0f6c4371] Remove read-only server settings lc_collate and lc_ctype
-->

    <listitem>
<!-- pgdoc-cn_start sig_en=35e08751d29999828a0d9bf9ca1607da sig_cn_org=3e0c6ae0ff9254ffdc148eb976a90dc5 source=16.8 
     <para>
      Remove read-only server variables <varname>lc_collate</varname>
      and <varname>lc_ctype</varname> (Peter Eisentraut)
      <ulink url="&commit_baseurl;b0f6c4371">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      移除只读服务器变量<varname>lc_collate</varname>
      和<varname>lc_ctype</varname>（Peter Eisentraut）
      <ulink url="&commit_baseurl;b0f6c4371">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=35e08751d29999828a0d9bf9ca1607da -->

<!-- pgdoc-cn_start sig_en=1d16741cc9867c42c0af47cdd1064052 sig_cn_org=a3fbfda857d1cadcd7bf4a66db15762f source=16.8 
     <para>
      Collations and locales can vary between databases so having them
      as read-only server variables was unhelpful.
     </para>
________________________________________________________-->
     <para>
      排序规则和区域设置可能因数据库而异，因此将它们作为只读服务器变量
      是不方便的。
</para>
<!-- pgdoc-cn_end sig_en=1d16741cc9867c42c0af47cdd1064052 -->
    </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-08-25 [e3ce2de09] Allow grant-level control of role inheritance behavior.
-->

    <listitem>
<!-- pgdoc-cn_start sig_en=fc1ac0a5e0c481fca4f4cc7fa4ac9efd sig_cn_org=261ffb1dadd4890a22f5ee2eb43ecb3b source=16.8 
     <para>
      Role inheritance now controls the default
      inheritance status of member roles added during <link
      linkend="sql-grant"><command>GRANT</command></link> (Robert Haas)
      <ulink url="&commit_baseurl;e3ce2de09">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      角色继承现在控制在 <link
      linkend="sql-grant"><command>GRANT</command></link> 期间添加的成员角色的默认
      继承状态 (Robert Haas)
      <ulink url="&commit_baseurl;e3ce2de09">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=fc1ac0a5e0c481fca4f4cc7fa4ac9efd -->

<!-- pgdoc-cn_start sig_en=c488f79fb6a9aa57202545d5571384bf sig_cn_org=7797ed8223262313c4a21df62d08213a source=16.8 
     <para>
      The role's default inheritance behavior can be overridden with the
      new <command>GRANT ... WITH INHERIT</command> clause.  This allows
      inheritance of some roles and not others because the members'
      inheritance status is set at <command>GRANT</command> time.
      Previously the inheritance status of member roles was controlled
      only by the role's inheritance status, and changes to a role's
      inheritance status affected all previous and future member roles.
     </para>
________________________________________________________-->
     <para>
      角色的默认继承行为可以通过新的<command>GRANT ... WITH INHERIT</command>
      子句来覆盖。这允许继承某些角色而不继承其他角色，因为成员的继承
      状态是在<command>GRANT</command>时设置的。以前，成员角色的继承状态
      仅由角色的继承状态控制，并且对角色继承状态的更改会影响所有先前
      和未来的成员角色。
</para>
<!-- pgdoc-cn_end sig_en=c488f79fb6a9aa57202545d5571384bf -->
    </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2023-01-10 [cf5eb37c5] Restrict the privileges of CREATEROLE users.
Author: Robert Haas <rhaas@postgresql.org>
2023-01-24 [f1358ca52] Adjust interaction of CREATEROLE with role properties.
-->

    <listitem>
<!-- pgdoc-cn_start sig_en=ad8f05805d11c3d0dcb603f8f2944391 sig_cn_org=cabccf2338789067fcfc803e7c4b7b94 source=16.8 
     <para>
      Restrict the privileges of <link
      linkend="sql-createrole"><literal>CREATEROLE</literal></link>
      and its ability to modify other roles (Robert Haas)
      <ulink url="&commit_baseurl;cf5eb37c5">&sect;</ulink>
      <ulink url="&commit_baseurl;f1358ca52">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      限制<link
      linkend="sql-createrole"><literal>CREATEROLE</literal></link>
      的权限及其修改其他角色的能力（Robert Haas）
      <ulink url="&commit_baseurl;cf5eb37c5">&sect;</ulink>
      <ulink url="&commit_baseurl;f1358ca52">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=ad8f05805d11c3d0dcb603f8f2944391 -->

<!-- pgdoc-cn_start sig_en=99c98fe18136429bbc83819cf7c5c50b sig_cn_org=b16edf8d3f94d071c63c9dad15cf94c5 source=16.8 
     <para>
      Previously roles with <literal>CREATEROLE</literal> privileges could
      change many aspects of any non-superuser role.  Such changes,
      including adding members, now require the role requesting
      the change to have <literal>ADMIN OPTION</literal> permission.
      For example, they can now change the <literal>CREATEDB</literal>,
      <literal>REPLICATION</literal>, and <literal>BYPASSRLS</literal>
      properties only if they also have those permissions.
     </para>
________________________________________________________-->
     <para>
      以前，具有<literal>CREATEROLE</literal>权限的角色可以更改任何非超级用户角色的
      许多方面。此类更改（包括添加成员）现在要求请求更改的角色具有
      <literal>ADMIN OPTION</literal>权限。例如，他们现在只能更改
      <literal>CREATEDB</literal>、<literal>REPLICATION</literal>和<literal>BYPASSRLS</literal>
      属性，前提是他们也拥有这些权限。
</para>
<!-- pgdoc-cn_end sig_en=99c98fe18136429bbc83819cf7c5c50b -->
    </listitem>

<!--
Author: Peter Eisentraut <peter@eisentraut.org>
2023-01-26 [37e267335] Don't install postmaster symlink anymore
-->

    <listitem>
<!-- pgdoc-cn_start sig_en=9227e006c21dd187964b1d4316157683 sig_cn_org=ee064123a8f239b11044d9a6d34dda1f source=16.8 
     <para>
      Remove symbolic links for the <application>postmaster</application>
      binary (Peter Eisentraut)
      <ulink url="&commit_baseurl;37e267335">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      删除<application>postmaster</application>二进制文件的符号链接
      (Peter Eisentraut)
      <ulink url="&commit_baseurl;37e267335">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=9227e006c21dd187964b1d4316157683 -->
    </listitem>

   </itemizedlist>

  </sect2>

  <sect2 id="release-16-changes">
<!-- pgdoc-cn_start sig_en=e161fef38e54e54458e215e5f978ef9b sig_cn_org=f104d50dd9d4dd802f94229ebe5bc097 source=15.7 
   <title>Changes</title>
________________________________________________________-->
   <title>变更</title>
<!-- pgdoc-cn_end sig_en=e161fef38e54e54458e215e5f978ef9b -->

<!-- pgdoc-cn_start sig_en=235a62e24c9aac286a3dc9b34efd0075 sig_cn_org=c155d073e2391d57196be00281c63177 source=16.8 
    <para>
     Below you will find a detailed account of the changes between
    <productname>PostgreSQL</productname> 16 and the previous major
    release.
    </para>
________________________________________________________-->
    <para>
     以下是<productname>PostgreSQL</productname> 16与之前主要版本之间更改的详细说明。
</para>
<!-- pgdoc-cn_end sig_en=235a62e24c9aac286a3dc9b34efd0075 -->

   <sect3 id="release-16-server">
<!-- pgdoc-cn_start sig_en=9189294b7a121aae803ff469797ca246 sig_cn_org=d9be102ccf075d32052f6a1c47f345a9 source=15.7 
    <title>Server</title>
________________________________________________________-->
    <title>服务器</title>
<!-- pgdoc-cn_end sig_en=9189294b7a121aae803ff469797ca246 -->

    <sect4 id="release-16-optimizer">
<!-- pgdoc-cn_start sig_en=74b6eff57a1f8c0e207b184771081be9 sig_cn_org=9a948b44ad66c389427f923daffd016d source=15.7 
     <title>Optimizer</title>
________________________________________________________-->
     <title>优化器</title>
<!-- pgdoc-cn_end sig_en=74b6eff57a1f8c0e207b184771081be9 -->

     <itemizedlist>

<!--
Author: David Rowley <drowley@postgresql.org>
2022-08-02 [b59242209] Relax overly strict rules in select_outer_pathkeys_for_m
Author: David Rowley <drowley@postgresql.org>
2023-01-11 [3c6fc5820] Have the planner consider Incremental Sort for DISTINCT
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=a6e80048e68ec98ac365674efcc0fb53 sig_cn_org=ef53625a8ebd13c32cb0cd5c489af734 source=16.8 
       <para>
        Allow incremental sorts in more cases, including
        <literal>DISTINCT</literal> (David Rowley)
        <ulink url="&commit_baseurl;b59242209">&sect;</ulink>
        <ulink url="&commit_baseurl;3c6fc5820">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许在更多情况下进行增量排序，包括
        <literal>DISTINCT</literal>（David Rowley）
        <ulink url="&commit_baseurl;b59242209">&sect;</ulink>
        <ulink url="&commit_baseurl;3c6fc5820">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=a6e80048e68ec98ac365674efcc0fb53 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2022-08-02 [1349d2790] Improve performance of ORDER BY / DISTINCT aggregates
Author: David Rowley <drowley@postgresql.org>
2022-12-20 [3226f4728] Add enable_presorted_aggregate GUC
Author: David Rowley <drowley@postgresql.org>
2023-01-17 [da5800d5f] Don't presort ORDER BY/DISTINCT Aggrefs with volatile fu
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=6f09b5e7e1104362ec70d7863874e9d4 sig_cn_org=1171d1490964f1ba24b71cc2cf10edee source=16.8 
       <para>
        Add the ability for aggregates having <literal>ORDER BY</literal>
        or <literal>DISTINCT</literal> to use pre-sorted data (David
        Rowley)
        <ulink url="&commit_baseurl;1349d2790">&sect;</ulink>
        <ulink url="&commit_baseurl;3226f4728">&sect;</ulink>
        <ulink url="&commit_baseurl;da5800d5f">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        为具有<literal>ORDER BY</literal>或<literal>DISTINCT</literal>的聚合添加使用
        预排序数据的能力（David Rowley）
        <ulink url="&commit_baseurl;1349d2790">&sect;</ulink>
        <ulink url="&commit_baseurl;3226f4728">&sect;</ulink>
        <ulink url="&commit_baseurl;da5800d5f">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=6f09b5e7e1104362ec70d7863874e9d4 -->

<!-- pgdoc-cn_start sig_en=b32b6ca792134a412daec1bbd5b08121 sig_cn_org=02fa48c4c26d6518593155c7638b7ccf source=16.8 
       <para>
        The new server variable <link
        linkend="guc-enable-presorted-aggregate"><varname>enable_presorted_aggregate</varname></link>
        can be used to disable this.
       </para>
________________________________________________________-->
       <para>
        新的服务器变量<link
        linkend="guc-enable-presorted-aggregate"><varname>enable_presorted_aggregate</varname></link>
        可用于禁用此功能。
       </para>
<!-- pgdoc-cn_end sig_en=b32b6ca792134a412daec1bbd5b08121 -->
      </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-03-16 [9bfd2822b] Enable use of Memoize atop an Append that came from UNIO
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=fdcccc70c31e83a81090e0a562ef1aef sig_cn_org=e12215b26bb6430754a17d82b7bb57f3 source=16.8 
       <para>
        Allow memoize atop a <literal>UNION ALL</literal> (Richard Guo)
        <ulink url="&commit_baseurl;9bfd2822b">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许在<literal>UNION ALL</literal>之上使用记忆化 (Richard Guo)
        <ulink url="&commit_baseurl;9bfd2822b">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=fdcccc70c31e83a81090e0a562ef1aef -->
      </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-04-05 [16dc2703c] Support "Right Anti Join" plan shapes.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=880618b5e0f3018f322647348c7b974a sig_cn_org=14d73fa6e9d32699d2016da74b37dd88 source=16.8 
       <para>
        Allow anti-joins to be performed with the non-nullable input as
        the inner relation (Richard Guo)
        <ulink url="&commit_baseurl;16dc2703c">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许使用非空输入作为内部关系执行反连接 (Richard Guo)
        <ulink url="&commit_baseurl;16dc2703c">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=880618b5e0f3018f322647348c7b974a -->
      </listitem>

<!--
Author: Thomas Munro <tmunro@postgresql.org>
2023-03-31 [11c2d6fdf] Parallel Hash Full Join.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=67eb949ee6cb591fc257fd180e5c3570 sig_cn_org=35a2abedd98f5e6e3d01aea155752027 source=16.8 
       <para>
        Allow parallelization of <link
        linkend="queries-join"><literal>FULL</literal></link> and internal
        right <literal>OUTER</literal> hash joins (Melanie Plageman,
        Thomas Munro)
        <ulink url="&commit_baseurl;11c2d6fdf">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许并行化<link
        linkend="queries-join"><literal>FULL</literal></link>和内部右
        <literal>OUTER</literal>哈希连接（Melanie Plageman，
        Thomas Munro）
        <ulink url="&commit_baseurl;11c2d6fdf">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=67eb949ee6cb591fc257fd180e5c3570 -->
      </listitem>

<!--
Author: Alexander Korotkov <akorotkov@postgresql.org>
2023-01-08 [cd9479af2] Improve GIN cost estimation
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=a351718991af78d2000c80bbc06dc453 sig_cn_org=a2f638e1e4e13796371efaa2fb0db3d6 source=16.8 
       <para>
        Improve the accuracy of <link
        linkend="gin"><literal>GIN</literal></link> index access optimizer
        costs (Ronan Dunklau)
        <ulink url="&commit_baseurl;cd9479af2">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        提高<link
        linkend="gin"><literal>GIN</literal></link>索引访问优化器成本的准确性
        (Ronan Dunklau)
        <ulink url="&commit_baseurl;cd9479af2">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=a351718991af78d2000c80bbc06dc453 -->
      </listitem>

     </itemizedlist>

    </sect4>

    <sect4 id="release-16-performance">
<!-- pgdoc-cn_start sig_en=a5864e69d999da12c9d6530175c2c3a6 sig_cn_org=1d8069b437dc11144dd2d5b63a2cffe8 source=15.7 
     <title>General Performance</title>
________________________________________________________-->
     <title>通用性能</title>
<!-- pgdoc-cn_end sig_en=a5864e69d999da12c9d6530175c2c3a6 -->

     <itemizedlist>

<!--
Author: Andres Freund <andres@anarazel.de>
2023-04-06 [00d1e02be] hio: Use ExtendBufferedRelBy() to extend tables more eff
Author: Andres Freund <andres@anarazel.de>
2023-04-06 [26158b852] Use ExtendBufferedRelTo() in XLogReadBufferExtended()
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=a8f733275f0485137ace606013db3480 sig_cn_org=a5d58cb6b8902bfbce662c1d54ce2256 source=16.8 
       <para>
        Allow more efficient addition of heap and index pages (Andres
        Freund)
        <ulink url="&commit_baseurl;00d1e02be">&sect;</ulink>
        <ulink url="&commit_baseurl;26158b852">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许更高效地添加堆和索引页面（Andres
        Freund）
        <ulink url="&commit_baseurl;00d1e02be">&sect;</ulink>
        <ulink url="&commit_baseurl;26158b852">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=a8f733275f0485137ace606013db3480 -->
      </listitem>

<!--
Author: Peter Geoghegan <pg@bowt.ie>
2022-09-08 [d977ffd92] Instrument freezing in autovacuum log reports.
Author: Peter Geoghegan <pg@bowt.ie>
2022-11-15 [9e5405993] Deduplicate freeze plans in freeze WAL records.
Author: Peter Geoghegan <pg@bowt.ie>
2022-12-28 [1de58df4f] Add page-level freezing to VACUUM.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=9e1cf58c2e5a70e315dacf5024e1e0c2 sig_cn_org=9a2d06359d2cd03944f05c3a1524bcce source=16.8 
       <para>
        During non-freeze operations, perform page <link
        linkend="vacuum-for-wraparound">freezing</link> where appropriate
        (Peter Geoghegan)
        <ulink url="&commit_baseurl;d977ffd92">&sect;</ulink>
        <ulink url="&commit_baseurl;9e5405993">&sect;</ulink>
        <ulink url="&commit_baseurl;1de58df4f">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        在非冻结操作期间，在适当的地方执行页面
        <link linkend="vacuum-for-wraparound">冻结</link>
        （Peter Geoghegan）
        <ulink url="&commit_baseurl;d977ffd92">&sect;</ulink>
        <ulink url="&commit_baseurl;9e5405993">&sect;</ulink>
        <ulink url="&commit_baseurl;1de58df4f">&sect;</ulink>
</para>
<!-- pgdoc-cn_end sig_en=9e1cf58c2e5a70e315dacf5024e1e0c2 -->

<!-- pgdoc-cn_start sig_en=0af20b2a15fdbea95bad16b444990d96 sig_cn_org=4528f3ad5ab55a5a4cff14e4d788d352 source=16.8 
       <para>
        This makes full-table freeze vacuums less necessary.
       </para>
________________________________________________________-->
       <para>
        这使得全表冻结清理变得不那么必要。
</para>
<!-- pgdoc-cn_end sig_en=0af20b2a15fdbea95bad16b444990d96 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2022-12-23 [ed1a88dda] Allow window functions to adjust their frameOptions
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=502d0089951e7ceebb16c4f193926500 sig_cn_org=d1ec597206c78c95962e277e4d123ed4 source=16.8 
       <para>
        Allow window functions to use the faster <link
        linkend="syntax-window-functions"><literal>ROWS</literal></link>
        mode internally when <literal>RANGE</literal> mode is active but
        unnecessary (David Rowley)
        <ulink url="&commit_baseurl;ed1a88dda">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许窗口函数在<literal>RANGE</literal>模式处于活动但不必要时，内部使用更快的
        <link linkend="syntax-window-functions"><literal>ROWS</literal></link>
        模式 (David Rowley)
        <ulink url="&commit_baseurl;ed1a88dda">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=502d0089951e7ceebb16c4f193926500 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2023-01-27 [456fa635a] Teach planner about more monotonic window functions
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=a73c8f2d84c85e021dadf4be6e0daf96 sig_cn_org=27ca7d9dce32296170044b485a8d05b6 source=16.8 
       <para>
        Allow optimization of always-increasing window functions <link
        linkend="functions-window-table"><function>ntile()</function></link>,
        <function>cume_dist()</function> and
        <function>percent_rank()</function> (David Rowley)
        <ulink url="&commit_baseurl;456fa635a">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许优化始终递增的窗口函数<link
        linkend="functions-window-table"><function>ntile()</function></link>、
        <function>cume_dist()</function>和
        <function>percent_rank()</function>（David Rowley）
        <ulink url="&commit_baseurl;456fa635a">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=a73c8f2d84c85e021dadf4be6e0daf96 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2023-01-23 [16fd03e95] Allow parallel aggregate on string_agg and array_agg
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=74618fad7c18c8c798d8b538ecae474b sig_cn_org=2eb9300beb2810262b22a3e65f998587 source=16.8 
       <para>
        Allow aggregate functions <link
        linkend="functions-aggregate-table"><function>string_agg()</function></link>
        and <function>array_agg()</function> to be parallelized (David
        Rowley)
        <ulink url="&commit_baseurl;16fd03e95">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许聚合函数<link
        linkend="functions-aggregate-table"><function>string_agg()</function></link>
        和<function>array_agg()</function>进行并行化处理（David
        Rowley）
        <ulink url="&commit_baseurl;16fd03e95">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=74618fad7c18c8c798d8b538ecae474b -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2022-08-02 [3592e0ff9] Have ExecFindPartition cache the last found partition
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=f6489b77e8d17004120a384d9581ae50 sig_cn_org=968f353a553adb19a83e91199561db4f source=16.8 
       <para>
        Improve performance by caching <link
        linkend="ddl-partitioning-overview"><literal>RANGE</literal></link>
        and <literal>LIST</literal> partition lookups (Amit Langote,
        Hou Zhijie, David Rowley)
        <ulink url="&commit_baseurl;3592e0ff9">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        通过缓存<link
        linkend="ddl-partitioning-overview"><literal>RANGE</literal></link>
        和<literal>LIST</literal>分区查找来提高性能（Amit Langote，
        Hou Zhijie，David Rowley）
        <ulink url="&commit_baseurl;3592e0ff9">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=f6489b77e8d17004120a384d9581ae50 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2023-04-07 [1cbbee033] Add VACUUM/ANALYZE BUFFER_USAGE_LIMIT option
Author: David Rowley <drowley@postgresql.org>
2023-04-07 [ae78cae3b] Add - -buffer-usage-limit option to vacuumdb
Author: Masahiko Sawada <msawada@postgresql.org>
2023-04-28 [b72f564d8] Add unit to vacuum_buffer_usage_limit value in postgresq
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=7cec35ea89dfe03e4b30672fd45583a7 sig_cn_org=d7de254b719f2d8239694d36f3087bbb source=16.8 
       <para>
        Allow control of the shared buffer usage by vacuum and analyze
        (Melanie Plageman)
        <ulink url="&commit_baseurl;1cbbee033">&sect;</ulink>
        <ulink url="&commit_baseurl;ae78cae3b">&sect;</ulink>
        <ulink url="&commit_baseurl;b72f564d8">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许通过真空和分析控制共享缓冲区的使用
        （Melanie Plageman）
        <ulink url="&commit_baseurl;1cbbee033">&sect;</ulink>
        <ulink url="&commit_baseurl;ae78cae3b">&sect;</ulink>
        <ulink url="&commit_baseurl;b72f564d8">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=7cec35ea89dfe03e4b30672fd45583a7 -->

<!-- pgdoc-cn_start sig_en=43701e73e0d21825161216092c438bf5 sig_cn_org=69cb71c60145fe7effa26057fe007ce5 source=16.8 
       <para>
        The <link
        linkend="sql-vacuum"><command>VACUUM</command></link>/<link
        linkend="sql-analyze"><command>ANALYZE</command></link>
        option is <literal>BUFFER_USAGE_LIMIT</literal>, and the <link
        linkend="app-vacuumdb"><application>vacuumdb</application></link>
        option is <option>-&minus;buffer-usage-limit</option>.
        The default value is set by server variable <link
        linkend="guc-vacuum-buffer-usage-limit"><varname>vacuum_buffer_usage_limit</varname></link>,
        which also controls autovacuum.
       </para>
________________________________________________________-->
       <para>
        <link
        linkend="sql-vacuum"><command>VACUUM</command></link>/<link
        linkend="sql-analyze"><command>ANALYZE</command></link>
        选项是<literal>BUFFER_USAGE_LIMIT</literal>，而<link
        linkend="app-vacuumdb"><application>vacuumdb</application></link>
        选项是<option>--buffer-usage-limit</option>。
        默认值由服务器变量<link
        linkend="guc-vacuum-buffer-usage-limit"><varname>vacuum_buffer_usage_limit</varname></link>
        设置，该变量也控制自动清理。
       </para>
<!-- pgdoc-cn_end sig_en=43701e73e0d21825161216092c438bf5 -->
      </listitem>

<!--
Author: Thomas Munro <tmunro@postgresql.org>
2022-07-20 [9430fb407] Add wal_sync_method=fdatasync for Windows.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=4f8e29e3522354d19c0eabd4e42bf8ee sig_cn_org=9c47f5fc17699688ca652e01147aa56b source=16.8 
