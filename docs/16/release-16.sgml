<!--
Author: John Naylor <john.naylor@postgresql.org>
2022-08-04 [56f2c7b58] Support SSE2 intrinsics where available
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=313ff3f3235cecb3b8f8b5ae3c1800e6 sig_cn_org=730b5b5f8784389a4ec792990ce79604 source=16.8 
