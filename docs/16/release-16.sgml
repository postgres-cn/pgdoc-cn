     <para>
      修复大对象的所有权测试（Tom Lane）
      <ulink url="&commit_baseurl;152bfc0af">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=822dafa1bf959c439c98043e9796ccdf -->

