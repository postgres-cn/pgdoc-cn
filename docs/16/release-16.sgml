<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-03-20 [72a5b1fc8] Add @extschema:name@ and no_relocate options to extensio
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=5775330601fc0079859c60f51e4461aa sig_cn_org=5d3b6a1ebb3aaa42bdce79cb8bfa6978 source=16.8 
      <para>
       Allow the schemas of required extensions to be
       referenced in extension scripts using the new syntax
       <literal>@extschema:referenced_extension_name@</literal>
       (Regina Obe)
       <ulink url="&commit_baseurl;72a5b1fc8">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许在扩展脚本中使用新语法
       <literal>@extschema:referenced_extension_name@</literal>
       引用所需扩展的模式
       （Regina Obe）
       <ulink url="&commit_baseurl;72a5b1fc8">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=5775330601fc0079859c60f51e4461aa -->
     </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-03-20 [72a5b1fc8] Add @extschema:name@ and no_relocate options to extensio
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=c7ef303e834d4a0c9aeaeae88d8be554 sig_cn_org=c17095baaa51147f11ad589b4073cbf6 source=16.8 
      <para>
       Allow required extensions to
       be marked as non-relocatable using <link
       linkend="extend-extensions-files-no-relocate"><literal>no_relocate</literal></link>
       (Regina Obe)
       <ulink url="&commit_baseurl;72a5b1fc8">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       允许将所需的扩展标记为不可重定位，使用<link
       linkend="extend-extensions-files-no-relocate"><literal>no_relocate</literal></link>
       （Regina Obe）
       <ulink url="&commit_baseurl;72a5b1fc8">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=c7ef303e834d4a0c9aeaeae88d8be554 -->

<!-- pgdoc-cn_start sig_en=f35f168583b7994d16ba22d0ab0574a6 sig_cn_org=9b69b858acdf71073853f36b6b58645c source=16.8 
      <para>
       This allows <literal>@extschema:referenced_extension_name@</literal>
       to be treated as a constant for the lifetime of the extension.
      </para>
________________________________________________________-->
      <para>
       这允许<literal>@extschema:referenced_extension_name@</literal>
       在扩展的生命周期内被视为常量。
</para>
<!-- pgdoc-cn_end sig_en=f35f168583b7994d16ba22d0ab0574a6 -->
     </listitem>

    </itemizedlist>

    <sect4 id="release-16-pgfdw">
     <title><link linkend="postgres-fdw"><application>postgres_fdw</application></link></title>

     <itemizedlist>

<!--
Author: Etsuro Fujita <efujita@postgresql.org>
2023-04-06 [983ec2300] postgres_fdw: Add support for parallel abort.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=156b2c42f0043c31c51824917afb6932 sig_cn_org=fc628234e14756197671df92381fde64 source=16.8 
       <para>
        Allow <application>postgres_fdw</application> to do aborts in
        parallel (Etsuro Fujita)
        <ulink url="&commit_baseurl;983ec2300">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许<application>postgres_fdw</application>在并行中执行中止操作
        （Etsuro Fujita）
        <ulink url="&commit_baseurl;983ec2300">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=156b2c42f0043c31c51824917afb6932 -->

<!-- pgdoc-cn_start sig_en=2624b12e93cad2ae3840f2299c87a49c sig_cn_org=eecbba1cf245148f687c814d1690ba18 source=16.8 
       <para>
        This is enabled with
        <application>postgres_fdw</application> option <link
        linkend="postgres-fdw-options-transaction-management"><option>parallel_abort</option></link>.
       </para>
________________________________________________________-->
       <para>
        通过<application>postgres_fdw</application>选项<link
        linkend="postgres-fdw-options-transaction-management"><option>parallel_abort</option></link>
        启用此功能。
</para>
<!-- pgdoc-cn_end sig_en=2624b12e93cad2ae3840f2299c87a49c -->
      </listitem>

<!--
Author: Tomas Vondra <tomas.vondra@postgresql.org>
2022-12-30 [8ad51b5f4] Sample postgres_fdw tables remotely during ANALYZE
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=001b99beace19d19dbd79595e6372a84 sig_cn_org=ac643bc011f30d667898b5bcc311776f source=16.8 
       <para>
        Make <link linkend="sql-analyze"><command>ANALYZE</command></link>
        on foreign <application>postgres_fdw</application> tables more
        efficient (Tomas Vondra)
        <ulink url="&commit_baseurl;8ad51b5f4">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        使外部<application>postgres_fdw</application>表上的
        <link linkend="sql-analyze"><command>ANALYZE</command></link>
        更高效 (Tomas Vondra)
        <ulink url="&commit_baseurl;8ad51b5f4">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=001b99beace19d19dbd79595e6372a84 -->

<!-- pgdoc-cn_start sig_en=b3678e781c7ce660e03712652c6288d5 sig_cn_org=0a774e7534c8a08cbceaab058e5a0dc3 source=16.8 
       <para>
        The <application>postgres_fdw</application> option <link
        linkend="postgres-fdw-options-cost-estimation"><option>analyze_sampling</option></link>
        controls the sampling method.
       </para>
________________________________________________________-->
       <para>
        <application>postgres_fdw</application>选项<link
        linkend="postgres-fdw-options-cost-estimation"><option>analyze_sampling</option></link>
        控制采样方法。
       </para>
<!-- pgdoc-cn_end sig_en=b3678e781c7ce660e03712652c6288d5 -->
      </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2022-07-17 [31e5b5029] postgres_fdw: be more wary about shippability of reg* co
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=f737ba36303de7214fbd555dba0c6f93 sig_cn_org=d061d7e6e45c388ea1105efbb77f68d3 source=16.8 
       <para>
        Restrict shipment of <link
        linkend="datatype-oid"><type>reg</type></link>* type constants
        in <application>postgres_fdw</application> to those referencing
        built-in objects or extensions marked as shippable (Tom Lane)
        <ulink url="&commit_baseurl;31e5b5029">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        限制<link linkend="datatype-oid"><type>reg</type></link>类型常量的运输到仅引用内置对象或标记为可运输的扩展
        的<application>postgres_fdw</application>中 (Tom Lane)
        <ulink url="&commit_baseurl;31e5b5029">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=f737ba36303de7214fbd555dba0c6f93 -->
      </listitem>

<!--
Author: Andres Freund <andres@anarazel.de>
2023-01-23 [e4602483e] dblink, postgres_fdw: Handle interrupts during connectio
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=7a6473252c557d79167e5de03e0305d1 sig_cn_org=a4060975a915f3e1dbfcead330d6b461 source=16.8 
       <para>
        Have <application>postgres_fdw</application> and <link
        linkend="dblink"><application>dblink</application></link> handle
        interrupts during connection establishment (Andres Freund)
        <ulink url="&commit_baseurl;e4602483e">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        让<application>postgres_fdw</application>和<link
        linkend="dblink"><application>dblink</application></link>在连接建立
        期间处理中断（Andres Freund）
        <ulink url="&commit_baseurl;e4602483e">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=7a6473252c557d79167e5de03e0305d1 -->
      </listitem>

     </itemizedlist>

    </sect4>

   </sect3>

