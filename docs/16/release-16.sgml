    <sect4 id="release-16-privileges">
<!-- pgdoc-cn_start sig_en=13cba4791f3b1778f8daa6f35b4036f4 sig_cn_org=None source=14.1 
     <title>Privileges</title>
________________________________________________________-->
     <title>权限</title>
<!-- pgdoc-cn_end sig_en=13cba4791f3b1778f8daa6f35b4036f4 -->

     <itemizedlist>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2023-03-30 [c3afe8cf5] Add new predefined role pg_create_subscription.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=ad3489aefabc132940d2547a85f9f828 sig_cn_org=eb4f7cad0ee525c9b7a5f3e9bbbade0a source=16.8 
       <para>
        Add predefined role <link
        linkend="predefined-roles"><literal>pg_create_subscription</literal></link>
        with permission to create subscriptions (Robert Haas)
        <ulink url="&commit_baseurl;c3afe8cf5">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        添加预定义角色<link
        linkend="predefined-roles"><literal>pg_create_subscription</literal></link>
        以获得创建订阅的权限（Robert Haas）
        <ulink url="&commit_baseurl;c3afe8cf5">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=ad3489aefabc132940d2547a85f9f828 -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2023-03-30 [c3afe8cf5] Add new predefined role pg_create_subscription.
Author: Amit Kapila <akapila@postgresql.org>
2023-04-20 [c1cc4e688] Restart the apply worker if the 'password_required' opti
Author: Amit Kapila <akapila@postgresql.org>
2023-04-24 [19e65dff3] Display 'password_required' option for \dRs+ command.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=55ecc98170368c4600876dda5cdcdc10 sig_cn_org=d613bbcfd7743a5f5a19488aa4a43f68 source=16.8 
       <para>
        Allow subscriptions to not require passwords (Robert Haas)
        <ulink url="&commit_baseurl;c3afe8cf5">&sect;</ulink>
        <ulink url="&commit_baseurl;c1cc4e688">&sect;</ulink>
        <ulink url="&commit_baseurl;19e65dff3">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许订阅不需要密码（Robert Haas）
        <ulink url="&commit_baseurl;c3afe8cf5">&sect;</ulink>
        <ulink url="&commit_baseurl;c1cc4e688">&sect;</ulink>
        <ulink url="&commit_baseurl;19e65dff3">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=55ecc98170368c4600876dda5cdcdc10 -->

<!-- pgdoc-cn_start sig_en=81ccd6e852401262abf40bcf614954d2 sig_cn_org=af4dd5d1cb179988433f1271f6999ca5 source=16.8 
       <para>
        This is accomplished with the option <link
        linkend="sql-createsubscription"><literal>password_required=false</literal></link>.
       </para>
________________________________________________________-->
       <para>
        通过选项<link
        linkend="sql-createsubscription"><literal>password_required=false</literal></link>
        完成此操作。
</para>
<!-- pgdoc-cn_end sig_en=81ccd6e852401262abf40bcf614954d2 -->
      </listitem>

<!--
Author: Jeff Davis <jdavis@postgresql.org>
2023-01-13 [c44f6334c] Simplify permissions for LOCK TABLE.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=3f5b2b4914b02bf3ea63f322f5134853 sig_cn_org=4a64c172766c442f16a4aec46bc029ec source=16.8 
       <para>
        Simplify permissions for <link linkend="sql-lock"><command>LOCK
        TABLE</command></link> (Jeff Davis)
        <ulink url="&commit_baseurl;c44f6334c">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        简化 <link linkend="sql-lock"><command>LOCK
        TABLE</command></link> 的权限 (Jeff Davis)
        <ulink url="&commit_baseurl;c44f6334c">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=3f5b2b4914b02bf3ea63f322f5134853 -->

<!-- pgdoc-cn_start sig_en=e40b5a29232d56d33c03ad4a5496e48f sig_cn_org=700acb1fb2c23847ae2274e40292e5f2 source=16.8 
       <para>
        Previously a user's ability to perform <command>LOCK
        TABLE</command> at various lock levels was limited to the
        lock levels required by the commands they had permission
        to execute on the table.  For example, someone with <link
        linkend="sql-update"><command>UPDATE</command></link>
        permission could perform all lock levels except <literal>ACCESS
        SHARE</literal>, even though it was a lesser lock level.  Now users
        can issue lesser lock levels if they already have permission for
        greater lock levels.
       </para>
________________________________________________________-->
       <para>
        以前，用户在不同锁级别上执行<command>LOCK TABLE</command>的能力仅限于他们有权
        在表上执行的命令所需的锁级别。例如，拥有<link linkend="sql-update">
        <command>UPDATE</command></link>权限的用户可以执行除<literal>ACCESS SHARE</literal>
        之外的所有锁级别，即使它是一个更低的锁级别。现在，如果用户已经拥有更高锁级别的
        权限，他们也可以发出更低锁级别的锁请求。
       </para>
<!-- pgdoc-cn_end sig_en=e40b5a29232d56d33c03ad4a5496e48f -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-08-22 [ce6b672e4] Make role grant system more consistent with other privil
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=f4cf20028b7d65096016f7c2a5a50e07 sig_cn_org=7f7cf1136a1ef6c3148562d824e65520 source=16.8 
       <para>
        Allow <link linkend="sql-altergroup"><literal>ALTER GROUP group_name
        ADD USER user_name</literal></link> to be performed with <literal>ADMIN
        OPTION</literal> (Robert Haas)
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许使用<link linkend="sql-altergroup"><literal>ALTER GROUP group_name
        ADD USER user_name</literal></link>与<literal>ADMIN OPTION</literal>一起执行
        （Robert Haas）
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=f4cf20028b7d65096016f7c2a5a50e07 -->

<!-- pgdoc-cn_start sig_en=0a192b18c4f748c667b7c7070cd02cc6 sig_cn_org=600223cd46228b9b6b1d7f01edcf3dc7 source=16.8 
       <para>
        Previously <literal>CREATEROLE</literal> permission was required.
       </para>
________________________________________________________-->
       <para>
        之前需要<literal>CREATEROLE</literal>权限。
</para>
<!-- pgdoc-cn_end sig_en=0a192b18c4f748c667b7c7070cd02cc6 -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-08-25 [e3ce2de09] Allow grant-level control of role inheritance behavior.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=beb006e4cc93eff5092ec599d59df328 sig_cn_org=935d628c59c4b9d08417ba4677200c7b source=16.8 
       <para>
        Allow <link linkend="sql-grant"><command>GRANT</command></link>
        to use <literal>WITH ADMIN TRUE</literal>/<literal>FALSE</literal>
        syntax (Robert Haas)
        <ulink url="&commit_baseurl;e3ce2de09">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许使用<link linkend="sql-grant"><command>GRANT</command></link>
        来使用<literal>WITH ADMIN TRUE</literal>/<literal>FALSE</literal>
        语法（Robert Haas）
        <ulink url="&commit_baseurl;e3ce2de09">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=beb006e4cc93eff5092ec599d59df328 -->

<!-- pgdoc-cn_start sig_en=805da6c8271cbbe2d520bbf3a125f016 sig_cn_org=46245dccc47466d687ca893b12f56c40 source=16.8 
       <para>
        Previously only the <literal>WITH ADMIN OPTION</literal> syntax
        was supported.
       </para>
________________________________________________________-->
       <para>
        之前仅支持<literal>WITH ADMIN OPTION</literal>语法。
       </para>
<!-- pgdoc-cn_end sig_en=805da6c8271cbbe2d520bbf3a125f016 -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2023-01-10 [e5b8a4c09] Add new GUC createrole_self_grant.
Author: Daniel Gustafsson <dgustafsson@postgresql.org>
2023-02-22 [e00bc6c92] doc: Add default value of createrole_self_grant
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=d41d02d6a623b102a1ee4520c9f576da sig_cn_org=0645c85b54b27d1a2e6a8ba6f678b437 source=16.8 
       <para>
        Allow roles that create other roles to automatically
        inherit the new role's rights or the ability to <link
        linkend="sql-set-role"><command>SET ROLE</command></link> to the
        new role (Robert Haas, Shi Yu)
        <ulink url="&commit_baseurl;e5b8a4c09">&sect;</ulink>
        <ulink url="&commit_baseurl;e00bc6c92">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许创建其他角色的角色自动继承新角色的权限或
        <link linkend="sql-set-role"><command>SET ROLE</command></link>
        到新角色的能力（Robert Haas, Shi Yu）
        <ulink url="&commit_baseurl;e5b8a4c09">&sect;</ulink>
        <ulink url="&commit_baseurl;e00bc6c92">&sect;</ulink>
</para>
<!-- pgdoc-cn_end sig_en=d41d02d6a623b102a1ee4520c9f576da -->

<!-- pgdoc-cn_start sig_en=ea14952f6e57494a17faa71225e69cab sig_cn_org=77708e06452d38f7f7229a7f59d25f69 source=16.8 
       <para>
        This is controlled by server variable <link
        linkend="guc-createrole-self-grant"><varname>createrole_self_grant</varname></link>.
       </para>
________________________________________________________-->
       <para>
        这由服务器变量<link
        linkend="guc-createrole-self-grant"><varname>createrole_self_grant</varname></link>
        控制。
       </para>
<!-- pgdoc-cn_end sig_en=ea14952f6e57494a17faa71225e69cab -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-09-19 [48a257d44] Make ALTER DEFAULT PRIVILEGES require privileges, not me
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=57c049fe463443275dc80ad69111aa2b sig_cn_org=b1c3897134911cc340effe0f9500ae69 source=16.8 
       <para>
        Prevent users from changing the default privileges of non-inherited
        roles (Robert Haas)
        <ulink url="&commit_baseurl;48a257d44">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        防止用户更改非继承角色的默认权限（Robert Haas）
        <ulink url="&commit_baseurl;48a257d44">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=57c049fe463443275dc80ad69111aa2b -->

<!-- pgdoc-cn_start sig_en=f73c29bfe59dd93a48505a128d3fc5c6 sig_cn_org=6574054570655eae8844ebf662566691 source=16.8 
       <para>
        This is now only allowed for inherited roles.
       </para>
________________________________________________________-->
       <para>
        这现在仅适用于继承的角色。
</para>
<!-- pgdoc-cn_end sig_en=f73c29bfe59dd93a48505a128d3fc5c6 -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-08-22 [ce6b672e4] Make role grant system more consistent with other privil
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=d15b0d6e24ae837a7c2b47e49dafe414 sig_cn_org=90d0498b9f6f42ac9297663cf63fccee source=16.8 
       <para>
        When granting role membership, require the granted-by role to be
        a role that has appropriate permissions (Robert Haas)
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        在授予角色成员资格时，要求授予者角色是具有适当权限的角色
        (Robert Haas)
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=d15b0d6e24ae837a7c2b47e49dafe414 -->

<!-- pgdoc-cn_start sig_en=0e1a122846b89eda49eee6db3839e568 sig_cn_org=945723a238a4256bc39d1a31f9271a29 source=16.8 
       <para>
        This is a requirement even when a non-bootstrap superuser is
        granting role membership.
       </para>
________________________________________________________-->
       <para>
        即使是非引导超级用户在授予角色成员资格时，这也是一个要求。
</para>
<!-- pgdoc-cn_end sig_en=0e1a122846b89eda49eee6db3839e568 -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-08-22 [ce6b672e4] Make role grant system more consistent with other privil
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=f930d9a89e96435f2ca0674d902fdd3b sig_cn_org=c28b4a13b045b73e2f46f1a63f7e11c5 source=16.8 
       <para>
        Allow non-superusers to grant permissions using a granted-by user
        that is not the current user (Robert Haas)
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许非超级用户使用非当前用户的授权用户授予权限
        （Robert Haas）
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=f930d9a89e96435f2ca0674d902fdd3b -->

<!-- pgdoc-cn_start sig_en=846acd42eafe46219e64818a5f8aa15d sig_cn_org=85aafa942e2cfd09a4548d8afa208d45 source=16.8 
       <para>
        The current user still must have sufficient permissions given by
        the specified granted-by user.
       </para>
________________________________________________________-->
       <para>
        当前用户仍然必须具有由指定的授权用户授予的足够权限。
</para>
<!-- pgdoc-cn_end sig_en=846acd42eafe46219e64818a5f8aa15d -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-11-18 [3d14e171e] Add a SET option to the GRANT command.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=ef651f99d99468cb59d30d78ad57a792 sig_cn_org=e82de4682bb425f87681e730fcc08058 source=16.8 
       <para>
        Add <link linkend="sql-grant"><command>GRANT</command></link> to
        control permission to use <link linkend="sql-set-role"><command>SET
        ROLE</command></link> (Robert Haas)
        <ulink url="&commit_baseurl;3d14e171e">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        添加<link linkend="sql-grant"><command>GRANT</command></link>以控制使用
        <link linkend="sql-set-role"><command>SET ROLE</command></link>的权限
        （Robert Haas）
        <ulink url="&commit_baseurl;3d14e171e">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=ef651f99d99468cb59d30d78ad57a792 -->

<!-- pgdoc-cn_start sig_en=67f0baa00f82b9d9523e565e5f925a78 sig_cn_org=50a5990ba4d26bd1decedbcab24e37d2 source=16.8 
       <para>
        This is controlled by a new <literal>GRANT ... SET</literal>
        option.
       </para>
________________________________________________________-->
       <para>
        这是由一个新的<literal>GRANT ... SET</literal>选项控制的。
       </para>
<!-- pgdoc-cn_end sig_en=67f0baa00f82b9d9523e565e5f925a78 -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-08-22 [ce6b672e4] Make role grant system more consistent with other privil
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=d9296ec5924957ee659feb8e58d7dac7 sig_cn_org=281bde7a9909fb2035d447229493c00e source=16.8 
       <para>
        Add dependency tracking to roles which have granted privileges
        (Robert Haas)
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        为已授予权限的角色添加依赖关系跟踪
        （Robert Haas）
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=d9296ec5924957ee659feb8e58d7dac7 -->

<!-- pgdoc-cn_start sig_en=d5b2a5a8862a6bd452c5aaacbc2877a8 sig_cn_org=91e50221d72d5ac6eb41b068867686e0 source=16.8 
       <para>
        For example, removing <literal>ADMIN OPTION</literal> will fail if
        there are privileges using that option;  <literal>CASCADE</literal>
        must be used to revoke dependent permissions.
       </para>
________________________________________________________-->
       <para>
        例如，如果存在使用该选项的权限，移除<literal>ADMIN OPTION</literal>将会失败；
        必须使用<literal>CASCADE</literal>来撤销依赖的权限。
       </para>
<!-- pgdoc-cn_end sig_en=d5b2a5a8862a6bd452c5aaacbc2877a8 -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-08-18 [6566133c5] Ensure that pg_auth_members.grantor is always valid.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=10916ab6dc60aaa0155ed54ba3b61ef3 sig_cn_org=fa920571f1a14d826f3f7db08836bb45 source=16.8 
       <para>
        Add dependency tracking of grantors for <link
        linkend="sql-grant"><command>GRANT</command></link> records
        (Robert Haas)
        <ulink url="&commit_baseurl;6566133c5">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        添加对<command>GRANT</command>记录的授予者依赖跟踪
        (<link linkend="sql-grant">Robert Haas</link>)
        <ulink url="&commit_baseurl;6566133c5">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=10916ab6dc60aaa0155ed54ba3b61ef3 -->

<!-- pgdoc-cn_start sig_en=a6419e4b71b5682f7587a3d54b581de9 sig_cn_org=d37b31be32712fca8e7aa5524ff280e9 source=16.8 
       <para>
        This guarantees that <link
        linkend="catalog-pg-auth-members"><structname>pg_auth_members</structname></link>.<structfield>grantor</structfield>
        values are always valid.
       </para>
________________________________________________________-->
       <para>
        这保证了<link
        linkend="catalog-pg-auth-members"><structname>pg_auth_members</structname></link>.<structfield>grantor</structfield>
        的值始终是有效的。
       </para>
<!-- pgdoc-cn_end sig_en=a6419e4b71b5682f7587a3d54b581de9 -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-08-22 [ce6b672e4] Make role grant system more consistent with other privil
Author: Robert Haas <rhaas@postgresql.org>
2022-08-31 [0101f770a] Fix a bug in roles_is_member_of.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=98a12b1e181e7d8063f936e67c0b37e1 sig_cn_org=2fd5ffce9696c2abbca3ba90a8010707 source=16.8 
       <para>
        Allow multiple role membership records (Robert Haas)
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
        <ulink url="&commit_baseurl;0101f770a">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许多个角色成员记录（Robert Haas）
        <ulink url="&commit_baseurl;ce6b672e4">&sect;</ulink>
        <ulink url="&commit_baseurl;0101f770a">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=98a12b1e181e7d8063f936e67c0b37e1 -->

<!-- pgdoc-cn_start sig_en=8a432dba62a0f368bad200c6943ecf7f sig_cn_org=13b3e3ff569ba0ac2fb4a21f79ba1ba3 source=16.8 
       <para>
        Previously a new membership grant would remove a previous matching
        membership grant, even if other aspects of the grant did not match.
       </para>
________________________________________________________-->
       <para>
        之前，一个新的成员资格授予会移除之前匹配的成员资格授予，
        即使授予的其他方面不匹配。
</para>
<!-- pgdoc-cn_end sig_en=8a432dba62a0f368bad200c6943ecf7f -->
      </listitem>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2022-07-26 [e530be2c5] Do not allow removal of superuser privileges from bootst
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=be8720a5c966b8c2a538e3560512a089 sig_cn_org=2e7f5a94f59af837c4c34985a2c3b9c5 source=16.8 
       <para>
        Prevent removal of superuser privileges for the bootstrap user
        (Robert Haas)
        <ulink url="&commit_baseurl;e530be2c5">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        防止为引导用户（Robert Haas）移除超级用户权限
        <ulink url="&commit_baseurl;e530be2c5">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=be8720a5c966b8c2a538e3560512a089 -->

<!-- pgdoc-cn_start sig_en=f777e40f6fdca2bc4589ba4ba311bce8 sig_cn_org=d1474fa15a558a56544740e359e58f62 source=16.8 
       <para>
        Restoring such users could lead to errors.
       </para>
________________________________________________________-->
       <para>
        恢复此类用户可能会导致错误。
       </para>
<!-- pgdoc-cn_end sig_en=f777e40f6fdca2bc4589ba4ba311bce8 -->
      </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2022-07-03 [b762bbde3] Allow makeaclitem() to accept multiple privilege names.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=01a691fda9078a0507f103408ad90ec9 sig_cn_org=84c592b18e4933d56c5b31d405734c2a source=16.8 
       <para>
        Allow <link
        linkend="functions-aclitem-fn-table"><function>makeaclitem()</function></link>
        to accept multiple privilege names (Robins Tharakan)
        <ulink url="&commit_baseurl;b762bbde3">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        允许<link
        linkend="functions-aclitem-fn-table"><function>makeaclitem()</function></link>
        接受多个权限名称（Robins Tharakan）
        <ulink url="&commit_baseurl;b762bbde3">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=01a691fda9078a0507f103408ad90ec9 -->

<!-- pgdoc-cn_start sig_en=fa2c08a07663347d7b113dccfc395d64 sig_cn_org=17f4cf84296b1dd535a6a8e7c905046a source=16.8 
       <para>
        Previously only a single privilege name, like <link
        linkend="sql-select"><command>SELECT</command></link>, was
        accepted.
       </para>
________________________________________________________-->
       <para>
        以前只接受单个权限名称，例如<link
        linkend="sql-select"><command>SELECT</command></link>。
       </para>
<!-- pgdoc-cn_end sig_en=fa2c08a07663347d7b113dccfc395d64 -->
      </listitem>

     </itemizedlist>

    </sect4>

    <sect4 id="release-16-server-config">
