    <itemizedlist>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us> 2023-03-22
     [3e51b278d] Add "-c name=value" switch to initdb.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=d4f5ad6268e845ce11b24775e25130d6 sig_cn_org=c898a30171a44a9ada9ad72a083924b4 source=16.8 
      <para>
       Add <link
       linkend="app-initdb"><application>initdb</application></link>
       option to set server variables for the duration of
       <application>initdb</application> and all future server starts
       (Tom Lane)
       <ulink url="&commit_baseurl;3e51b278d">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       添加<link
       linkend="app-initdb"><application>initdb</application></link>
       选项以在<application>initdb</application>期间以及所有未来的服务器启动
       过程中设置服务器变量（Tom Lane）
       <ulink url="&commit_baseurl;3e51b278d">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=d4f5ad6268e845ce11b24775e25130d6 -->

<!-- pgdoc-cn_start sig_en=615f697d3d8fee93eadcfdaffeac9aea sig_cn_org=bf2a76e55bc104b653eee0305dca803c source=16.8 
      <para>
       The option is <option>-c name=value</option>.
      </para>
________________________________________________________-->
      <para>
       该选项是<option>-c name=value</option>。
</para>
<!-- pgdoc-cn_end sig_en=615f697d3d8fee93eadcfdaffeac9aea -->
     </listitem>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2022-07-13 [08951a7c9] createuser: Add support for more clause types through ne
Author: Nathan Bossart <nathan@postgresql.org>
2023-05-21 [2dcd1578c] Rename some createuser options.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=9ea9fb28319dafb1008739220b234d19 sig_cn_org=3053bed519e128e01241616c00f5a347 source=16.8 
      <para>
       Add options to <link
       linkend="app-createuser"><application>createuser</application></link>
       to control more user options (Shinya Kato)
       <ulink url="&commit_baseurl;08951a7c9">&sect;</ulink>
       <ulink url="&commit_baseurl;2dcd1578c">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       为<link
       linkend="app-createuser"><application>createuser</application></link>
       添加选项以控制更多用户选项（Shinya Kato）
       <ulink url="&commit_baseurl;08951a7c9">&sect;</ulink>
       <ulink url="&commit_baseurl;2dcd1578c">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=9ea9fb28319dafb1008739220b234d19 -->

<!-- pgdoc-cn_start sig_en=62deac172af6bfd5f388db8a9f9c2b96 sig_cn_org=7525cf901ec2a7517005130e24af3cc3 source=16.8 
      <para>
       Specifically, the new options control the valid-until date,
       bypassing of row-level security, and role membership.
      </para>
________________________________________________________-->
      <para>
       具体来说，新选项控制有效期日期、绕过行级安全性和角色成员资格。
</para>
<!-- pgdoc-cn_end sig_en=62deac172af6bfd5f388db8a9f9c2b96 -->
     </listitem>

<!--
Author: Nathan Bossart <nathan@postgresql.org>
2023-05-21 [2dcd1578c] Rename some createuser options.
Author: Nathan Bossart <nathan@postgresql.org>
2023-05-23 [381d19b3e] Document deprecated createuser option.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=bc359db9019f570e560326867a2b955d sig_cn_org=89201d045c5d426870f56b339d201d46 source=16.8 
      <para>
       Deprecate <link
       linkend="app-createuser"><application>createuser</application></link>
       option <option>-&minus;role</option> (Nathan Bossart)
       <ulink url="&commit_baseurl;2dcd1578c">&sect;</ulink>
       <ulink url="&commit_baseurl;381d19b3e">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       弃用<link
       linkend="app-createuser"><application>createuser</application></link>
       选项<option>--role</option>（Nathan Bossart）
       <ulink url="&commit_baseurl;2dcd1578c">&sect;</ulink>
       <ulink url="&commit_baseurl;381d19b3e">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=bc359db9019f570e560326867a2b955d -->

<!-- pgdoc-cn_start sig_en=cf4a2f2e92f86035b3b44c0e98acd9d2 sig_cn_org=bf8ac779a4cc12d47be079fe1470ebc4 source=16.8 
      <para>
       This option could be easily confused with new
       <application>createuser</application> role membership options,
       so option <option>-&minus;member-of</option> has been added with the
       same functionality.  The <option>-&minus;role</option> option can still
       be used.
      </para>
________________________________________________________-->
      <para>
       此选项可能很容易与新的<application>createuser</application>角色成员选项混淆，
       因此添加了具有相同功能的<option>--member-of</option>选项。
       <option>--role</option>选项仍然可以使用。
      </para>
<!-- pgdoc-cn_end sig_en=cf4a2f2e92f86035b3b44c0e98acd9d2 -->
     </listitem>

<!--
Author: Andrew Dunstan <andrew@dunslane.net>
2022-07-31 [7781f4e3e] Add - -schema and - -exclude-schema options to vacuumdb.
-->

