<!--
Author: Andrew Dunstan <andrew@dunslane.net>
2023-03-13 [9f8377f7a] Add a DEFAULT option to COPY  FROM
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=a82ac4b16c5aa6166a9328a46959e34e sig_cn_org=57baa60ff1ca2a3747df21141e502840 source=16.8 
      <para>
       Allow a <link linkend="sql-copy"><command>COPY FROM</command></link>
