    <sect4 id="release-16-pgdump">
     <title><link linkend="app-pgdump"><application>pg_dump</application></link></title>

     <itemizedlist>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-03-14 [a563c24c9] Allow pg_dump to include/exclude child tables automatica
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=d4c8abb35e6ff918e6c1eddfe2d39bef sig_cn_org=27e45b8a86f247726a85379a45c75f2d source=16.8 
       <para>
        Add <application>pg_dump</application> control of dumping child
        tables and partitions (Gilles Darold)
        <ulink url="&commit_baseurl;a563c24c9">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        添加<application>pg_dump</application>对转储子表和分区的控制
        (Gilles Darold)
        <ulink url="&commit_baseurl;a563c24c9">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=d4c8abb35e6ff918e6c1eddfe2d39bef -->

<!-- pgdoc-cn_start sig_en=dad88f415ecc15c0a5dfd8555d4546bb sig_cn_org=064c02470d15de2ed68bd519bcc1913f source=16.8 
       <para>
        The new options are <option>-&minus;table-and-children</option>,
        <option>-&minus;exclude-table-and-children</option>, and
        <option>-&minus;exclude-table-data-and-children</option>.
       </para>
________________________________________________________-->
       <para>
        新的选项是<option>--table-and-children</option>、
        <option>--exclude-table-and-children</option>和
        <option>--exclude-table-data-and-children</option>。
</para>
<!-- pgdoc-cn_end sig_en=dad88f415ecc15c0a5dfd8555d4546bb -->
      </listitem>

<!--
Author: Tomas Vondra <tomas.vondra@postgresql.org>
2023-02-23 [0da243fed] Add LZ4 compression to pg_dump
Author: Tomas Vondra <tomas.vondra@postgresql.org>
2023-04-01 [0070b66fe] pg_dump: Use only LZ4 frame format for compression
Author: Tomas Vondra <tomas.vondra@postgresql.org>
2023-04-05 [84adc8e20] pg_dump: Add support for zstd compression-->

      <listitem>
<!-- pgdoc-cn_start sig_en=231cf210351d281f234cfe1fa614194e sig_cn_org=d2b2cba8f4d6b375783c09a67a39ca31 source=16.8 
