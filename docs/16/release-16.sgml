<!--
Author: Michael Paquier <michael@paquier.xyz>
2023-03-14 [5c1b66280] Rework design of functions in pg_walinspect
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=49c7474d77de4e92c1b69ce3400a93b7 sig_cn_org=014c17bc1ff31f332caadee4d957fab4 source=16.8 
      <para>
       Change how <link
       linkend="pgwalinspect"><application>pg_walinspect</application></link>
