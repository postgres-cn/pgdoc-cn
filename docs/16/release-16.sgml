    <itemizedlist>

<!--
Author: Alvaro Herrera <alvherre@alvh.no-ip.org>
2023-03-29 [7081ac46a] SQL/JSON: add standard JSON constructor functions
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=c08e294f98101d562877f02dc2a8e950 sig_cn_org=8fc714f08d346427312236d44480d7b5 source=16.8 
