Branch: REL_16_STABLE [2143d96dc] 2023-09-25 16:03:17 +0200
-->
<!-- pgdoc-cn_start sig_en=8e5872a3b156a404614bee36bb437676 sig_cn_org=3ff1f14193c6ead188f1cdf18d11615a source=16.8 
     <para>
      Fix <application>vacuumdb</application>'s handling of
      multiple <option>-N</option> switches (Nathan Bossart, Kuwamura
      Masaki)
      <ulink url="&commit_baseurl;2143d96dc">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      修复<application>vacuumdb</application>处理多个<option>-N</option>
      开关的问题（Nathan Bossart, Kuwamura Masaki）
      <ulink url="&commit_baseurl;2143d96dc">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=8e5872a3b156a404614bee36bb437676 -->

<!-- pgdoc-cn_start sig_en=ae56cfae3953f54f90fc5468df8485c3 sig_cn_org=cc71b84682403c36edd97c8387af8d86 source=16.8 
     <para>
      Multiple <option>-N</option> switches should exclude tables
      in multiple schemas, but in fact excluded nothing due to faulty
      construction of a generated query.
     </para>
________________________________________________________-->
     <para>
      多个<option>-N</option>开关应排除多个模式中的表，但实际上由于生成查询的
      构造错误，未排除任何内容。
</para>
<!-- pgdoc-cn_end sig_en=ae56cfae3953f54f90fc5468df8485c3 -->
    </listitem>

    <listitem>
