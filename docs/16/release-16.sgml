<!-- pgdoc-cn_start sig_en=a908034087c2b1e19ffa39083be11561 sig_cn_org=1e25b905dc311e8e1a4f2678e61246dd source=16.8 
      <para>
       This eventually will replace the <productname>Autoconf</productname>
       and <systemitem class="osname">Windows</systemitem>-based
       <productname>MSVC</productname> build systems.
      </para>
________________________________________________________-->
      <para>
       这最终将取代<productname>Autoconf</productname>和基于
       <systemitem class="osname">Windows</systemitem>的
       <productname>MSVC</productname>构建系统。
</para>
<!-- pgdoc-cn_end sig_en=a908034087c2b1e19ffa39083be11561 -->
     </listitem>

