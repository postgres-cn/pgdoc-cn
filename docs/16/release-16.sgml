    <itemizedlist>

<!--
Author: Dean Rasheed <dean.a.rasheed@gmail.com>
2022-07-20 [bcedd8f5f] Make subquery aliases optional in the FROM clause.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=a4aee45748495706c5abbcd1361b8101 sig_cn_org=35d4c4b2dc22223d5f86496807c0dce2 source=16.8 
