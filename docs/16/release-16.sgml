<!--
Author: Dean Rasheed <dean.a.rasheed@gmail.com>
2023-01-07 [d913928c9] psql: Add support for \dpS and \zS.
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-07-19 [d65ddaca9] Add psql \drg command to display role
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=9d952df3bef5f3eab3e51fd818e4e989 sig_cn_org=cf7e0ea0e5e22353fe5a2eeb95d5b00d source=16.8 
       <para>
        Add <application>psql</application> command <link
        linkend="app-psql-meta-command-drg"><command>\drg</command></link>
        to show role membership details (Pavel Luzanov)
        <ulink url="&commit_baseurl;d913928c9">&sect;</ulink>
        <ulink url="&commit_baseurl;d65ddaca9">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
        添加<application>psql</application>命令<link
        linkend="app-psql-meta-command-drg"><command>\drg</command></link>
        以显示角色成员详细信息（Pavel Luzanov）
        <ulink url="&commit_baseurl;d913928c9">&sect;</ulink>
        <ulink url="&commit_baseurl;d65ddaca9">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=9d952df3bef5f3eab3e51fd818e4e989 -->

<!-- pgdoc-cn_start sig_en=e4a7a05e0b2e8572324f194203338422 sig_cn_org=7867bdc2744b6942ac27e6c58d602b45 source=16.8 
       <para>
        The <literal>Member of</literal> output column has been removed
        from <command>\du</command> and <command>\dg</command> because
        this new command displays this information in more detail.
       </para>
________________________________________________________-->
       <para>
        <literal>成员所属</literal>输出列已从<command>\du</command>和<command>\dg</command>
        中移除，因为这个新命令以更详细的方式显示了这些信息。
       </para>
<!-- pgdoc-cn_end sig_en=e4a7a05e0b2e8572324f194203338422 -->
      </listitem>

<!--
Author: Dean Rasheed <dean.a.rasheed@gmail.com>
