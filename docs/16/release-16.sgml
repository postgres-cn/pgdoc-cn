        允许<application>psql</application>控制扩展格式中标题行的最大宽度
        （Platon Pronko）
        <ulink url="&commit_baseurl;a45388d6e">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=a4f80906cfa8dd07b28eb5341c744240 -->

<!-- pgdoc-cn_start sig_en=42b52f6a417f57958f5e67ee443f8268 sig_cn_org=93da0c7ec6e232befa900eea8436f279 source=16.8 
