<!-- pgdoc-cn_start sig_en=08e7b77aa7af4aeff817d6a6d8983a28 sig_cn_org=24a411d063c6fbce5165bb173928c7d3 source=16.8 
       <para>
        Physical <acronym>WAL</acronym> senders do not display a database
        name.
       </para>
________________________________________________________-->
       <para>
        物理<acronym>WAL</acronym>发送器不会显示数据库名称。
</para>
<!-- pgdoc-cn_end sig_en=08e7b77aa7af4aeff817d6a6d8983a28 -->
      </listitem>

<!--
Author: Fujii Masao <fujii@postgresql.org>
2022-07-07 [62c46eee2] Add checkpoint and REDO LSN to log_checkpoints message.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=e6a4eefd79e738e915bd62fdc0f5906a sig_cn_org=bc23fc03485b7c2719db987449678842 source=16.8 
