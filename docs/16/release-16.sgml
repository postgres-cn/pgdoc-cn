<!--
Author: Alvaro Herrera <alvherre@alvh.no-ip.org>
2023-03-31 [6ee30209a] SQL/JSON: support the IS JSON predicate
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=41f7d9efdf76cdbb97b1ce482a135177 sig_cn_org=b221b414c2da3233c36cd9814ec0f8e4 source=16.8 
      <para>
       Add <acronym>SQL/JSON</acronym> object checks (Nikita Glukhov,
       Teodor Sigaev, Oleg Bartunov, Alexander Korotkov, Amit Langote,
       Andrew Dunstan)
       <ulink url="&commit_baseurl;6ee30209a">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
       添加<acronym>SQL/JSON</acronym>对象检查（Nikita Glukhov、
       Teodor Sigaev、Oleg Bartunov、Alexander Korotkov、Amit Langote、
       Andrew Dunstan）
       <ulink url="&commit_baseurl;6ee30209a">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=41f7d9efdf76cdbb97b1ce482a135177 -->

<!-- pgdoc-cn_start sig_en=513327efd24cbc7f967ec1d3c58ee5ab sig_cn_org=0ba6ae9654aa77eb54fba48d6d5d91ec source=16.8 
      <para>
       The <link linkend="functions-sqljson-misc"><literal>IS
       JSON</literal></link> checks include checks for values, arrays,
       objects, scalars, and unique keys.
      </para>
________________________________________________________-->
      <para>
       <link linkend="functions-sqljson-misc"><literal>IS
       JSON</literal></link>检查包括对值、数组、对象、标量和唯一键的检查。
      </para>
<!-- pgdoc-cn_end sig_en=513327efd24cbc7f967ec1d3c58ee5ab -->
     </listitem>

<!--
Author: John Naylor <john.naylor@postgresql.org>
2022-09-02 [0a8de93a4] Speed up lexing of long JSON strings
-->

     <listitem>
