 </indexterm>
<!-- pgdoc-cn_end sig_en=aebe3c9a6e15fb318fce95c5604e4962 -->

 <refmeta>
  <refentrytitle>CREATE SUBSCRIPTION</refentrytitle>
  <manvolnum>7</manvolnum>
  <refmiscinfo>SQL - Language Statements</refmiscinfo>
 </refmeta>

<!-- pgdoc-cn_start sig_en=ad698e1be8f1853b568df2001ed99209 sig_cn_org=None source=14.1 
 <refnamediv>
  <refname>CREATE SUBSCRIPTION</refname>
  <refpurpose>define a new subscription</refpurpose>
 </refnamediv>
________________________________________________________-->
 <refnamediv>
  <refname>CREATE SUBSCRIPTION</refname>
  <refpurpose>定义一个新的订阅</refpurpose>
 </refnamediv>
<!-- pgdoc-cn_end sig_en=ad698e1be8f1853b568df2001ed99209 -->

 <refsynopsisdiv>
<!-- pgdoc-cn_start sig_en=9171f9b3b2a2026f21cae17ebcdf1459 sig_cn_org=None source=14.1 
<synopsis>
CREATE SUBSCRIPTION <replaceable class="parameter">subscription_name</replaceable>
    CONNECTION '<replaceable class="parameter">conninfo</replaceable>'
    PUBLICATION <replaceable class="parameter">publication_name</replaceable> [, ...]
    [ WITH ( <replaceable class="parameter">subscription_parameter</replaceable> [= <replaceable class="parameter">value</replaceable>] [, ... ] ) ]
</synopsis>
________________________________________________________-->
<synopsis>
CREATE SUBSCRIPTION <replaceable class="parameter">subscription_name</replaceable>
    CONNECTION '<replaceable class="parameter">conninfo</replaceable>'
    PUBLICATION <replaceable class="parameter">publication_name</replaceable> [, ...]
    [ WITH ( <replaceable class="parameter">subscription_parameter</replaceable> [= <replaceable class="parameter">value</replaceable>] [, ... ] ) ]
</synopsis>
<!-- pgdoc-cn_end sig_en=9171f9b3b2a2026f21cae17ebcdf1459 -->
 </refsynopsisdiv>

 <refsect1>
<!-- pgdoc-cn_start sig_en=59d6e86f3a60db4f1e08d0d6e639924e sig_cn_org=None source=14.1 
  <title>Description</title>
________________________________________________________-->
  <title>描述</title>
<!-- pgdoc-cn_end sig_en=59d6e86f3a60db4f1e08d0d6e639924e -->

<!-- pgdoc-cn_start sig_en=39f10261e9c784530ccd5147688f8678 sig_cn_org=4e06b39138d43e051b67856fb5350819 source=16.8 
  <para>
   <command>CREATE SUBSCRIPTION</command> adds a new logical-replication
   subscription.  The user that creates a subscription becomes the owner
   of the subscription. The subscription name must be distinct from the name of
   any existing subscription in the current database.
  </para>
________________________________________________________-->
  <para>
   <command>CREATE SUBSCRIPTION</command> 添加一个新的逻辑复制订阅。创建订阅的用户
   成为该订阅的所有者。订阅名称必须与当前数据库中任何现有订阅的名称不同。
</para>
<!-- pgdoc-cn_end sig_en=39f10261e9c784530ccd5147688f8678 -->

<!-- pgdoc-cn_start sig_en=ecbe44fbc9dcdf7e1cb81204580b4283 sig_cn_org=1420932b907e10499975885ed559e4cf source=15.7 
  <para>
   A subscription represents a replication connection to the publisher.
   Hence, in addition to adding definitions in the local catalogs, this
   command normally creates a replication slot on the publisher.
  </para>
________________________________________________________-->
  <para>
   订阅表示与发布者的复制连接。因此，除了在本地目录中添加定义外，该命令通常会在发布者上创建一个复制槽。
  </para>
<!-- pgdoc-cn_end sig_en=ecbe44fbc9dcdf7e1cb81204580b4283 -->

<!-- pgdoc-cn_start sig_en=18dcd29d856f94a59c4d26ff72168dde sig_cn_org=3efaaf30230e41a35357b1172e935e6b source=15.7 
  <para>
   A logical replication worker will be started to replicate data for the new
   subscription at the commit of the transaction where this command is run,
   unless the subscription is initially disabled.
  </para>
________________________________________________________-->
  <para>
   逻辑复制工作者将在运行此命令的事务提交时开始为新订阅复制数据，除非订阅最初被禁用。
</para>
<!-- pgdoc-cn_end sig_en=18dcd29d856f94a59c4d26ff72168dde -->

<!-- pgdoc-cn_start sig_en=2843cde467d85fdaa1933d8a58d8f2f8 sig_cn_org=35b403d6a7708adb36d33da6f1f51410 source=16.8 
  <para>
   To be able to create a subscription, you must have the privileges of the
   the <literal>pg_create_subscription</literal> role, as well as
   <literal>CREATE</literal> privileges on the current database.
  </para>
________________________________________________________-->
  <para>
   要能够创建订阅，您必须具有<literal>pg_create_subscription</literal>角色的权限，
   以及当前数据库的<literal>CREATE</literal>权限。
</para>
<!-- pgdoc-cn_end sig_en=2843cde467d85fdaa1933d8a58d8f2f8 -->

<!-- pgdoc-cn_start sig_en=3627a1970d43481378c6c67c28ac77db sig_cn_org=None source=14.1 
  <para>
   Additional information about subscriptions and logical replication as a
   whole is available at <xref linkend="logical-replication-subscription"/> and
   <xref linkend="logical-replication"/>.
  </para>
________________________________________________________-->
  <para>
   关于订阅和逻辑复制的更多信息，请参见
   <xref linkend="logical-replication-subscription"/>和
   <xref linkend="logical-replication"/>。
  </para>
<!-- pgdoc-cn_end sig_en=3627a1970d43481378c6c67c28ac77db -->

 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=55f21f3bddee6a8d223aa24ab57d80dc sig_cn_org=None source=14.1 
  <title>Parameters</title>
________________________________________________________-->
  <title>参数</title>
<!-- pgdoc-cn_end sig_en=55f21f3bddee6a8d223aa24ab57d80dc -->

  <variablelist>
   <varlistentry id="sql-createsubscription-name">
    <term><replaceable class="parameter">subscription_name</replaceable></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=07ee0401d4ef7e9dc474aad5fdbf925e sig_cn_org=None source=14.1 
     <para>
      The name of the new subscription.
     </para>
________________________________________________________-->
     <para>
      新订阅的名称。
     </para>
<!-- pgdoc-cn_end sig_en=07ee0401d4ef7e9dc474aad5fdbf925e -->
    </listitem>
   </varlistentry>

   <varlistentry id="sql-createsubscription-connection">
    <term><literal>CONNECTION '<replaceable class="parameter">conninfo</replaceable>'</literal></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=c4568c99d67c1f0b06392129662103f9 sig_cn_org=ccd676598bae2fc049c7722f7d758788 source=15.7 
     <para>
      The <application>libpq</application> connection string defining how
      to connect to the publisher database.  For details see
      <xref linkend="libpq-connstring"/>.
     </para>
________________________________________________________-->
     <para>
      定义如何连接到发布者数据库的<application>libpq</application>连接字符串。详情请参见<xref linkend="libpq-connstring"/>。
     </para>
<!-- pgdoc-cn_end sig_en=c4568c99d67c1f0b06392129662103f9 -->
    </listitem>
   </varlistentry>

   <varlistentry id="sql-createsubscription-publication">
    <term><literal>PUBLICATION <replaceable class="parameter">publication_name</replaceable> [, ...]</literal></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=effb37ab133bd44c8c5cc97503fcfaed sig_cn_org=None source=14.1 
     <para>
      Names of the publications on the publisher to subscribe to.
     </para>
________________________________________________________-->
     <para>
      要订阅的发布者上的发布名称。
     </para>
<!-- pgdoc-cn_end sig_en=effb37ab133bd44c8c5cc97503fcfaed -->
    </listitem>
   </varlistentry>

   <varlistentry id="sql-createsubscription-with">
    <term><literal>WITH ( <replaceable class="parameter">subscription_parameter</replaceable> [= <replaceable class="parameter">value</replaceable>] [, ... ] )</literal></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=61f03ef76bcbc61f8d45ce7661d40bc2 sig_cn_org=b79dc3d7835b03a5fd31847c95325cff source=15.7 
     <para>
      This clause specifies optional parameters for a subscription.
     </para>
________________________________________________________-->
     <para>
      本条款指定了订阅的可选参数。
     </para>
<!-- pgdoc-cn_end sig_en=61f03ef76bcbc61f8d45ce7661d40bc2 -->

<!-- pgdoc-cn_start sig_en=8ae3b073f5abd0f3e1a95ae3460c169c sig_cn_org=6f1dce4a442377d44fb2bbe34b177814 source=16.8 
     <para>
      The following parameters control what happens during subscription creation:

      <variablelist>

       <varlistentry id="sql-createsubscription-with-connect">
        <term><literal>connect</literal> (<type>boolean</type>)</term>
        <listitem>
         <para>
          Specifies whether the <command>CREATE SUBSCRIPTION</command>
          command should connect to the publisher at all.  The default
          is <literal>true</literal>.  Setting this to
          <literal>false</literal> will force the values of
          <literal>create_slot</literal>, <literal>enabled</literal> and
          <literal>copy_data</literal> to <literal>false</literal>.
          (You cannot combine setting <literal>connect</literal>
          to <literal>false</literal> with
          setting <literal>create_slot</literal>, <literal>enabled</literal>,
          or <literal>copy_data</literal> to <literal>true</literal>.)
         </para>

         <para>
          Since no connection is made when this option is
          <literal>false</literal>, no tables are subscribed. To initiate
          replication, you must manually create the replication slot, enable
          the subscription, and refresh the subscription. See
          <xref linkend="logical-replication-subscription-examples-deferred-slot"/>
          for examples.
         </para>
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-create-slot">
        <term><literal>create_slot</literal> (<type>boolean</type>)</term>
        <listitem>
         <para>
          Specifies whether the command should create the replication slot on
          the publisher.  The default is <literal>true</literal>.
         </para>
         <para>
          If set to <literal>false</literal>, you are responsible for
          creating the publisher's slot in some other way. See
          <xref linkend="logical-replication-subscription-examples-deferred-slot"/>
          for examples.
         </para>
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-enabled">
        <term><literal>enabled</literal> (<type>boolean</type>)</term>
        <listitem>
         <para>
          Specifies whether the subscription should be actively replicating
          or whether it should just be set up but not started yet.  The default
          is <literal>true</literal>.
         </para>
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-slot-name">
        <term><literal>slot_name</literal> (<type>string</type>)</term>
        <listitem>
         <para>
          Name of the publisher's replication slot to use.  The default is
          to use the name of the subscription for the slot name.
         </para>

         <para>
          Setting <literal>slot_name</literal> to <literal>NONE</literal>
          means there will be no replication slot associated with the
          subscription. Such subscriptions must also have both
          <literal>enabled</literal> and <literal>create_slot</literal> set to
          <literal>false</literal>.  Use this when you will be creating the
          replication slot later manually. See
          <xref linkend="logical-replication-subscription-examples-deferred-slot"/>
          for examples.
         </para>
        </listitem>
       </varlistentry>
      </variablelist>
     </para>
________________________________________________________-->
     <para>
      以下参数控制订阅创建期间发生的情况：

      <variablelist>

       <varlistentry id="sql-createsubscription-with-connect">
        <term><literal>connect</literal> (<type>boolean</type>)</term>
        <listitem>
         <para>
          指定<command>CREATE SUBSCRIPTION</command>命令是否应连接到发布者。
          默认值是<literal>true</literal>。将此设置为<literal>false</literal>
          会强制<literal>create_slot</literal>、<literal>enabled</literal>和
          <literal>copy_data</literal>的值为<literal>false</literal>。
          （不能将<literal>connect</literal>设置为<literal>false</literal>
          与将<literal>create_slot</literal>、<literal>enabled</literal>或
          <literal>copy_data</literal>设置为<literal>true</literal>结合使用。）
         </para>

         <para>
          当此选项设置为<literal>false</literal>时，由于未建立连接，因此
          不会订阅任何表。要启动复制，您必须手动创建复制槽、启用订阅并刷新
          订阅。参见
          <xref linkend="logical-replication-subscription-examples-deferred-slot"/>
          获取示例。
         </para>
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-create-slot">
        <term><literal>create_slot</literal> (<type>boolean</type>)</term>
        <listitem>
         <para>
          指定命令是否应在发布者上创建复制槽。默认值是
          <literal>true</literal>。
         </para>
         <para>
          如果设置为<literal>false</literal>，您需要以其他方式负责创建
          发布者的槽。参见
          <xref linkend="logical-replication-subscription-examples-deferred-slot"/>
          获取示例。
         </para>
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-enabled">
        <term><literal>enabled</literal> (<type>boolean</type>)</term>
        <listitem>
         <para>
          指定订阅是否应主动进行复制，或者是否仅设置但尚未启动。
          默认值是<literal>true</literal>。
         </para>
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-slot-name">
        <term><literal>slot_name</literal> (<type>string</type>)</term>
        <listitem>
         <para>
          要使用的发布者复制槽的名称。默认值是使用订阅的名称作为槽名称。
         </para>

         <para>
          将<literal>slot_name</literal>设置为<literal>NONE</literal>表示
          订阅不会关联任何复制槽。此类订阅还必须将
          <literal>enabled</literal>和<literal>create_slot</literal>都设置为
          <literal>false</literal>。在您稍后手动创建复制槽时使用此选项。
          参见
          <xref linkend="logical-replication-subscription-examples-deferred-slot"/>
          获取示例。
         </para>
        </listitem>
       </varlistentry>
      </variablelist>
     </para>
<!-- pgdoc-cn_end sig_en=8ae3b073f5abd0f3e1a95ae3460c169c -->

<!-- pgdoc-cn_start sig_en=1810a8809d07e3a28c74b8853f96052c sig_cn_org=5c4caf1b6fa2c722be5dd8011d32cde5 source=16.8 
     <para>
      The following parameters control the subscription's replication
      behavior after it has been created:

      <variablelist>

       <varlistentry id="sql-createsubscription-with-binary">
________________________________________________________-->
     <para>
      以下参数控制订阅在创建后的复制行为：
      
      <variablelist>

       <varlistentry id="sql-createsubscription-with-binary">
<!-- pgdoc-cn_end sig_en=1810a8809d07e3a28c74b8853f96052c -->
<!-- pgdoc-cn_start sig_en=095ab9f019e82e4b031b0438550ab8d8 sig_cn_org=2c34e41ff197d19b0c55cbb4430bacce source=15.7 
        <term><literal>binary</literal> (<type>boolean</type>)</term>
________________________________________________________-->
        <term><literal>binary</literal> (<type>boolean</type>)</term>
<!-- pgdoc-cn_end sig_en=095ab9f019e82e4b031b0438550ab8d8 -->
        <listitem>
<!-- pgdoc-cn_start sig_en=4ddb2bdbcab681ceb8c37798ec911ad0 sig_cn_org=04e187c1185fb265cb32bacd28dc8ee0 source=16.8 
         <para>
          Specifies whether the subscription will request the publisher to send
          the data in binary format (as opposed to text). The default is
          <literal>false</literal>. Any initial table synchronization copy
          (see <literal>copy_data</literal>) also uses the same format. Binary
          format can be faster than the text format, but it is less portable
          across machine architectures and <productname>PostgreSQL</productname>
          versions. Binary format is very data type specific; for example, it
          will not allow copying from a <type>smallint</type> column to an
          <type>integer</type> column, even though that would work fine in text
          format. Even when this option is enabled, only data types having binary
          send and receive functions will be transferred in binary. Note that
          the initial synchronization requires all data types to have binary
          send and receive functions, otherwise the synchronization will fail
          (see <xref linkend="sql-createtype"/> for more about send/receive
          functions).
         </para>
________________________________________________________-->
         <para>
          指定订阅是否请求发布者以二进制格式（而不是文本格式）发送数据。默认值为
          <literal>false</literal>。任何初始表同步副本（参见<literal>copy_data</literal>）
          也使用相同的格式。二进制格式可能比文本格式更快，但在不同的机器架构和
          <productname>PostgreSQL</productname>版本之间的可移植性较差。二进制格式对数据
          类型非常具体；例如，它不允许从<type>smallint</type>列复制到
          <type>integer</type>列，即使在文本格式下这可以正常工作。即使启用了此选项，
          只有具有二进制发送和接收函数的数据类型才会以二进制方式传输。请注意，
          初始同步要求所有数据类型都具有二进制发送和接收函数，否则同步将失败
          （参见<xref linkend="sql-createtype"/>以了解更多关于发送/接收函数的信息）。
</para>
<!-- pgdoc-cn_end sig_en=4ddb2bdbcab681ceb8c37798ec911ad0 -->

<!-- pgdoc-cn_start sig_en=91ba1bc62a541386c77f7cc86a2d8279 sig_cn_org=b5eed36b7105b27f57148d2a71605885 source=15.7 
         <para>
          When doing cross-version replication, it could be that the
          publisher has a binary send function for some data type, but the
          subscriber lacks a binary receive function for that type.  In
          such a case, data transfer will fail, and
          the <literal>binary</literal> option cannot be used.
         </para>
________________________________________________________-->
         <para>
          在进行跨版本复制时，可能出现这样的情况：发布者对某种数据类型有二进制发送功能，但订阅者缺乏该类型的二进制接收功能。
          在这种情况下，数据传输将失败，且<literal>binary</literal>选项无法使用。
         </para>
<!-- pgdoc-cn_end sig_en=91ba1bc62a541386c77f7cc86a2d8279 -->

<!-- pgdoc-cn_start sig_en=12a674c9d8327398ddfc1b49e0e69db8 sig_cn_org=9bf9186a1bec799673228936ec2df958 source=16.8 
         <para>
          If the publisher is a <productname>PostgreSQL</productname> version
          before 16, then any initial table synchronization will use text format
          even if <literal>binary = true</literal>.
         </para>
________________________________________________________-->
         <para>
          如果发布者是<productname>PostgreSQL</productname> 16版本之前的版本，
          那么即使<literal>binary = true</literal>，任何初始表同步也将使用文本格式。
         </para>
<!-- pgdoc-cn_end sig_en=12a674c9d8327398ddfc1b49e0e69db8 -->
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-copy-data">
<!-- pgdoc-cn_start sig_en=1b81fe14306835b32fd2acd439a9c8b0 sig_cn_org=c6fd797d9a19da6d693d3e6f452eca2c source=15.7 
        <term><literal>copy_data</literal> (<type>boolean</type>)</term>
________________________________________________________-->
        <term><literal>copy_data</literal>（<type>boolean</type>）</term>
<!-- pgdoc-cn_end sig_en=1b81fe14306835b32fd2acd439a9c8b0 -->
        <listitem>
<!-- pgdoc-cn_start sig_en=8be274eeb0e22a3f8e8a3f168e7ac212 sig_cn_org=8d2a976e46283145376fb9fabe193a74 source=15.7 
         <para>
          Specifies whether to copy pre-existing data in the publications
          that are being subscribed to when the replication starts.
          The default is <literal>true</literal>.
         </para>
________________________________________________________-->
         <para>
          指定在复制开始时是否复制正在订阅的publication中的预先存在的数据。
          默认值为<literal>true</literal>。
         </para>
<!-- pgdoc-cn_end sig_en=8be274eeb0e22a3f8e8a3f168e7ac212 -->
<!-- pgdoc-cn_start sig_en=3f44ae0a5207dc9353631c7b2493d08c sig_cn_org=f79759d636dffaca981fe7a4dd3ecc3c source=15.7 
         <para>
          If the publications contain <literal>WHERE</literal> clauses, it
          will affect what data is copied. Refer to the
          <xref linkend="sql-createsubscription-notes" /> for details.
         </para>
________________________________________________________-->
         <para>
          如果publication包含<literal>WHERE</literal>子句，它将影响复制的数据。请参考
          <xref linkend="sql-createsubscription-notes" />获取详细信息。
         </para>
<!-- pgdoc-cn_end sig_en=3f44ae0a5207dc9353631c7b2493d08c -->
<!-- pgdoc-cn_start sig_en=fa6f1f5e23f565c46db62637d7a6af87 sig_cn_org=f5fa8433da10491397cad0c5f7bf004d source=16.8 
         <para>
          See <xref linkend="sql-createsubscription-notes"/> for details of how
          <literal>copy_data = true</literal> can interact with the
          <literal>origin</literal> parameter.
         </para>
________________________________________________________-->
         <para>
          请参阅<xref linkend="sql-createsubscription-notes"/>了解
          <literal>copy_data = true</literal>如何与
          <literal>origin</literal>参数交互的详细信息。
         </para>
<!-- pgdoc-cn_end sig_en=fa6f1f5e23f565c46db62637d7a6af87 -->
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-streaming">
<!-- pgdoc-cn_start sig_en=f629b7bf5a51c7a2655e8afdecc03ee6 sig_cn_org=e1e1d08befeb9049e3e4ae8399303efd source=16.8 
        <term><literal>streaming</literal> (<type>enum</type>)</term>
________________________________________________________-->
        <term><literal>流式处理</literal> (<type>enum</type>)</term>
<!-- pgdoc-cn_end sig_en=f629b7bf5a51c7a2655e8afdecc03ee6 -->
        <listitem>
<!-- pgdoc-cn_start sig_en=820232a7ca153fba587ef961087511ee sig_cn_org=6e61fe6723deeabe335b70eb61ee41e8 source=16.8 
         <para>
          Specifies whether to enable streaming of in-progress transactions
          for this subscription.  The default value is <literal>off</literal>,
          meaning all transactions are fully decoded on the publisher and only
          then sent to the subscriber as a whole.
         </para>
________________________________________________________-->
         <para>
          指定是否为此订阅启用正在进行的事务的流式传输。默认值为
          <literal>off</literal>，这意味着所有事务都会在发布者上完全解码，
          然后作为一个整体发送给订阅者。
         </para>
<!-- pgdoc-cn_end sig_en=820232a7ca153fba587ef961087511ee -->

<!-- pgdoc-cn_start sig_en=819bd57d89bfbd085132776a89b2f224 sig_cn_org=f6c9f46e0fc03bb3645c1d8d22f53f0f source=16.8 
         <para>
          If set to <literal>on</literal>, the incoming changes are written to
          temporary files and then applied only after the transaction is
          committed on the publisher and received by the subscriber.
         </para>
________________________________________________________-->
         <para>
          如果设置为<literal>on</literal>，传入的更改将被写入临时文件，
          并且只有在发布者提交事务并由订阅者接收后才会应用。
         </para>
<!-- pgdoc-cn_end sig_en=819bd57d89bfbd085132776a89b2f224 -->

<!-- pgdoc-cn_start sig_en=05c915ffdb9bc85347f02dc8c9386f14 sig_cn_org=7e71a22eb176c5ce1c8365cedb14a4a0 source=16.8 
         <para>
          If set to <literal>parallel</literal>, incoming changes are directly
          applied via one of the parallel apply workers, if available. If no
          parallel apply worker is free to handle streaming transactions then
          the changes are written to temporary files and applied after the
          transaction is committed. Note that if an error happens in a
          parallel apply worker, the finish LSN of the remote transaction
          might not be reported in the server log.
         </para>
________________________________________________________-->
         <para>
          如果设置为<literal>parallel</literal>，传入的更改将直接通过一个并行应用
          工作线程（如果可用）进行应用。如果没有空闲的并行应用工作线程来处理流
          式事务，则更改会被写入临时文件，并在事务提交后应用。请注意，如果在并
          行应用工作线程中发生错误，远程事务的完成LSN可能不会在服务器日志中报
          告。
         </para>
<!-- pgdoc-cn_end sig_en=05c915ffdb9bc85347f02dc8c9386f14 -->
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-synchronous-commit">
<!-- pgdoc-cn_start sig_en=bf39b8a31009fb17c8b8ad039e2f4bc8 sig_cn_org=f3a4348ee27c4494ce1ccdd219654180 source=15.7 
        <term><literal>synchronous_commit</literal> (<type>enum</type>)</term>
________________________________________________________-->
        <term><literal>synchronous_commit</literal> (<type>enum</type>)</term>
<!-- pgdoc-cn_end sig_en=bf39b8a31009fb17c8b8ad039e2f4bc8 -->
        <listitem>
<!-- pgdoc-cn_start sig_en=bbefcda69b2a192f6b0ae3ce63e354d9 sig_cn_org=e5dc27e90ce87e7a1b71223b7edf6766 source=15.7 
         <para>
          The value of this parameter overrides the
          <xref linkend="guc-synchronous-commit"/> setting within this
          subscription's apply worker processes.  The default value
          is <literal>off</literal>.
         </para>
________________________________________________________-->
         <para>
          此参数的值将覆盖此订阅的应用工作进程中的
          <xref linkend="guc-synchronous-commit"/>设置。默认值为
          <literal>off</literal>。
         </para>
<!-- pgdoc-cn_end sig_en=bbefcda69b2a192f6b0ae3ce63e354d9 -->

<!-- pgdoc-cn_start sig_en=156f425b4fe3bb962005d547c8aab0a3 sig_cn_org=d7cc091a851a058bb6cefb744d47ace0 source=15.7 
         <para>
          It is safe to use <literal>off</literal> for logical replication:
          If the subscriber loses transactions because of missing
          synchronization, the data will be sent again from the publisher.
         </para>
________________________________________________________-->
         <para>
          使用<literal>off</literal>对于逻辑复制是安全的：
          如果订阅者由于缺少同步而丢失事务，则数据将再次从发布者发送。
         </para>
<!-- pgdoc-cn_end sig_en=156f425b4fe3bb962005d547c8aab0a3 -->

<!-- pgdoc-cn_start sig_en=2dd25a1a3bd2a92f11face54d8724c84 sig_cn_org=eedc55e31c109738c3b6d44e843b6602 source=15.7 
         <para>
          A different setting might be appropriate when doing synchronous
          logical replication.  The logical replication workers report the
          positions of writes and flushes to the publisher, and when using
          synchronous replication, the publisher will wait for the actual
          flush.  This means that setting
          <literal>synchronous_commit</literal> for the subscriber to
          <literal>off</literal> when the subscription is used for
          synchronous replication might increase the latency for
          <command>COMMIT</command> on the publisher.  In this scenario, it
          can be advantageous to set <literal>synchronous_commit</literal>
          to <literal>local</literal> or higher.
         </para>
________________________________________________________-->
         <para>
          在进行同步逻辑复制时，可能需要使用不同的设置。逻辑复制工作者会向发布者报告写入和刷新的位置，
          在使用同步复制时，发布者将等待实际的刷新。这意味着当订阅用于同步复制时，将订阅者的
          <literal>synchronous_commit</literal>设置为<literal>off</literal>可能会增加发布者上
          <command>COMMIT</command>的延迟。在这种情况下，将<literal>synchronous_commit</literal>
          设置为<literal>local</literal>或更高可能是有利的。
         </para>
<!-- pgdoc-cn_end sig_en=2dd25a1a3bd2a92f11face54d8724c84 -->
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-two-phase">
<!-- pgdoc-cn_start sig_en=62393a7a94252f528a3e5d0332346599 sig_cn_org=6367118acee35409abf7c59d070d8de9 source=15.7 
        <term><literal>two_phase</literal> (<type>boolean</type>)</term>
________________________________________________________-->
        <term><literal>two_phase</literal>（<type>boolean</type>）</term>
<!-- pgdoc-cn_end sig_en=62393a7a94252f528a3e5d0332346599 -->
        <listitem>
<!-- pgdoc-cn_start sig_en=acb606d19fa31110084a65b0f1e01007 sig_cn_org=8fbbf40579510ec58b237d08ac847bf0 source=15.7 
         <para>
          Specifies whether two-phase commit is enabled for this subscription.
          The default is <literal>false</literal>.
         </para>
________________________________________________________-->
         <para>
          指定是否为此订阅启用两阶段提交。默认值为<literal>false</literal>。
         </para>
<!-- pgdoc-cn_end sig_en=acb606d19fa31110084a65b0f1e01007 -->

<!-- pgdoc-cn_start sig_en=d6a38fa439c98b620397077787e5a82f sig_cn_org=f6260855b49a6d7beb09d8b37b55db9c source=15.7 
         <para>
          When two-phase commit is enabled, prepared transactions are sent
          to the subscriber at the time of <command>PREPARE
          TRANSACTION</command>, and are processed as two-phase
          transactions on the subscriber too.  Otherwise, prepared
          transactions are sent to the subscriber only when committed, and
          are then processed immediately by the subscriber.
         </para>
________________________________________________________-->
         <para>
          当启用两阶段提交时，准备好的事务会在<command>PREPARE TRANSACTION</command>时发送给订阅者，
          并在订阅者上也作为两阶段事务处理。否则，准备好的事务只有在提交时才会发送给
          订阅者，然后由订阅者立即处理。
         </para>
<!-- pgdoc-cn_end sig_en=d6a38fa439c98b620397077787e5a82f -->

<!-- pgdoc-cn_start sig_en=0003efcb9bd36050765a6fdd4f20792a sig_cn_org=efa1f19b432f3bb4649030a1ccf746c9 source=15.7 
         <para>
          The implementation of two-phase commit requires that replication
          has successfully finished the initial table synchronization
          phase. So even when <literal>two_phase</literal> is enabled for a
          subscription, the internal two-phase state remains
          temporarily <quote>pending</quote> until the initialization phase
          completes. See column <structfield>subtwophasestate</structfield>
          of <link linkend="catalog-pg-subscription"><structname>pg_subscription</structname></link>
          to know the actual two-phase state.
         </para>
________________________________________________________-->
         <para>
          两阶段提交的实现要求复制已成功完成初始表同步阶段。因此，即使为订阅启用了<literal>two_phase</literal>，
          内部的两阶段状态仍会暂时保持<quote>挂起</quote>，直到初始化阶段完成。
          参见<link linkend="catalog-pg-subscription"><structname>pg_subscription</structname></link>的<structfield>subtwophasestate</structfield>列，
          以了解实际的两阶段状态。
         </para>
<!-- pgdoc-cn_end sig_en=0003efcb9bd36050765a6fdd4f20792a -->

        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-disable-on-error">
<!-- pgdoc-cn_start sig_en=8ae364bc664865aa29e8fa33f49a4dce sig_cn_org=05ad2a5c34da5c1775b0d1c82ba6c1f3 source=15.7 
        <term><literal>disable_on_error</literal> (<type>boolean</type>)</term>
________________________________________________________-->
        <term><literal>disable_on_error</literal>（<type>boolean</type>）</term>
<!-- pgdoc-cn_end sig_en=8ae364bc664865aa29e8fa33f49a4dce -->
        <listitem>
<!-- pgdoc-cn_start sig_en=05a465819a9f9b27d4990318cf041433 sig_cn_org=93b86efa4f3de767e804c62f3339d6c6 source=15.7 
         <para>
          Specifies whether the subscription should be automatically disabled
          if any errors are detected by subscription workers during data
          replication from the publisher. The default is
          <literal>false</literal>.
         </para>
________________________________________________________-->
         <para>
          指定是否应在发布者进行数据复制期间，如果订阅工作者检测到任何错误，则自动禁用订阅。默认值为
          <literal>false</literal>。
         </para>
<!-- pgdoc-cn_end sig_en=05a465819a9f9b27d4990318cf041433 -->
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-password-required">
<!-- pgdoc-cn_start sig_en=f031d63bd4354f334ea3892fb1f301fc sig_cn_org=f031d63bd4354f334ea3892fb1f301fc source=16.8 
        <term><literal>password_required</literal> (<type>boolean</type>)</term>
________________________________________________________-->
        <term><literal>password_required</literal> (<type>boolean</type>)</term>
<!-- pgdoc-cn_end sig_en=f031d63bd4354f334ea3892fb1f301fc -->
        <listitem>
<!-- pgdoc-cn_start sig_en=3b22eac2f25f65437d1b923f8ef11301 sig_cn_org=f65d4e4fb3f61e90adef398dd9ebb4ac source=16.8 
         <para>
          If set to <literal>true</literal>, connections to the publisher made
          as a result of this subscription must use password authentication
          and the password must be specified as a part of the connection
          string. This setting is ignored when the subscription is owned by a
          superuser.  The default is <literal>true</literal>. Only superusers
          can set this value to <literal>false</literal>.
         </para>
________________________________________________________-->
         <para>
          如果设置为<literal>true</literal>，则由于此订阅建立的与发布者的连接
          必须使用密码认证，并且密码必须作为连接字符串的一部分指定。当订阅
          由超级用户拥有时，此设置将被忽略。默认值为<literal>true</literal>。
          只有超级用户可以将此值设置为<literal>false</literal>。
         </para>
<!-- pgdoc-cn_end sig_en=3b22eac2f25f65437d1b923f8ef11301 -->
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-run-as-owner">
<!-- pgdoc-cn_start sig_en=e7e36b68f247033d9c9ccdb522ad4c9a sig_cn_org=699550a1266249385a5cac2050eb7bab source=16.8 
        <term><literal>run_as_owner</literal> (<type>boolean</type>)</term>
________________________________________________________-->
        <term><literal>run_as_owner</literal> (<type>boolean</type>)</term>
<!-- pgdoc-cn_end sig_en=e7e36b68f247033d9c9ccdb522ad4c9a -->
        <listitem>
<!-- pgdoc-cn_start sig_en=c8111a530c6283270792cb0cc6438d1a sig_cn_org=60a87408fab294d62a1854785a8b9aac source=16.8 
         <para>
          If true, all replication actions are performed as the subscription
          owner. If false, replication workers will perform actions on each
          table as the owner of that table. The latter configuration is
          generally much more secure; for details, see
          <xref linkend="logical-replication-security" />.
          The default is <literal>false</literal>.
         </para>
________________________________________________________-->
         <para>
          如果为 true，所有复制操作都将以订阅者的身份执行。如果为 false，
          复制工作者将在每个表上以该表的所有者身份执行操作。后一种配置通常
          更加安全；详情请参见
          <xref linkend="logical-replication-security" />。
          默认值为 <literal>false</literal>。
         </para>
<!-- pgdoc-cn_end sig_en=c8111a530c6283270792cb0cc6438d1a -->
        </listitem>
       </varlistentry>

       <varlistentry id="sql-createsubscription-with-origin">
<!-- pgdoc-cn_start sig_en=780cbdbe1616577f4f61606d5496f334 sig_cn_org=780cbdbe1616577f4f61606d5496f334 source=16.8 
        <term><literal>origin</literal> (<type>string</type>)</term>
________________________________________________________-->
        <term><literal>origin</literal> (<type>string</type>)</term>
<!-- pgdoc-cn_end sig_en=780cbdbe1616577f4f61606d5496f334 -->
        <listitem>
<!-- pgdoc-cn_start sig_en=95190beea870241d086ed8e9d6d55513 sig_cn_org=2f7685a349f832204f4f673184a86ce8 source=16.8 
         <para>
          Specifies whether the subscription will request the publisher to only
          send changes that don't have an origin or send changes regardless of
          origin. Setting <literal>origin</literal> to <literal>none</literal>
          means that the subscription will request the publisher to only send
          changes that don't have an origin. Setting <literal>origin</literal>
          to <literal>any</literal> means that the publisher sends changes
          regardless of their origin. The default is <literal>any</literal>.
         </para>
________________________________________________________-->
         <para>
          指定订阅是否会请求发布者仅发送没有来源的更改，或者无论来源如何都发送
          更改。将<literal>origin</literal>设置为<literal>none</literal>表示订阅会请求
          发布者仅发送没有来源的更改。将<literal>origin</literal>设置为<literal>any</literal>
          表示发布者会发送无论来源如何的更改。默认值是<literal>any</literal>。
         </para>
<!-- pgdoc-cn_end sig_en=95190beea870241d086ed8e9d6d55513 -->
<!-- pgdoc-cn_start sig_en=fa6f1f5e23f565c46db62637d7a6af87 sig_cn_org=f5fa8433da10491397cad0c5f7bf004d source=16.8 
         <para>
          See <xref linkend="sql-createsubscription-notes"/> for details of how
          <literal>copy_data = true</literal> can interact with the
          <literal>origin</literal> parameter.
         </para>
________________________________________________________-->
         <para>
          请参阅<xref linkend="sql-createsubscription-notes"/>了解
          <literal>copy_data = true</literal>如何与
          <literal>origin</literal>参数交互的详细信息。
         </para>
<!-- pgdoc-cn_end sig_en=fa6f1f5e23f565c46db62637d7a6af87 -->
        </listitem>
       </varlistentry>
      </variablelist></para>

    </listitem>
   </varlistentry>
  </variablelist>

<!-- pgdoc-cn_start sig_en=9092a8a456f5bfaadd62d60bf74666bc sig_cn_org=922e30c3f8f87df3b135b8c245e8a30d source=16.8 
  <para>
   When specifying a parameter of type <type>boolean</type>, the
   <literal>=</literal> <replaceable class="parameter">value</replaceable>
   part can be omitted, which is equivalent to
   specifying <literal>TRUE</literal>.
  </para>
________________________________________________________-->
  <para>
   当指定类型为<type>boolean</type>的参数时，
   <literal>=</literal><replaceable class="parameter">值</replaceable>
   部分可以省略，这等同于指定<literal>TRUE</literal>。
  </para>
<!-- pgdoc-cn_end sig_en=9092a8a456f5bfaadd62d60bf74666bc -->
 </refsect1>

 <refsect1 id="sql-createsubscription-notes" xreflabel="Notes">
<!-- pgdoc-cn_start sig_en=c44fa43baeb4f69a8a2aa1ea108c6e97 sig_cn_org=None source=14.1 
  <title>Notes</title>
________________________________________________________-->
  <title>注意</title>
<!-- pgdoc-cn_end sig_en=c44fa43baeb4f69a8a2aa1ea108c6e97 -->

<!-- pgdoc-cn_start sig_en=425ba77d46ec4f7c4078ab3ede011077 sig_cn_org=None source=14.1 
  <para>
   See <xref linkend="logical-replication-security"/> for details on
   how to configure access control between the subscription and the
   publication instance.
  </para>
________________________________________________________-->
  <para>
   有关如何在订阅和发布实例之间配置访问控制的详细信息，请参见
   <xref linkend="logical-replication-security"/>。
  </para>
<!-- pgdoc-cn_end sig_en=425ba77d46ec4f7c4078ab3ede011077 -->

<!-- pgdoc-cn_start sig_en=a4039461db70c4a2ea37dc774c449d0c sig_cn_org=None source=14.1 
  <para>
   When creating a replication slot (the default behavior), <command>CREATE
   SUBSCRIPTION</command> cannot be executed inside a transaction block.
  </para>
________________________________________________________-->
  <para>
   创建复制槽时(默认行为), <command>CREATE
   SUBSCRIPTION</command>不能在事务块内部执行。
  </para>
<!-- pgdoc-cn_end sig_en=a4039461db70c4a2ea37dc774c449d0c -->

<!-- pgdoc-cn_start sig_en=42dbde2bbed8c55f3dc793a2cefe8748 sig_cn_org=b5682a13b1bc52b90de85534c41210d4 source=16.8 
  <para>
   Creating a subscription that connects to the same database cluster (for
   example, to replicate between databases in the same cluster or to replicate
   within the same database) will only succeed if the replication slot is not
   created as part of the same command.  Otherwise, the <command>CREATE
   SUBSCRIPTION</command> call will hang.  To make this work, create the
   replication slot separately (using the
   function <function>pg_create_logical_replication_slot</function> with the
   plugin name <literal>pgoutput</literal>) and create the subscription using
   the parameter <literal>create_slot = false</literal>.  See
   <xref linkend="logical-replication-subscription-examples-deferred-slot"/>
   for examples. This is an implementation restriction that might be lifted in a
   future release.
  </para>
________________________________________________________-->
  <para>
   创建一个连接到同一数据库集群的订阅（例如，在同一集群中的数据库之间
   进行复制或在同一数据库内进行复制）只有在复制槽未作为同一命令的一部分
   创建时才会成功。否则，<command>CREATE SUBSCRIPTION</command> 调用将会挂起。
   为了使其正常工作，请单独创建复制槽（使用函数
   <function>pg_create_logical_replication_slot</function>，插件名称为
   <literal>pgoutput</literal>），并使用参数
   <literal>create_slot = false</literal> 创建订阅。请参阅
   <xref linkend="logical-replication-subscription-examples-deferred-slot"/>
   以获取示例。这是一个实现限制，可能会在未来的版本中解除。
</para>
<!-- pgdoc-cn_end sig_en=42dbde2bbed8c55f3dc793a2cefe8748 -->

<!-- pgdoc-cn_start sig_en=1e1e06aeac7c6d3475c86ab98fdd3117 sig_cn_org=e62cfc1ce2fb0f48208a0d2c6362f0c5 source=16.8 
  <para>
   If any table in the publication has a <literal>WHERE</literal> clause, rows
   for which the <replaceable class="parameter">expression</replaceable>
   evaluates to false or null will not be published. If the subscription has
   several publications in which the same table has been published with
   different <literal>WHERE</literal> clauses, a row will be published if any
   of the expressions (referring to that publish operation) are satisfied. In
   the case of different <literal>WHERE</literal> clauses, if one of the
   publications has no <literal>WHERE</literal> clause (referring to that
   publish operation) or the publication is declared as
   <link linkend="sql-createpublication-for-all-tables"><literal>FOR ALL TABLES</literal></link>
   or <link linkend="sql-createpublication-for-tables-in-schema"><literal>FOR TABLES IN SCHEMA</literal></link>,
   rows are always published regardless of the definition of the other
   expressions. If the subscriber is a <productname>PostgreSQL</productname>
   version before 15, then any row filtering is ignored during the initial data
   synchronization phase. For this case, the user might want to consider
   deleting any initially copied data that would be incompatible with
   subsequent filtering. Because initial data synchronization does not take
   into account the publication
   <link linkend="sql-createpublication-with-publish"><literal>publish</literal></link>
   parameter when copying existing table data, some rows may be copied that
   would not be replicated using DML. See
   <xref linkend="logical-replication-subscription-examples"/> for examples.
  </para>
________________________________________________________-->
  <para>
   如果发布中的任何表包含<literal>WHERE</literal>子句，则对于
   <replaceable class="parameter">表达式</replaceable>计算结果为假或空的行将不会被发布。
   如果订阅包含多个发布，并且同一表在不同的<literal>WHERE</literal>子句下被发布，
   那么如果任何表达式（与该发布操作相关）满足条件，则该行将被发布。
   在不同<literal>WHERE</literal>子句的情况下，如果其中一个发布没有
   <literal>WHERE</literal>子句（与该发布操作相关），或者该发布被声明为
   <link linkend="sql-createpublication-for-all-tables"><literal>FOR ALL TABLES</literal></link>
   或
   <link linkend="sql-createpublication-for-tables-in-schema"><literal>FOR TABLES IN SCHEMA</literal></link>，
   则无论其他表达式的定义如何，行始终会被发布。
   如果订阅者是<productname>PostgreSQL</productname> 15 之前的版本，
   那么在初始数据同步阶段会忽略任何行过滤。
   对于这种情况，用户可能需要考虑删除任何最初复制的数据，这些数据可能与后续过滤不兼容。
   因为初始数据同步在复制现有表数据时不会考虑发布的
   <link linkend="sql-createpublication-with-publish"><literal>publish</literal></link>
   参数，所以可能会复制一些不会通过 DML 复制的行。
   有关示例，请参见
   <xref linkend="logical-replication-subscription-examples"/>。
</para>
<!-- pgdoc-cn_end sig_en=1e1e06aeac7c6d3475c86ab98fdd3117 -->

<!-- pgdoc-cn_start sig_en=aaac945fb0f79866d51dadcfc4ce674f sig_cn_org=6ea41971aa27ff88d045a4661f04156f source=15.7 
  <para>
   Subscriptions having several publications in which the same table has been
   published with different column lists are not supported.
  </para>
________________________________________________________-->
  <para>
   具有多个publication的订阅，其中同一表以不同的列列表发布，不受支持。
  </para>
<!-- pgdoc-cn_end sig_en=aaac945fb0f79866d51dadcfc4ce674f -->

<!-- pgdoc-cn_start sig_en=1b8ae17f0d043dfe1c475a1d653b1e53 sig_cn_org=89434fceb74a1688e20c83ff28023e8e source=15.7 
  <para>
   We allow non-existent publications to be specified so that users can add
   those later. This means
   <link linkend="catalog-pg-subscription"><structname>pg_subscription</structname></link>
   can have non-existent publications.
  </para>
________________________________________________________-->
  <para>
   我们允许指定不存在的publication，以便用户稍后添加。这意味着
   <link linkend="catalog-pg-subscription"><structname>pg_subscription</structname></link>
   可以有不存在的publication。
</para>
<!-- pgdoc-cn_end sig_en=1b8ae17f0d043dfe1c475a1d653b1e53 -->

<!-- pgdoc-cn_start sig_en=f07fdc0dbeb142224e3f1acebe65d262 sig_cn_org=98388348f5932416dacea348b9d0781d source=16.8 
  <para>
   When using a subscription parameter combination of
   <literal>copy_data = true</literal> and <literal>origin = NONE</literal>,
   the initial sync table data is copied directly from the publisher, meaning
   that knowledge of the true origin of that data is not possible. If the
   publisher also has subscriptions then the copied table data might have
   originated from further upstream. This scenario is detected and a WARNING is
   logged to the user, but the warning is only an indication of a potential
   problem; it is the user's responsibility to make the necessary checks to
   ensure the copied data origins are really as wanted or not.
  </para>
________________________________________________________-->
  <para>
   当使用订阅参数组合<literal>copy_data = true</literal>和
   <literal>origin = NONE</literal>时，初始同步表数据直接从发布者复制，
   这意味着无法得知这些数据的真正来源。如果发布者也有订阅，那么复制的
   表数据可能来自更上游的来源。此场景会被检测到，并向用户记录一条
   WARNING，但该警告仅是潜在问题的提示；用户有责任进行必要的检查，
   以确保复制的数据来源确实符合预期。
</para>
<!-- pgdoc-cn_end sig_en=f07fdc0dbeb142224e3f1acebe65d262 -->

<!-- pgdoc-cn_start sig_en=e566861432d720b2f8cefc4b47ec4dcd sig_cn_org=3c3c3a7ee7ff7031e591a53ed0bd3866 source=16.8 
  <para>
   To find which tables might potentially include non-local origins (due to
   other subscriptions created on the publisher) try this SQL query:
<programlisting>
# substitute &lt;pub-names&gt; below with your publication name(s) to be queried
SELECT DISTINCT PT.schemaname, PT.tablename
FROM pg_publication_tables PT,
     pg_subscription_rel PS
     JOIN pg_class C ON (C.oid = PS.srrelid)
     JOIN pg_namespace N ON (N.oid = C.relnamespace)
WHERE N.nspname = PT.schemaname AND
      C.relname = PT.tablename AND
      PT.pubname IN (&lt;pub-names&gt;);
</programlisting></para>
________________________________________________________-->
  <para>
   要查找哪些表可能包含非本地来源（由于发布者上创建的其他订阅），
   可以尝试以下SQL查询：
<programlisting>
# substitute &lt;pub-names&gt; below with your publication name(s) to be queried
SELECT DISTINCT PT.schemaname, PT.tablename
FROM pg_publication_tables PT,
     pg_subscription_rel PS
     JOIN pg_class C ON (C.oid = PS.srrelid)
     JOIN pg_namespace N ON (N.oid = C.relnamespace)
WHERE N.nspname = PT.schemaname AND
      C.relname = PT.tablename AND
      PT.pubname IN (&lt;pub-names&gt;);
</programlisting></para>
<!-- pgdoc-cn_end sig_en=e566861432d720b2f8cefc4b47ec4dcd -->

 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=8f24ed0a9e4d47ffa2be9a1f3e09fa6d sig_cn_org=None source=14.1 
  <title>Examples</title>
________________________________________________________-->
  <title>示例</title>
<!-- pgdoc-cn_end sig_en=8f24ed0a9e4d47ffa2be9a1f3e09fa6d -->

<!-- pgdoc-cn_start sig_en=15f5e3b2021bb31c4c1bd6889debdeaf sig_cn_org=None source=14.1 
  <para>
   Create a subscription to a remote server that replicates tables in
   the publications <literal>mypublication</literal> and
   <literal>insert_only</literal> and starts replicating immediately on
   commit:
<programlisting>
CREATE SUBSCRIPTION mysub
         CONNECTION 'host=192.168.1.50 port=5432 user=foo dbname=foodb'
        PUBLICATION mypublication, insert_only;
</programlisting>
  </para>
________________________________________________________-->
  <para>
   创建一个到远程服务器的订阅，复制发布<literal>mypublication</literal>和
   <literal>insert_only</literal>中的表，并在提交时立即开始复制：
<programlisting>
CREATE SUBSCRIPTION mysub
         CONNECTION 'host=192.168.1.50 port=5432 user=foo dbname=foodb'
        PUBLICATION mypublication, insert_only;
</programlisting>
  </para>
<!-- pgdoc-cn_end sig_en=15f5e3b2021bb31c4c1bd6889debdeaf -->

<!-- pgdoc-cn_start sig_en=78de4c2a5027751b8ea08c14ec05d17f sig_cn_org=None source=14.1 
  <para>
   Create a subscription to a remote server that replicates tables in
   the <literal>insert_only</literal> publication and does not start replicating
   until enabled at a later time.
<programlisting>
CREATE SUBSCRIPTION mysub
         CONNECTION 'host=192.168.1.50 port=5432 user=foo dbname=foodb'
        PUBLICATION insert_only
               WITH (enabled = false);
</programlisting></para>
________________________________________________________-->
  <para>
   创建一个到远程服务器的订阅，复制<literal>insert_only</literal>发布中的表，
   并且不开始复制直到稍后启用复制。
<programlisting>
CREATE SUBSCRIPTION mysub
         CONNECTION 'host=192.168.1.50 port=5432 user=foo dbname=foodb'
        PUBLICATION insert_only
               WITH (enabled = false);
</programlisting></para>
<!-- pgdoc-cn_end sig_en=78de4c2a5027751b8ea08c14ec05d17f -->
 </refsect1>

