-->

<refentry id="app-initdb">
<!-- pgdoc-cn_start sig_en=ea9ba0b97e52876d7ab4e1ee6fb8abde sig_cn_org=None source=14.1 
 <indexterm zone="app-initdb">
  <primary>initdb</primary>
 </indexterm>
________________________________________________________-->
 <indexterm zone="app-initdb">
  <primary>initdb</primary>
 </indexterm>
<!-- pgdoc-cn_end sig_en=ea9ba0b97e52876d7ab4e1ee6fb8abde -->

 <refmeta>
  <refentrytitle><application>initdb</application></refentrytitle>
  <manvolnum>1</manvolnum>
  <refmiscinfo>Application</refmiscinfo>
 </refmeta>

<!-- pgdoc-cn_start sig_en=13b8d870abee64140c8c5eb065754f38 sig_cn_org=None source=14.1 
 <refnamediv>
  <refname>initdb</refname>
  <refpurpose>create a new <productname>PostgreSQL</productname> database cluster</refpurpose>
 </refnamediv>
________________________________________________________-->
 <refnamediv>
  <refname>initdb</refname>
  <refpurpose>创建一个新的<productname>PostgreSQL</productname>数据库集群</refpurpose>
 </refnamediv>
<!-- pgdoc-cn_end sig_en=13b8d870abee64140c8c5eb065754f38 -->

 <refsynopsisdiv>
  <cmdsynopsis>
   <command>initdb</command>
   <arg rep="repeat"><replaceable>option</replaceable></arg>
   <group choice="plain">
    <group choice="opt">
     <arg choice="plain"><option>--pgdata</option></arg>
     <arg choice="plain"><option>-D</option></arg>
    </group>
    <replaceable> directory</replaceable>
   </group>
  </cmdsynopsis>
 </refsynopsisdiv>

 <refsect1 id="r1-app-initdb-1">
<!-- pgdoc-cn_start sig_en=59d6e86f3a60db4f1e08d0d6e639924e sig_cn_org=None source=14.1 
  <title>Description</title>
________________________________________________________-->
  <title>描述</title>
<!-- pgdoc-cn_end sig_en=59d6e86f3a60db4f1e08d0d6e639924e -->
<!-- pgdoc-cn_start sig_en=f351bcf6dc9ce4dcff2f88a9ddeefc2f sig_cn_org=afc62c1f94ec1e3b1c3a650180140f54 source=16.8 
  <para>
   <command>initdb</command> creates a new
   <productname>PostgreSQL</productname> <glossterm linkend="glossary-db-cluster">database cluster</glossterm>.
  </para>
________________________________________________________-->
  <para>
   <command>initdb</command> 创建了一个新的
   <productname>PostgreSQL</productname> <glossterm linkend="glossary-db-cluster">数据库集簇</glossterm>。
  </para>
<!-- pgdoc-cn_end sig_en=f351bcf6dc9ce4dcff2f88a9ddeefc2f -->

<!-- pgdoc-cn_start sig_en=08cc7ff130d7ef4ce0725a0172e0ffbf sig_cn_org=5b59df9ab216712235c3b16aa3a16b02 source=16.8 
  <para>
   Creating a database cluster consists of creating the
   <glossterm linkend="glossary-data-directory">directories</glossterm> in
   which the cluster data will live, generating the shared catalog
   tables (tables that belong to the whole cluster rather than to any
   particular database), and creating the <literal>postgres</literal>,
   <literal>template1</literal>, and <literal>template0</literal> databases.
   The <literal>postgres</literal> database is a default database meant
   for use by users, utilities and third party applications.
   <literal>template1</literal> and <literal>template0</literal> are
   meant as source databases to be copied by later <command>CREATE
   DATABASE</command> commands.  <literal>template0</literal> should never
   be modified, but you can add objects to <literal>template1</literal>,
   which by default will be copied into databases created later.  See
   <xref linkend="manage-ag-templatedbs"/> for more details.
  </para>
________________________________________________________-->
  <para>
   创建数据库集群包括创建
   <glossterm linkend="glossary-data-directory">目录</glossterm>，这些目录是
   集群数据存储的地方，生成共享目录表（属于整个集群而不是任何特定数据库的表），
   并创建<literal>postgres</literal>、<literal>template1</literal>和
   <literal>template0</literal>数据库。
   <literal>postgres</literal>数据库是一个默认数据库，供用户、工具和第三方应用程序使用。
   <literal>template1</literal>和<literal>template0</literal>是
   用作源数据库的，稍后由<command>CREATE DATABASE</command>命令复制。
   <literal>template0</literal>不应被修改，但您可以向<literal>template1</literal>添加对象，
   默认情况下，这些对象会被复制到稍后创建的数据库中。有关更多详细信息，请参阅
   <xref linkend="manage-ag-templatedbs"/>。
</para>
<!-- pgdoc-cn_end sig_en=08cc7ff130d7ef4ce0725a0172e0ffbf -->

<!-- pgdoc-cn_start sig_en=39e0caecf409bf03891352fb3635d8b0 sig_cn_org=None source=14.1 
  <para>
   Although <command>initdb</command> will attempt to create the
   specified data directory, it might not have permission if the parent
   directory of the desired data directory is root-owned. To initialize
   in such a setup, create an empty data directory as root, then use
   <command>chown</command> to assign ownership of that directory to the
   database user account, then <command>su</command> to become the
   database user to run <command>initdb</command>.
  </para>
________________________________________________________-->
  <para>
   尽管<command>initdb</command>将尝试创建指定的数据目录，但如果想要的数据目录的父目录被根用户拥有，它可能没有权限。要在这样一种设置中初始化，作为 root 创建一个空数据目录，然后使用<command>chown</command>将该目录赋予给数据库用户账户，再然后<command>su</command>成为该数据库用户并运行<command>initdb</command>。
  </para>
<!-- pgdoc-cn_end sig_en=39e0caecf409bf03891352fb3635d8b0 -->

<!-- pgdoc-cn_start sig_en=7f372014d7105436ed97bf4e2c3a619a sig_cn_org=None source=14.1 
  <para>
   <command>initdb</command> must be run as the user that will own the
   server process, because the server needs to have access to the
   files and directories that <command>initdb</command> creates.
   Since the server cannot be run as root, you must not run
   <command>initdb</command> as root either.  (It will in fact refuse
   to do so.)
  </para>
________________________________________________________-->
  <para>
   <command>initdb</command>必须以将拥有该服务器进程的用户运行，因为该服务器需要访问<command>initdb</command>创建的文件和目录。因为该服务器不能作为 root 运行，你不能以 root 运行<command>initdb</command>（事实上它会拒绝这样做）。
  </para>
<!-- pgdoc-cn_end sig_en=7f372014d7105436ed97bf4e2c3a619a -->

<!-- pgdoc-cn_start sig_en=4ef9431c373764d5e56c5e3531600d78 sig_cn_org=None source=14.1 
  <para>
    For security reasons the new cluster created by <command>initdb</command>
    will only be accessible by the cluster owner by default.  The
    <option>-&minus;allow-group-access</option> option allows any user in the same
    group as the cluster owner to read files in the cluster.  This is useful
    for performing backups as a non-privileged user.
  </para>
________________________________________________________-->
  <para>
    由于安全原因，由<command>initdb</command>创建的新集簇默认将只能由集簇拥有者访问。<option>--allow-group-access</option>选项允许与集簇拥有者同组的任何用户读取集簇中的文件。这对非特权用户执行备份很有用。
  </para>
<!-- pgdoc-cn_end sig_en=4ef9431c373764d5e56c5e3531600d78 -->

<!-- pgdoc-cn_start sig_en=f5276c0b5e5a53472a790857813e0bb5 sig_cn_org=a20a13a6f840438a0c6798c874ae725e source=16.8 
  <para>
   <command>initdb</command> initializes the database cluster's default locale
   and character set encoding. These can also be set separately for each
   database when it is created. <command>initdb</command> determines those
   settings for the template databases, which will serve as the default for
   all other databases.
  </para>
________________________________________________________-->
  <para>
   <command>initdb</command> 初始化了数据库集群的默认区域设置和字符集编码。
   这些也可以在创建每个数据库时单独设置。<command>initdb</command> 确定了
   模板数据库的这些设置，这些设置将作为所有其他数据库的默认值。
  </para>
<!-- pgdoc-cn_end sig_en=f5276c0b5e5a53472a790857813e0bb5 -->

<!-- pgdoc-cn_start sig_en=2a6c382692e819f4b8babc7994ef97a5 sig_cn_org=9a1f03a7c91a5d9818d039418ef366f9 source=16.8 
  <para>
   By default, <command>initdb</command> uses the locale provider
   <literal>libc</literal> (see <xref linkend="locale-providers"/>). The
   <literal>libc</literal> locale provider takes the locale settings from the
   environment, and determines the encoding from the locale settings.
  </para>
________________________________________________________-->
  <para>
   默认情况下，<command>initdb</command> 使用区域设置提供程序
   <literal>libc</literal>（参见 <xref linkend="locale-providers"/>）。该
   <literal>libc</literal> 区域设置提供程序从环境中获取区域设置，并根据
   区域设置确定编码。
</para>
<!-- pgdoc-cn_end sig_en=2a6c382692e819f4b8babc7994ef97a5 -->

<!-- pgdoc-cn_start sig_en=bb3a76378c6015c231a41c49323a0f3c sig_cn_org=ab54702807541f180b5849113064dcef source=16.8 
  <para>
   To choose a different locale for the cluster, use the option
   <option>-&minus;locale</option>.  There are also individual options
   <option>-&minus;lc-*</option> and <option>-&minus;icu-locale</option> (see below) to
   set values for the individual locale categories.  Note that inconsistent
   settings for different locale categories can give nonsensical results, so
   this should be used with care.
  </para>
________________________________________________________-->
  <para>
   要为集群选择不同的区域设置，请使用选项
   <option>--locale</option>。此外，还有单独的选项
   <option>--lc-*</option> 和 <option>--icu-locale</option>（见下文）来
   为各个区域设置类别设置值。请注意，不同区域设置类别的不一致
   设置可能会导致无意义的结果，因此应谨慎使用。
</para>
<!-- pgdoc-cn_end sig_en=bb3a76378c6015c231a41c49323a0f3c -->

<!-- pgdoc-cn_start sig_en=126935508d0e4fbc87e2c67577042e8d sig_cn_org=f0a96ba16e658182ca7e6647eeaa7056 source=16.8 
  <para>
   Alternatively, <command>initdb</command> can use the ICU library to provide
   locale services by specifying <literal>-&minus;locale-provider=icu</literal>. The
   server must be built with ICU support. To choose the specific ICU locale ID
   to apply, use the option <option>-&minus;icu-locale</option>.  Note that for
   implementation reasons and to support legacy code,
   <command>initdb</command> will still select and initialize libc locale
   settings when the ICU locale provider is used.
  </para>
________________________________________________________-->
  <para>
   或者，可以通过指定<literal>--locale-provider=icu</literal>，让<command>initdb</command>
   使用ICU库来提供区域设置服务。服务器必须支持ICU。要选择要应用的特定ICU区域ID，
   请使用选项<option>--icu-locale</option>。请注意，由于实现原因以及支持遗留代码，
   当使用ICU区域设置提供程序时，<command>initdb</command>仍然会选择并初始化libc
   区域设置。
</para>
<!-- pgdoc-cn_end sig_en=126935508d0e4fbc87e2c67577042e8d -->

<!-- pgdoc-cn_start sig_en=21ccb5f087201cc0b536e1183b5dff1c sig_cn_org=791eeefb607b4ef6bde824a9d7a5b9f2 source=15.7 
  <para>
   When <command>initdb</command> runs, it will print out the locale settings
   it has chosen.  If you have complex requirements or specified multiple
   options, it is advisable to check that the result matches what was
   intended.
  </para>
________________________________________________________-->
  <para>
   当<command>initdb</command>运行时，它会打印出所选择的区域设置。如果您有复杂的要求或指定了多个选项，
   建议检查结果是否符合预期。
</para>
<!-- pgdoc-cn_end sig_en=21ccb5f087201cc0b536e1183b5dff1c -->

<!-- pgdoc-cn_start sig_en=98b3a5f7d34d63ca299023e0e088b4de sig_cn_org=50e278b3216c99e97d18bdc4236e1073 source=15.7 
  <para>
   More details about locale settings can be found in <xref
   linkend="locale"/>.
  </para>
________________________________________________________-->
  <para>
   更多有关区域设置的详细信息可以在<xref linkend="locale"/>中找到。
</para>
<!-- pgdoc-cn_end sig_en=98b3a5f7d34d63ca299023e0e088b4de -->

<!-- pgdoc-cn_start sig_en=40c2c0bcc7122827d0833180a58d4885 sig_cn_org=None source=14.1 
  <para>
   To alter the default encoding, use the <option>-&minus;encoding</option>.
   More details can be found in <xref linkend="multibyte"/>.
  </para>
________________________________________________________-->
  <para>
   要修改默认编码，使用<option>--encoding</option>。更多详细信息可以在<xref linkend="multibyte"/>中找到。
  </para>
<!-- pgdoc-cn_end sig_en=40c2c0bcc7122827d0833180a58d4885 -->

 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=ee3f399228d18d2103d5b7f4e0aeeba8 sig_cn_org=None source=14.1 
  <title>Options</title>
________________________________________________________-->
  <title>选项</title>
<!-- pgdoc-cn_end sig_en=ee3f399228d18d2103d5b7f4e0aeeba8 -->

   <para>
    <variablelist>
     <varlistentry id="app-initdb-option-auth">
      <term><option>-A <replaceable class="parameter">authmethod</replaceable></option></term>
      <term><option>--auth=<replaceable class="parameter">authmethod</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=ee2d50abbeb86237cf8f7003f680ac79 sig_cn_org=ed8ee199d96cc00152aec8b5e6dd4f89 source=15.7 
       <para>
        This option specifies the default authentication method for local
        users used in <filename>pg_hba.conf</filename> (<literal>host</literal>
        and <literal>local</literal> lines).  See <xref linkend="auth-pg-hba-conf"/>
        for an overview of valid values.
       </para>
________________________________________________________-->
       <para>
        这个选项指定了用于<filename>pg_hba.conf</filename>（<literal>host</literal>和<literal>local</literal>行）中使用的本地用户的默认身份验证方法。
        有关有效值的概述，请参阅<xref linkend="auth-pg-hba-conf"/>。
       </para>
<!-- pgdoc-cn_end sig_en=ee2d50abbeb86237cf8f7003f680ac79 -->

<!-- pgdoc-cn_start sig_en=12e1c73dd9b5a1b919b5004d4a71a87b sig_cn_org=96809dc51195325c5cc2a0228844e3fa source=15.7 
       <para>
        <command>initdb</command> will
        prepopulate <filename>pg_hba.conf</filename> entries using the
        specified authentication method for non-replication as well as
        replication connections.
       </para>
________________________________________________________-->
       <para>
        <command>initdb</command>将使用指定的身份验证方法为非复制连接和复制连接预填充<filename>pg_hba.conf</filename>条目。
       </para>
<!-- pgdoc-cn_end sig_en=12e1c73dd9b5a1b919b5004d4a71a87b -->

<!-- pgdoc-cn_start sig_en=0327cf48d7324e554a97c7a28d3d28e4 sig_cn_org=6bcf296f3d7d2bfa925e9cf2a89e58c2 source=15.7 
       <para>
        Do not use <literal>trust</literal> unless you trust all local users on your
        system.  <literal>trust</literal> is the default for ease of installation.
       </para>
________________________________________________________-->
       <para>
        不要使用<literal>trust</literal>，除非您信任系统上的所有本地用户。<literal>trust</literal>是为了安装方便而默认设置的。
       </para>
<!-- pgdoc-cn_end sig_en=0327cf48d7324e554a97c7a28d3d28e4 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-auth-host">
      <term><option>--auth-host=<replaceable class="parameter">authmethod</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=7b6b61cdfcd307e4f262db161ed32676 sig_cn_org=84f6966a00db2838c081342ba79c281d source=15.7 
       <para>
        This option specifies the authentication method for local users via
        TCP/IP connections used in <filename>pg_hba.conf</filename>
        (<literal>host</literal> lines).
       </para>
________________________________________________________-->
       <para>
        该选项指定了通过TCP/IP连接在<filename>pg_hba.conf</filename>（<literal>host</literal>行）中使用的本地用户的身份验证方法。
       </para>
<!-- pgdoc-cn_end sig_en=7b6b61cdfcd307e4f262db161ed32676 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-auth-local">
      <term><option>--auth-local=<replaceable class="parameter">authmethod</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=77a687e9047d0ffdb253f3f443f77a75 sig_cn_org=8adc2437b14e090a7c378d2cb80d1a2e source=15.7 
       <para>
        This option specifies the authentication method for local users via
        Unix-domain socket connections used in <filename>pg_hba.conf</filename>
        (<literal>local</literal> lines).
       </para>
________________________________________________________-->
       <para>
        这个选项指定了本地用户通过Unix域套接字连接在<filename>pg_hba.conf</filename>
        （<literal>local</literal>行）中使用的身份验证方法。
       </para>
<!-- pgdoc-cn_end sig_en=77a687e9047d0ffdb253f3f443f77a75 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-pgdata">
      <term><option>-D <replaceable class="parameter">directory</replaceable></option></term>
      <term><option>--pgdata=<replaceable class="parameter">directory</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=cd11fec9ad4d2c2e797bba5acb1ec7e4 sig_cn_org=8a4b258fa2e54a2e7ee7d7926596cc6c source=16.8 
       <para>
        This option specifies the directory where the database cluster
        should be stored. This is the only information required by
        <command>initdb</command>, but you can avoid writing it by
        setting the <envar>PGDATA</envar> environment variable, which
        can be convenient since the database server
        (<command>postgres</command>) can find the data
        directory later by the same variable.
       </para>
________________________________________________________-->
       <para>
        此选项指定应存储数据库集群的目录。这是
        <command>initdb</command>所需的唯一信息，但您可以通过设置
        <envar>PGDATA</envar>环境变量来避免手动输入，这样会更方便，
        因为数据库服务器(<command>postgres</command>)稍后可以通过
        相同的变量找到数据目录。
       </para>
<!-- pgdoc-cn_end sig_en=cd11fec9ad4d2c2e797bba5acb1ec7e4 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-encoding">
      <term><option>-E <replaceable class="parameter">encoding</replaceable></option></term>
      <term><option>--encoding=<replaceable class="parameter">encoding</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=0775444b06f16debfa7a944680e9b719 sig_cn_org=d08ca4b7365c4f997c4b22d6307a7989 source=16.8 
       <para>
        Selects the encoding of the template databases. This will also be the
        default encoding of any database you create later, unless you override
        it then. The character sets supported by the
        <productname>PostgreSQL</productname> server are described in <xref
        linkend="multibyte-charset-supported"/>.
       </para>
________________________________________________________-->
       <para>
        选择模板数据库的编码。这也将是您之后创建的任何数据库的默认编码，
        除非您在创建时覆盖它。<productname>PostgreSQL</productname>服务器支持的字符集
        在<xref linkend="multibyte-charset-supported"/>中进行了描述。
</para>
<!-- pgdoc-cn_end sig_en=0775444b06f16debfa7a944680e9b719 -->
<!-- pgdoc-cn_start sig_en=f5d1f7bb305e9a866668d2304dd8ad81 sig_cn_org=ad2052e08b28393d617c153f68208edf source=16.8 
       <para>
        By default, the template database encoding is derived from the
        locale. If <xref linkend="app-initdb-option-no-locale"/> is specified
        (or equivalently, if the locale is <literal>C</literal> or
        <literal>POSIX</literal>), then the default is <literal>UTF8</literal>
        for the ICU provider and <literal>SQL_ASCII</literal> for the
        <literal>libc</literal> provider.
       </para>
________________________________________________________-->
       <para>
        默认情况下，模板数据库的编码是从区域设置中派生的。如果指定了
        <xref linkend="app-initdb-option-no-locale"/>（或者等效地，如果区域设置是
        <literal>C</literal>或<literal>POSIX</literal>），那么对于ICU提供程序，
        默认编码是<literal>UTF8</literal>，而对于<literal>libc</literal>提供程序，
        默认编码是<literal>SQL_ASCII</literal>。
       </para>
<!-- pgdoc-cn_end sig_en=f5d1f7bb305e9a866668d2304dd8ad81 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-allow-group-access" xreflabel="group access">
      <term><option>-g</option></term>
      <term><option>--allow-group-access</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=422101289e3e7462131b348f3993a317 sig_cn_org=5a48725fe1ab353c7c09f8c942a9d053 source=15.7 
       <para>
        Allows users in the same group as the cluster owner to read all cluster
        files created by <command>initdb</command>.  This option is ignored
        on <productname>Windows</productname> as it does not support
        <acronym>POSIX</acronym>-style group permissions.
       </para>
________________________________________________________-->
       <para>
        允许与集群所有者在同一组中的用户读取由<command>initdb</command>创建的所有集群文件。
        此选项在<productname>Windows</productname>上被忽略，因为它不支持<acronym>POSIX</acronym>风格的组权限。
       </para>
<!-- pgdoc-cn_end sig_en=422101289e3e7462131b348f3993a317 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-icu-locale">
      <term><option>--icu-locale=<replaceable>locale</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=077a10a4409307fcd468689d09dc1151 sig_cn_org=117ef6aeafa73339d73eb187ad22c86b source=16.8 
       <para>
        Specifies the ICU locale when the ICU provider is used. Locale support
        is described in <xref linkend="locale"/>.
       </para>
________________________________________________________-->
       <para>
        指定使用ICU提供程序时的ICU语言环境。语言环境支持在
        <xref linkend="locale"/>中描述。
</para>
<!-- pgdoc-cn_end sig_en=077a10a4409307fcd468689d09dc1151 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-icu-rules">
      <term><option>--icu-rules=<replaceable>rules</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=13b9b84ed752aedd86aeb5fd03808b0c sig_cn_org=9de8c7e2af5151ac9e752ccf0310a075 source=16.8 
       <para>
        Specifies additional collation rules to customize the behavior of the
        default collation.  This is supported for ICU only.
       </para>
________________________________________________________-->
       <para>
        指定附加的排序规则以自定义默认排序的行为。这仅支持ICU。
       </para>
<!-- pgdoc-cn_end sig_en=13b9b84ed752aedd86aeb5fd03808b0c -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-data-checksums" xreflabel="data checksums">
      <term><option>-k</option></term>
      <term><option>--data-checksums</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=48b8e5861428752ca191eb24e78490e5 sig_cn_org=26dd7270d36884d5920bb24716486d2d source=15.7 
       <para>
        Use checksums on data pages to help detect corruption by the
        I/O system that would otherwise be silent. Enabling checksums
        may incur a noticeable performance penalty. If set, checksums
        are calculated for all objects, in all databases. All checksum
        failures will be reported in the
        <link linkend="monitoring-pg-stat-database-view">
        <structname>pg_stat_database</structname></link> view.
        See <xref linkend="checksums" /> for details.
       </para>
________________________________________________________-->
       <para>
        使用数据页上的校验和来帮助检测I/O系统可能会默默发生的损坏。启用校验和可能会导致明显的性能损失。如果设置了校验和，将为所有对象在所有数据库中计算校验和。所有校验失败将在
        <link linkend="monitoring-pg-stat-database-view">
        <structname>pg_stat_database</structname></link> 视图中报告。详细信息请参见<xref linkend="checksums" />。
       </para>
<!-- pgdoc-cn_end sig_en=48b8e5861428752ca191eb24e78490e5 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-locale">
      <term><option>--locale=<replaceable>locale</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=33bef41e04fda7607a5ec06a5c283d61 sig_cn_org=e3b7a8210a387deeec7e1c3138511d2a source=15.7 
       <para>
        Sets the default locale for the database cluster.  If this
        option is not specified, the locale is inherited from the
        environment that <command>initdb</command> runs in. Locale
        support is described in <xref linkend="locale"/>.
       </para>
________________________________________________________-->
       <para>
        设置数据库集群的默认语言环境。如果未指定此选项，则语言环境将从<command>initdb</command>运行的环境继承。
        语言环境支持在<xref linkend="locale"/>中描述。
       </para>
<!-- pgdoc-cn_end sig_en=33bef41e04fda7607a5ec06a5c283d61 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-lc-collate">
      <term><option>--lc-collate=<replaceable>locale</replaceable></option></term>
      <term><option>--lc-ctype=<replaceable>locale</replaceable></option></term>
      <term><option>--lc-messages=<replaceable>locale</replaceable></option></term>
      <term><option>--lc-monetary=<replaceable>locale</replaceable></option></term>
      <term><option>--lc-numeric=<replaceable>locale</replaceable></option></term>
      <term><option>--lc-time=<replaceable>locale</replaceable></option></term>

      <listitem>
<!-- pgdoc-cn_start sig_en=5ca6e6ff0adad12b4273cedbe1d66e0a sig_cn_org=0b7f0636906489b1708090e69dfd9be8 source=15.7 
       <para>
        Like <option>-&minus;locale</option>, but only sets the locale in
        the specified category.
       </para>
________________________________________________________-->
       <para>
        类似于<option>--locale</option>，但仅在指定的类别中设置语言环境。
       </para>
<!-- pgdoc-cn_end sig_en=5ca6e6ff0adad12b4273cedbe1d66e0a -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-no-locale">
      <term><option>--no-locale</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=128a5dcb6a40337e081b206d71000399 sig_cn_org=05e74546c10404bc3941166904d5278a source=15.7 
       <para>
        Equivalent to <option>-&minus;locale=C</option>.
       </para>
________________________________________________________-->
       <para>
        等同于<option>--locale=C</option>。
       </para>
<!-- pgdoc-cn_end sig_en=128a5dcb6a40337e081b206d71000399 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-locale-provider">
      <term><option>--locale-provider={<literal>libc</literal>|<literal>icu</literal>}</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=e43feb78f8d85b530033f112a941d266 sig_cn_org=83289ee8678bf7cebcd6613c2c6c1805 source=16.8 
       <para>
        This option sets the locale provider for databases created in the new
        cluster.  It can be overridden in the <command>CREATE
        DATABASE</command> command when new databases are subsequently
        created.  The default is <literal>libc</literal> (see <xref
        linkend="locale-providers"/>).
       </para>
________________________________________________________-->
       <para>
        此选项为新集群中创建的数据库设置区域设置提供程序。它可以在随后创建新数据库时通过
        <command>CREATE DATABASE</command>命令覆盖。默认值是<literal>libc</literal>
        （参见<xref linkend="locale-providers"/>）。
       </para>
<!-- pgdoc-cn_end sig_en=e43feb78f8d85b530033f112a941d266 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-no-sync">
      <term><option>-N</option></term>
      <term><option>--no-sync</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=64fdc9df83aa0718ebe4717af883eb33 sig_cn_org=7664a1581c39bd4875b52fe8c6575096 source=15.7 
       <para>
        By default, <command>initdb</command> will wait for all files to be
        written safely to disk.  This option causes <command>initdb</command>
        to return without waiting, which is faster, but means that a
        subsequent operating system crash can leave the data directory
        corrupt.  Generally, this option is useful for testing, but should not
        be used when creating a production installation.
       </para>
________________________________________________________-->
       <para>
        默认情况下，<command>initdb</command>将等待所有文件被安全写入磁盘。
        此选项导致<command>initdb</command>在不等待的情况下返回，这样更快，
        但意味着随后的操作系统崩溃可能会使数据目录损坏。通常，此选项在测试时很有用，
        但在创建生产安装时不应使用。
       </para>
<!-- pgdoc-cn_end sig_en=64fdc9df83aa0718ebe4717af883eb33 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-no-instructions">
      <term><option>--no-instructions</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=15e26f15d1a6b369de6f47219ede4b7b sig_cn_org=6eb4a23db2ca2b5d4729ef743ffd8569 source=15.7 
       <para>
        By default, <command>initdb</command> will write instructions for how
        to start the cluster at the end of its output. This option causes
        those instructions to be left out. This is primarily intended for use
        by tools that wrap <command>initdb</command> in platform-specific
        behavior, where those instructions are likely to be incorrect.
       </para>
________________________________________________________-->
       <para>
        默认情况下，<command>initdb</command>会在输出的末尾写入启动集群的说明。
        此选项会导致省略这些说明。这主要是为了供将<command>initdb</command>包装在特定平台行为中的工具使用，
        在那些说明可能不正确的情况下。
       </para>
<!-- pgdoc-cn_end sig_en=15e26f15d1a6b369de6f47219ede4b7b -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-pwfile">
      <term><option>--pwfile=<replaceable>filename</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=a2407346d4cee14478da65b4f0d0257e sig_cn_org=4bf467044e55da3b1054ab6049786773 source=16.8 
       <para>
        Makes <command>initdb</command> read the bootstrap superuser's password
        from a file.  The first line of the file is taken as the password.
       </para>
________________________________________________________-->
       <para>
        使<command>initdb</command>从文件中读取引导超级用户的密码。文件的第一行
        被视为密码。
</para>
<!-- pgdoc-cn_end sig_en=a2407346d4cee14478da65b4f0d0257e -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-sync-only">
      <term><option>-S</option></term>
      <term><option>--sync-only</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=e1028822255eb72771a33ba267a8ddbe sig_cn_org=1c2e3a19d8db0575913e8ac424282270 source=15.7 
       <para>
        Safely write all database files to disk and exit.  This does not
        perform any of the normal <application>initdb</application> operations.
        Generally, this option is useful for ensuring reliable recovery after
        changing <xref linkend="guc-fsync"/> from <literal>off</literal> to
        <literal>on</literal>.
       </para>
________________________________________________________-->
       <para>
        安全地将所有数据库文件写入磁盘并退出。这不执行任何正常的<application>initdb</application>操作。
        通常，此选项对于在将<xref linkend="guc-fsync"/>从<literal>off</literal>更改为<literal>on</literal>后确保可靠恢复很有用。
       </para>
<!-- pgdoc-cn_end sig_en=e1028822255eb72771a33ba267a8ddbe -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-text-search-config">
      <term><option>-T <replaceable>config</replaceable></option></term>
      <term><option>--text-search-config=<replaceable>config</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=7f09887a4e16f762f49ffb182d0c8f45 sig_cn_org=084c7c06d16e11a4c4dbbdff7bff8c65 source=15.7 
       <para>
        Sets the default text search configuration.
        See <xref linkend="guc-default-text-search-config"/> for further information.
       </para>
________________________________________________________-->
       <para>
        设置默认的文本搜索配置。
        有关更多信息，请参见<xref linkend="guc-default-text-search-config"/>。
       </para>
<!-- pgdoc-cn_end sig_en=7f09887a4e16f762f49ffb182d0c8f45 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-username">
      <term><option>-U <replaceable class="parameter">username</replaceable></option></term>
      <term><option>--username=<replaceable class="parameter">username</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=2f81dd9f34fb76957120aa26002ed5b7 sig_cn_org=4c6a527733183777cc32d756758173dd source=16.8 
       <para>
        Sets the user name of the
        <glossterm linkend="glossary-bootstrap-superuser">bootstrap superuser</glossterm>.
        This defaults to the name of the operating-system user running
        <command>initdb</command>.
       </para>
________________________________________________________-->
       <para>
        设置
        <glossterm linkend="glossary-bootstrap-superuser">引导超级用户</glossterm>
        的用户名。默认情况下，这将设置为运行
        <command>initdb</command>
        的操作系统用户的名称。
</para>
<!-- pgdoc-cn_end sig_en=2f81dd9f34fb76957120aa26002ed5b7 -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-pwprompt">
      <term><option>-W</option></term>
      <term><option>--pwprompt</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=f6f84fe9fb6f6b84d7128f075a3e062b sig_cn_org=0bda6cbe14a7322c10256ac9871a1c7b source=16.8 
       <para>
        Makes <command>initdb</command> prompt for a password
        to give the bootstrap superuser. If you don't plan on using password
        authentication, this is not important.  Otherwise you won't be
        able to use password authentication until you have a password
        set up.
       </para>
________________________________________________________-->
       <para>
        使<command>initdb</command>提示输入密码以提供给引导超级用户。
        如果您不打算使用密码认证，这并不重要。否则，在设置密码之前，
        您将无法使用密码认证。
</para>
<!-- pgdoc-cn_end sig_en=f6f84fe9fb6f6b84d7128f075a3e062b -->
      </listitem>
     </varlistentry>

      <varlistentry id="app-initdb-option-waldir">
      <term><option>-X <replaceable class="parameter">directory</replaceable></option></term>
      <term><option>--waldir=<replaceable class="parameter">directory</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=eca2b770df072bfd00fff230f1077dad sig_cn_org=098fc69e42685c6884cab816714ce98f source=15.7 
       <para>
        This option specifies the directory where the write-ahead log
        should be stored.
       </para>
________________________________________________________-->
       <para>
        这个选项指定了预写日志应该存储的目录。
       </para>
<!-- pgdoc-cn_end sig_en=eca2b770df072bfd00fff230f1077dad -->
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-wal-segsize">
      <term><option>--wal-segsize=<replaceable>size</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=bad66bd13c7a5f4846613f7ba51647a7 sig_cn_org=4a36d47c53753a703a0520f18bafc800 source=15.7 
       <para>
        Set the <firstterm>WAL segment size</firstterm>, in megabytes.  This
        is the size of each individual file in the WAL log.  The default size
        is 16 megabytes.  The value must be a power of 2 between 1 and 1024
        (megabytes).  This option can only be set during initialization, and
        cannot be changed later.
       </para>
________________________________________________________-->
       <para>
        设置<firstterm>WAL段大小</firstterm>，单位为兆字节。这是WAL日志中每个单独文件的大小。
        默认大小为16兆字节。该值必须是1到1024（兆字节）之间的2的幂。此选项只能在初始化期间设置，
        以后不能更改。
       </para>
<!-- pgdoc-cn_end sig_en=bad66bd13c7a5f4846613f7ba51647a7 -->

<!-- pgdoc-cn_start sig_en=cfaee057f27770601b029edb871764b0 sig_cn_org=08507c06e48126879abf3d9d779ebb12 source=15.7 
       <para>
        It may be useful to adjust this size to control the granularity of
        WAL log shipping or archiving.  Also, in databases with a high volume
        of WAL, the sheer number of WAL files per directory can become a
        performance and management problem.  Increasing the WAL file size
        will reduce the number of WAL files.
       </para>
________________________________________________________-->
       <para>
        调整这个大小可能是有用的，以控制WAL日志传送或归档的粒度。此外，在具有大量WAL的数据库中，每个目录中的WAL文件数量之多可能会成为性能和管理问题。增加WAL文件大小将减少WAL文件数量。
       </para>
<!-- pgdoc-cn_end sig_en=cfaee057f27770601b029edb871764b0 -->
      </listitem>
     </varlistentry>
    </variablelist>
   </para>

<!-- pgdoc-cn_start sig_en=72c0bba755ba4dc178051eca43dffe68 sig_cn_org=0e1d5f2ec93a88e4c9e8ec6e03e6cd7e source=16.8 
   <para>
    Other, less commonly used, options are also available:

    <variablelist>
     <varlistentry id="app-initdb-option-set">
      <term><option>-c <replaceable>name</replaceable>=<replaceable>value</replaceable></option></term>
      <term><option>-&minus;set <replaceable>name</replaceable>=<replaceable>value</replaceable></option></term>
      <listitem>
       <para>
        Forcibly set the server parameter <replaceable>name</replaceable>
        to <replaceable>value</replaceable> during <command>initdb</command>,
        and also install that setting in the
        generated <filename>postgresql.conf</filename> file,
        so that it will apply during future server runs.
        This option can be given more than once to set several parameters.
        It is primarily useful when the environment is such that the server
        will not start at all using the default parameters.
       </para>
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-debug">
      <term><option>-d</option></term>
      <term><option>-&minus;debug</option></term>
      <listitem>
       <para>
        Print debugging output from the bootstrap backend and a few other
        messages of lesser interest for the general public.
        The bootstrap backend is the program <command>initdb</command>
        uses to create the catalog tables.  This option generates a tremendous
        amount of extremely boring output.
       </para>
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-discard-caches">
      <term><option>-&minus;discard-caches</option></term>
      <listitem>
       <para>
        Run the bootstrap backend with the
        <literal>debug_discard_caches=1</literal> option.
        This takes a very long time and is only of use for deep debugging.
       </para>
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-l">
      <term><option>-L <replaceable class="parameter">directory</replaceable></option></term>
      <listitem>
       <para>
        Specifies where <command>initdb</command> should find
        its input files to initialize the database cluster.  This is
        normally not necessary.  You will be told if you need to
        specify their location explicitly.
       </para>
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-no-clean">
      <term><option>-n</option></term>
      <term><option>-&minus;no-clean</option></term>
      <listitem>
       <para>
        By default, when <command>initdb</command>
        determines that an error prevented it from completely creating the database
        cluster, it removes any files it might have created before discovering
        that it cannot finish the job. This option inhibits tidying-up and is
        thus useful for debugging.
       </para>
      </listitem>
     </varlistentry>
    </variablelist>
   </para>
________________________________________________________-->
   <para>
    其他一些不常用的选项也可以使用：

    <variablelist>
     <varlistentry id="app-initdb-option-set">
      <term><option>-c <replaceable>name</replaceable>=<replaceable>value</replaceable></option></term>
      <term><option>--set <replaceable>name</replaceable>=<replaceable>value</replaceable></option></term>
      <listitem>
       <para>
        在<command>initdb</command>期间强制将服务器参数<replaceable>name</replaceable>
        设置为<replaceable>value</replaceable>，并将该设置安装到生成的
        <filename>postgresql.conf</filename>文件中，以便在未来的服务器运行中生效。
        此选项可以多次使用以设置多个参数。它主要在服务器使用默认参数
        无法启动的环境中有用。
       </para>
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-debug">
      <term><option>-d</option></term>
      <term><option>--debug</option></term>
      <listitem>
       <para>
        打印来自引导后端的调试输出以及一些对普通公众兴趣较小的其他消息。
        引导后端是<command>initdb</command>用于创建目录表的程序。
        此选项会生成大量极其无聊的输出。
       </para>
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-discard-caches">
      <term><option>--discard-caches</option></term>
      <listitem>
       <para>
        使用<literal>debug_discard_caches=1</literal>选项运行引导后端。
        这将花费很长时间，仅用于深入调试。
       </para>
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-l">
      <term><option>-L <replaceable class="parameter">directory</replaceable></option></term>
      <listitem>
       <para>
        指定<command>initdb</command>应在哪里找到其输入文件以初始化数据库集群。
        通常不需要这样做。如果需要明确指定它们的位置，系统会通知您。
       </para>
      </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-no-clean">
      <term><option>-n</option></term>
      <term><option>--no-clean</option></term>
      <listitem>
       <para>
        默认情况下，当<command>initdb</command>确定某个错误阻止其完全创建数据库
        集群时，它会删除在发现无法完成任务之前可能已创建的任何文件。
        此选项会禁止清理，因此对调试很有用。
       </para>
      </listitem>
     </varlistentry>
    </variablelist>
   </para>
<!-- pgdoc-cn_end sig_en=72c0bba755ba4dc178051eca43dffe68 -->

<!-- pgdoc-cn_start sig_en=9b978e9eafcb2e94d1835df899731d04 sig_cn_org=f6066d64ddc159aed411d01a08037061 source=16.8 
   <para>
    Other options:

    <variablelist>
     <varlistentry id="app-initdb-option-version">
       <term><option>-V</option></term>
       <term><option>-&minus;version</option></term>
       <listitem>
       <para>
       Print the <application>initdb</application> version and exit.
       </para>
       </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-help">
       <term><option>-?</option></term>
       <term><option>-&minus;help</option></term>
       <listitem>
       <para>
       Show help about <application>initdb</application> command line
       arguments, and exit.
       </para>
       </listitem>
     </varlistentry>

    </variablelist>
   </para>
________________________________________________________-->
   <para>
    其他选项:

    <variablelist>
     <varlistentry id="app-initdb-option-version">
       <term><option>-V</option></term>
       <term><option>-–version</option></term>
       <listitem>
       <para>
       打印<application>initdb</application>版本并退出。
       </para>
       </listitem>
     </varlistentry>

     <varlistentry id="app-initdb-option-help">
       <term><option>-?</option></term>
       <term><option>-–help</option></term>
       <listitem>
       <para>
       显示关于<application>initdb</application>命令行参数的帮助信息，并退出。
       </para>
       </listitem>
     </varlistentry>

    </variablelist>
   </para>
<!-- pgdoc-cn_end sig_en=9b978e9eafcb2e94d1835df899731d04 -->

 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=3b1cdb4e9f7c411322dc1c76ca7f31f3 sig_cn_org=None source=14.1 
  <title>Environment</title>
________________________________________________________-->
  <title>环境</title>
<!-- pgdoc-cn_end sig_en=3b1cdb4e9f7c411322dc1c76ca7f31f3 -->

  <variablelist>
   <varlistentry id="app-initdb-environment-pgdata">
    <term><envar>PGDATA</envar></term>

    <listitem>
<!-- pgdoc-cn_start sig_en=cd1e3cad2ca086d4aaf74a947d9514cc sig_cn_org=None source=14.1 
     <para>
      Specifies the directory where the database cluster is to be
      stored; can be overridden using the <option>-D</option> option.
     </para>
________________________________________________________-->
     <para>
      指定数据库集簇应该被存放的目录，可以使用<option>-D</option>选项覆盖。
     </para>
<!-- pgdoc-cn_end sig_en=cd1e3cad2ca086d4aaf74a947d9514cc -->
    </listitem>
   </varlistentry>

   <varlistentry id="app-initdb-environment-pg-color">
    <term><envar>PG_COLOR</envar></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=39edaf7f74e555fd049f4cbfdb1bb1dd sig_cn_org=None source=14.1 
     <para>
      Specifies whether to use color in diagnostic messages. Possible values
      are <literal>always</literal>, <literal>auto</literal> and
      <literal>never</literal>.
     </para>
________________________________________________________-->
     <para>
      规定在诊断消息中是否使用颜色。可能的值为<literal>always</literal>、<literal>auto</literal>和
     <literal>never</literal>。
     </para>
<!-- pgdoc-cn_end sig_en=39edaf7f74e555fd049f4cbfdb1bb1dd -->
    </listitem>
   </varlistentry>

   <varlistentry id="app-initdb-environment-tz">
    <term><envar>TZ</envar></term>

    <listitem>
<!-- pgdoc-cn_start sig_en=52d5ca441df0b872deeeaf776b14665a sig_cn_org=None source=14.1 
     <para>
      Specifies the default time zone of the created database cluster.  The
      value should be a full time zone name
      (see <xref linkend="datatype-timezones"/>).
     </para>
________________________________________________________-->
     <para>
      指定创建的数据库集簇的默认时区。值应该是一个完整的时区名称（见<xref linkend="datatype-timezones"/>）。
     </para>
<!-- pgdoc-cn_end sig_en=52d5ca441df0b872deeeaf776b14665a -->
    </listitem>
   </varlistentry>
  </variablelist>

 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=c44fa43baeb4f69a8a2aa1ea108c6e97 sig_cn_org=None source=14.1 
  <title>Notes</title>
________________________________________________________-->
  <title>备注</title>
<!-- pgdoc-cn_end sig_en=c44fa43baeb4f69a8a2aa1ea108c6e97 -->

<!-- pgdoc-cn_start sig_en=2ed0cd25709a1edbf7d4f664e8a9f798 sig_cn_org=None source=14.1 
  <para>
   <command>initdb</command> can also be invoked via
   <command>pg_ctl initdb</command>.
  </para>
________________________________________________________-->
  <para>
   <command>initdb</command>可以通过<command>pg_ctl initdb</command>来调用。
  </para>
<!-- pgdoc-cn_end sig_en=2ed0cd25709a1edbf7d4f664e8a9f798 -->
 </refsect1>

