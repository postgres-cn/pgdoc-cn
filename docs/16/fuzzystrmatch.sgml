<!-- pgdoc-cn_start sig_en=1ec6147dbfa8f33e9cb99b409b735190 sig_cn_org=557f37a3cba23e6a92aeb7c1cf125e2e source=16.8 
 <title>fuzzystrmatch &mdash; determine string similarities and distance</title>
________________________________________________________-->
 <title>fuzzystrmatch &mdash; 确定字符串相似性和距离</title>
<!-- pgdoc-cn_end sig_en=1ec6147dbfa8f33e9cb99b409b735190 -->

<!-- pgdoc-cn_start sig_en=11e9a2dbd0b8680fd195102abe521528 sig_cn_org=None source=14.1 
