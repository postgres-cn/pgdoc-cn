<!-- doc/src/sgml/pglogicalinspect.sgml -->

<sect1 id="pglogicalinspect" xreflabel="pg_logicalinspect">
<!-- pgdoc-cn_start sig_en=0d311ce77f9da1722a85c1ed0bb48692 sig_cn_org=09f304d7114bdb087c286a40d9880ab2 source=18.3 
 <title>pg_logicalinspect &mdash; logical decoding components inspection</title>
________________________________________________________-->
 <title>pg_logicalinspect &mdash; 逻辑解码组件检查</title>
<!-- pgdoc-cn_end sig_en=0d311ce77f9da1722a85c1ed0bb48692 -->

<!-- pgdoc-cn_start sig_en=2902fe6ccea35aa667b7801d7bf16387 sig_cn_org=72926d3acdddf90fcd26446c52652e43 source=18.3 
 <indexterm zone="pglogicalinspect">
  <primary>pg_logicalinspect</primary>
 </indexterm>
________________________________________________________-->
 <indexterm zone="pglogicalinspect">
  <primary>pg_logicalinspect</primary>
 </indexterm>
<!-- pgdoc-cn_end sig_en=2902fe6ccea35aa667b7801d7bf16387 -->

<!-- pgdoc-cn_start sig_en=c2880a6618c68836ad61436ea6325d73 sig_cn_org=ff270b2fa8b694a8cc994f3e4bcea343 source=18.3 
 <para>
  The <filename>pg_logicalinspect</filename> module provides SQL functions
  that allow you to inspect the contents of logical decoding components. It
  allows the inspection of serialized logical snapshots of a running
  <productname>PostgreSQL</productname> database cluster, which is useful
  for debugging or educational purposes.
 </para>
________________________________________________________-->
 <para>
  <filename>pg_logicalinspect</filename> 模块提供 SQL 函数，
  允许您检查逻辑解码组件的内容。它
  允许检查正在运行的 <productname>PostgreSQL</productname> 数据库集群的
  序列化逻辑快照，这对于调试或教育目的非常有用。
 </para>
<!-- pgdoc-cn_end sig_en=c2880a6618c68836ad61436ea6325d73 -->

<!-- pgdoc-cn_start sig_en=4015c109fc599761d10f87b7b3292bc5 sig_cn_org=d11a2901b4ed45f261434cb2d3036ea6 source=15.7 
 <para>
  By default, use of these functions is restricted to superusers and members of
  the <literal>pg_read_server_files</literal> role. Access may be granted by
  superusers to others using <command>GRANT</command>.
 </para>
________________________________________________________-->
 <para>
  默认情况下，这些函数的使用仅限于超级用户和<literal>pg_read_server_files</literal>角色的成员。
  超级用户可以使用<command>GRANT</command>授予其他用户访问权限。
 </para>
<!-- pgdoc-cn_end sig_en=4015c109fc599761d10f87b7b3292bc5 -->

 <sect2 id="pglogicalinspect-funcs">
<!-- pgdoc-cn_start sig_en=a75e46b58752dd4a3c18092d0816bc01 sig_cn_org=None source=14.1 
  <title>Functions</title>
________________________________________________________-->
  <title>函数</title>
<!-- pgdoc-cn_end sig_en=a75e46b58752dd4a3c18092d0816bc01 -->

  <variablelist>
   <varlistentry id="pglogicalinspect-funcs-pg-get-logical-snapshot-meta">
    <term>
     <function>pg_get_logical_snapshot_meta(filename text) returns record</function>
    </term>

    <listitem>
<!-- pgdoc-cn_start sig_en=b17f3188abc20b2287e34cf405cde598 sig_cn_org=09ce1159730cb3b69c2d272659cb3bec source=18.3 
     <para>
      Gets logical snapshot metadata about a snapshot file that is located in
      the server's <filename>pg_logical/snapshots</filename> directory.
      The <replaceable>filename</replaceable> argument represents the snapshot
      file name.
      For example:
<screen>
postgres=# SELECT * FROM pg_ls_logicalsnapdir();
-[ RECORD 1 ]+-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-
name         | 0-40796E18.snap
size         | 152
modification | 2024-08-14 16:36:32+00

postgres=# SELECT * FROM pg_get_logical_snapshot_meta('0-40796E18.snap');
-[ RECORD 1 ]-&minus;-&minus;-&minus;-&minus;
magic    | 1369563137
checksum | 1028045905
version  | 6

postgres=# SELECT ss.name, meta.* FROM pg_ls_logicalsnapdir() AS ss,
pg_get_logical_snapshot_meta(ss.name) AS meta;
-[ RECORD 1 ]-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-
name     | 0-40796E18.snap
magic    | 1369563137
checksum | 1028045905
version  | 6
</screen>
     </para>
________________________________________________________-->
     <para>
      获取位于服务器 <filename>pg_logical/snapshots</filename> 目录中的
      快照文件的逻辑快照元数据。
      <replaceable>filename</replaceable> 参数表示快照
      文件名。
      例如：
<screen>
postgres=# SELECT * FROM pg_ls_logicalsnapdir();
-[ RECORD 1 ]+-----------------------
name         | 0-40796E18.snap
size         | 152
modification | 2024-08-14 16:36:32+00

postgres=# SELECT * FROM pg_get_logical_snapshot_meta('0-40796E18.snap');
-[ RECORD 1 ]-------- 
magic    | 1369563137
checksum | 1028045905
version  | 6

postgres=# SELECT ss.name, meta.* FROM pg_ls_logicalsnapdir() AS ss,
pg_get_logical_snapshot_meta(ss.name) AS meta;
-[ RECORD 1 ]-------------
name     | 0-40796E18.snap
magic    | 1369563137
checksum | 1028045905
version  | 6
</screen>
     </para>
<!-- pgdoc-cn_end sig_en=b17f3188abc20b2287e34cf405cde598 -->
<!-- pgdoc-cn_start sig_en=425dae1c003880b8add26536724d7dbb sig_cn_org=a30fa6be94fe4966541fe3c20d72e402 source=18.3 
     <para>
      If <replaceable>filename</replaceable> does not match a snapshot file, the
      function raises an error.
     </para>
________________________________________________________-->
     <para>
      如果 <replaceable>filename</replaceable> 不匹配快照文件，则
      函数会引发错误。
     </para>
<!-- pgdoc-cn_end sig_en=425dae1c003880b8add26536724d7dbb -->
    </listitem>
   </varlistentry>

   <varlistentry id="pglogicalinspect-funcs-pg-get-logical-snapshot-info">
    <term>
     <function>pg_get_logical_snapshot_info(filename text) returns record</function>
    </term>

    <listitem>
<!-- pgdoc-cn_start sig_en=f2f46526c67a70a9f189a281dcf9a1e2 sig_cn_org=cc91c2279849791cbff007a6953b19b0 source=18.3 
     <para>
      Gets logical snapshot information about a snapshot file that is located in
      the server's <filename>pg_logical/snapshots</filename> directory.
      The <replaceable>filename</replaceable> argument represents the snapshot
      file name.
      For example:
<screen>
postgres=# SELECT * FROM pg_ls_logicalsnapdir();
-[ RECORD 1 ]+-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-
name         | 0-40796E18.snap
size         | 152
modification | 2024-08-14 16:36:32+00

postgres=# SELECT * FROM pg_get_logical_snapshot_info('0-40796E18.snap');
-[ RECORD 1 ]-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;+-&minus;-&minus;-&minus;-&minus;-&minus;-
state                    | consistent
xmin                     | 751
xmax                     | 751
start_decoding_at        | 0/40796AF8
two_phase_at             | 0/40796AF8
initial_xmin_horizon     | 0
building_full_snapshot   | f
in_slot_creation         | f
last_serialized_snapshot | 0/0
next_phase_at            | 0
committed_count          | 0
committed_xip            |
catchange_count          | 2
catchange_xip            | {751,752}

postgres=# SELECT ss.name, info.* FROM pg_ls_logicalsnapdir() AS ss,
pg_get_logical_snapshot_info(ss.name) AS info;
-[ RECORD 1 ]-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;+-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;-&minus;
name                     | 0-40796E18.snap
state                    | consistent
xmin                     | 751
xmax                     | 751
start_decoding_at        | 0/40796AF8
two_phase_at             | 0/40796AF8
initial_xmin_horizon     | 0
building_full_snapshot   | f
in_slot_creation         | f
last_serialized_snapshot | 0/0
next_phase_at            | 0
committed_count          | 0
committed_xip            |
catchange_count          | 2
catchange_xip            | {751,752}
</screen>
     </para>
________________________________________________________-->
     <para>
      获取位于服务器 <filename>pg_logical/snapshots</filename> 目录中的
      快照文件的逻辑快照信息。
      <replaceable>filename</replaceable> 参数表示快照
      文件名。
      例如：
<screen>
postgres=# SELECT * FROM pg_ls_logicalsnapdir();
-[ RECORD 1 ]+-----------------------
name         | 0-40796E18.snap
size         | 152
modification | 2024-08-14 16:36:32+00

postgres=# SELECT * FROM pg_get_logical_snapshot_info('0-40796E18.snap');
-[ RECORD 1 ]------------+-----------
state                    | consistent
xmin                     | 751
xmax                     | 751
start_decoding_at        | 0/40796AF8
two_phase_at             | 0/40796AF8
initial_xmin_horizon     | 0
building_full_snapshot   | f
in_slot_creation         | f
last_serialized_snapshot | 0/0
next_phase_at            | 0
committed_count          | 0
committed_xip            |
catchange_count          | 2
catchange_xip            | {751,752}

postgres=# SELECT ss.name, info.* FROM pg_ls_logicalsnapdir() AS ss,
pg_get_logical_snapshot_info(ss.name) AS info;
-[ RECORD 1 ]------------+----------------
name                     | 0-40796E18.snap
state                    | consistent
xmin                     | 751
xmax                     | 751
start_decoding_at        | 0/40796AF8
two_phase_at             | 0/40796AF8
initial_xmin_horizon     | 0
building_full_snapshot   | f
in_slot_creation         | f
last_serialized_snapshot | 0/0
next_phase_at            | 0
committed_count          | 0
committed_xip            |
catchange_count          | 2
catchange_xip            | {751,752}
</screen>
     </para>
<!-- pgdoc-cn_end sig_en=f2f46526c67a70a9f189a281dcf9a1e2 -->
<!-- pgdoc-cn_start sig_en=425dae1c003880b8add26536724d7dbb sig_cn_org=a30fa6be94fe4966541fe3c20d72e402 source=18.3 
     <para>
      If <replaceable>filename</replaceable> does not match a snapshot file, the
      function raises an error.
     </para>
________________________________________________________-->
     <para>
      如果 <replaceable>filename</replaceable> 不匹配快照文件，函数
      会引发错误。
     </para>
<!-- pgdoc-cn_end sig_en=425dae1c003880b8add26536724d7dbb -->
