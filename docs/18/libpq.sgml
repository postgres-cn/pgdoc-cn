<!-- pgdoc-cn_end sig_en=7359a6515586cc92a51609b42e5ab72b -->

     <listitem>
<!-- pgdoc-cn_start sig_en=c432b520934694040cd43f34d95d230f sig_cn_org=6f39534bd9571670f375c4d2aa07370e source=17.5 
      <para>
       Submits a request to close the specified prepared statement, without
