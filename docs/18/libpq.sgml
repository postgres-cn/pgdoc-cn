     </para>
________________________________________________________-->
     <para>
      <indexterm>
       <primary><envar>PGREQUIREAUTH</envar></primary>
      </indexterm>
      <envar>PGREQUIREAUTH</envar>的行为与<xref linkend="libpq-connect-require-auth"/>连接参数相同。
      </para>
<!-- pgdoc-cn_end sig_en=9a228508d4329dd3cbe88b96679656ee -->
    </listitem>

    <listitem>
<!-- pgdoc-cn_start sig_en=52125337afd2dae422e864b94e4e03c8 sig_cn_org=32dccb516b93cd8115d9aa267281fc04 source=15.7 
     <para>
      <indexterm>
       <primary><envar>PGCHANNELBINDING</envar></primary>
      </indexterm>
      <envar>PGCHANNELBINDING</envar> behaves the same as the <xref
