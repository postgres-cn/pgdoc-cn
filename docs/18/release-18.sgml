 <sect1 id="release-18-3">
<!-- pgdoc-cn_start sig_en=823c9cb95747a377c54d797764b6f991 sig_cn_org=f20caee860a24acbc09b0ac8a3a7d3f0 source=18.3 
  <title>Release 18.3</title>
________________________________________________________-->
  <title>版本 18.3</title>
<!-- pgdoc-cn_end sig_en=823c9cb95747a377c54d797764b6f991 -->

  <formalpara>
<!-- pgdoc-cn_start sig_en=c45e8127eac45f2347bf1713afaeffda sig_cn_org=253305b4c6dff5b87ef36e3c2d95e52e source=15.7 
  <title>Release date:</title>
________________________________________________________-->
  <title>发布日期：</title>
<!-- pgdoc-cn_end sig_en=c45e8127eac45f2347bf1713afaeffda -->
<!-- pgdoc-cn_start sig_en=3c7199549ab2b6c882e68d699a30796d sig_cn_org=2f66df344b2b98b1eed79ed5e8b78fa8 source=18.3 
  <para>2026-02-26</para>
________________________________________________________-->
  <para>2026-02-26</para>
<!-- pgdoc-cn_end sig_en=3c7199549ab2b6c882e68d699a30796d -->
  </formalpara>

<!-- pgdoc-cn_start sig_en=1be379d81e3b2ed46bf177abd3574aa9 sig_cn_org=6d6c2556893aba86ab60d59f0694656f source=18.3 
  <para>
   This release contains a small number of fixes from 18.2.
   For information about new features in major release 18, see
   <xref linkend="release-18"/>.
  </para>
________________________________________________________-->
  <para>
   此版本包含来自 18.2 的少量修复。
   有关主要版本 18 中新功能的信息，请参见
   <xref linkend="release-18"/>。
  </para>
<!-- pgdoc-cn_end sig_en=1be379d81e3b2ed46bf177abd3574aa9 -->

  <sect2 id="release-18-3-migration">
<!-- pgdoc-cn_start sig_en=ce62303475de123f567d246a268e96e6 sig_cn_org=bc8e0d0bf63df133eedaf68cc4ef0c0b source=18.3 
   <title>Migration to Version 18.3</title>
________________________________________________________-->
   <title>迁移到版本 18.3</title>
<!-- pgdoc-cn_end sig_en=ce62303475de123f567d246a268e96e6 -->

<!-- pgdoc-cn_start sig_en=45204236df61a22e670593ffea4a5c26 sig_cn_org=90b9a58858a643fe3fe6473b1dbe1abf source=18.3 
   <para>
    A dump/restore is not required for those running 18.X.
   </para>
________________________________________________________-->
   <para>
    对于运行 18.X 的用户，不需要进行转储/恢复。
   </para>
<!-- pgdoc-cn_end sig_en=45204236df61a22e670593ffea4a5c26 -->

<!-- pgdoc-cn_start sig_en=78d4606f21805cbef88e32f9b98dc7b7 sig_cn_org=54f82711b4b675a4436e2d4f3b831f29 source=18.3 
   <para>
    However, if you are upgrading from a version earlier than 18.2,
    see <xref linkend="release-18-2"/>.
   </para>
________________________________________________________-->
   <para>
    然而，如果您是从早于 18.2 的版本升级，
    请参阅 <xref linkend="release-18-2"/>。
</para>
<!-- pgdoc-cn_end sig_en=78d4606f21805cbef88e32f9b98dc7b7 -->
  </sect2>

  <sect2 id="release-18-3-changes">
<!-- pgdoc-cn_start sig_en=e161fef38e54e54458e215e5f978ef9b sig_cn_org=f104d50dd9d4dd802f94229ebe5bc097 source=15.7 
   <title>Changes</title>
________________________________________________________-->
   <title>变更</title>
<!-- pgdoc-cn_end sig_en=e161fef38e54e54458e215e5f978ef9b -->

   <itemizedlist>

    <listitem>
<!--
Author: Heikki Linnakangas <heikki.linnakangas@iki.fi>
Branch: REL_18_STABLE [817f74600] 2026-02-16 17:16:59 +0200
Branch: REL_17_STABLE [4a36c89f1] 2026-02-16 17:18:17 +0200
Branch: REL_16_STABLE [23064542f] 2026-02-16 17:20:29 +0200
Branch: REL_15_STABLE [899de38d8] 2026-02-16 17:20:51 +0200
Branch: REL_14_STABLE [547a8aaa7] 2026-02-16 17:20:56 +0200
-->
<!-- pgdoc-cn_start sig_en=6d64cee21f111b8e84e09597d254c3c5 sig_cn_org=554a5860ecd409fb2b522f99dc8a43d3 source=18.3 
     <para>
      Fix failure after replaying a multixid truncation record from WAL
      that was generated by an older minor version (Heikki Linnakangas)
      <ulink url="&commit_baseurl;817f74600">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      修复从 WAL 重放由旧的次要版本生成的 multixid 截断记录后失败的问题
      (Heikki Linnakangas)
      <ulink url="&commit_baseurl;817f74600">&sect;</ulink>
</para>
<!-- pgdoc-cn_end sig_en=6d64cee21f111b8e84e09597d254c3c5 -->

<!-- pgdoc-cn_start sig_en=65cf198100318c724dc5226bafb3cf4d sig_cn_org=a902ab4a1ecdca677068b3d55a146ae8 source=18.3 
     <para>
      Erroneous logic for coping with the way that previous versions
      handled multixid wraparound led to replay failure, with messages
      like <quote>could not access status of transaction</quote>.
      A typical scenario in which this could occur is a standby server of
      the latest minor version consuming WAL from a primary server of an
      older version.
     </para>
________________________________________________________-->
     <para>
      处理以前版本处理 multixid 回绕的方式的错误逻辑导致重放失败，
      并出现类似 <quote>无法访问事务状态</quote> 的消息。
      这种情况的典型场景是最新次要版本的备用服务器从
      旧版本的主服务器消费 WAL。
</para>
<!-- pgdoc-cn_end sig_en=65cf198100318c724dc5226bafb3cf4d -->
    </listitem>

    <listitem>
