    <sect4 id="release-18-pgstatstatements">
     <title><xref linkend="pgstatstatements"/></title>

     <itemizedlist>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2024-10-28 [6b652e6ce] Set query ID for inner queries of CREATE TABLE AS and DE
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=e7137d54e433376a7c3ba410d5ec98ce sig_cn_org=ec9d59a65727d859351d0d212497093a source=18.3 
      <para>
      Allow the queries of <xref linkend="sql-createtableas"/>
      and <xref linkend="sql-declare"/> to be tracked by
      <application>pg_stat_statements</application> (Anthonin Bonnefoy)
      <ulink url="&commit_baseurl;6b652e6ce">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      允许 <xref linkend="sql-createtableas"/>
      和 <xref linkend="sql-declare"/> 的查询被
      <application>pg_stat_statements</application> 跟踪 (Anthonin Bonnefoy)
      <ulink url="&commit_baseurl;6b652e6ce">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=e7137d54e433376a7c3ba410d5ec98ce -->

<!-- pgdoc-cn_start sig_en=4d6f21c811795f561cb88778a24d027e sig_cn_org=0f2efbe687d624fdbcd0203e2e39c4fb source=18.3 
      <para>
      They are also now assigned query ids.
      </para>
________________________________________________________-->
      <para>
      现在它们也被分配了查询 ID。
      </para>
<!-- pgdoc-cn_end sig_en=4d6f21c811795f561cb88778a24d027e -->
      </listitem>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2024-09-30 [dc6851596] Show values of SET statements as constants in pg_stat_st
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=6787634663299adea1d18408eca6ff56 sig_cn_org=2c5fcb309138157922fe0431407b3f88 source=18.3 
      <para>
      Allow the parameterization of <xref linkend="sql-set"/> values in
      <application>pg_stat_statements</application> (Greg Sabino Mullane,
      Michael Paquier)
      <ulink url="&commit_baseurl;dc6851596">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      允许在 <application>pg_stat_statements</application> 中对 <xref linkend="sql-set"/> 值进行参数化 (Greg Sabino Mullane,
      Michael Paquier)
      <ulink url="&commit_baseurl;dc6851596">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=6787634663299adea1d18408eca6ff56 -->

<!-- pgdoc-cn_start sig_en=e6ede9608c647a8ba1ab27827fc1bc75 sig_cn_org=74c2916e6104cf504e14717661e685b1 source=18.3 
      <para>
      This reduces the bloat caused by <command>SET</command> statements
      with differing constants.
      </para>
________________________________________________________-->
      <para>
      这减少了由于不同常量的 <command>SET</command> 语句造成的膨胀。
      </para>
<!-- pgdoc-cn_end sig_en=e6ede9608c647a8ba1ab27827fc1bc75 -->
      </listitem>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2024-10-09 [cf54a2c00] pg_stat_statements: Add columns to track parallel worker
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=28d0bcaf8ba6f554b2a44396435c280e sig_cn_org=14f9a174a533ca264f44230a3cd01f69 source=18.3 
      <para>
      Add <link
      linkend="pgstatstatements-pg-stat-statements"><structname>pg_stat_statements</structname></link>
      columns to report parallel activity (Guillaume Lelarge)
      <ulink url="&commit_baseurl;cf54a2c00">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加 <link
      linkend="pgstatstatements-pg-stat-statements"><structname>pg_stat_statements</structname></link>
      列以报告并行活动 (Guillaume Lelarge)
      <ulink url="&commit_baseurl;cf54a2c00">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=28d0bcaf8ba6f554b2a44396435c280e -->

<!-- pgdoc-cn_start sig_en=ab2b53415dcf95c445e25152f1ea3b1e sig_cn_org=6a8ec245cf4d4a4020d41c5f75538f34 source=18.3 
      <para>
      The new columns are
      <structfield>parallel_workers_to_launch</structfield> and
      <structfield>parallel_workers_launched</structfield>.
      </para>
________________________________________________________-->
      <para>
      新列为
      <structfield>parallel_workers_to_launch</structfield> 和
      <structfield>parallel_workers_launched</structfield>。
      </para>
<!-- pgdoc-cn_end sig_en=ab2b53415dcf95c445e25152f1ea3b1e -->
      </listitem>

<!--
Author: Michael Paquier <michael@paquier.xyz>
2025-02-17 [ce5bcc4a9] pg_stat_statements: Add wal_buffers_full
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=f2894691e63c8f7b50fad03929b76138 sig_cn_org=7ffa552567633e9bac56e005c3d72fca source=18.3 
      <para>
      Add
      <structname>pg_stat_statements</structname>.<structfield>wal_buffers_full</structfield>
      to report full <acronym>WAL</acronym> buffers (Bertrand Drouvot)
      <ulink url="&commit_baseurl;ce5bcc4a9">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加
      <structname>pg_stat_statements</structname>.<structfield>wal_buffers_full</structfield>
      以报告满的 <acronym>WAL</acronym> 缓冲区 (Bertrand Drouvot)
      <ulink url="&commit_baseurl;ce5bcc4a9">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=f2894691e63c8f7b50fad03929b76138 -->
      </listitem>

     </itemizedlist>

    </sect4>

    <sect4 id="release-18-pgcrypto">
     <title><xref linkend="pgcrypto"/></title>

     <itemizedlist>

<!--
Author: Álvaro Herrera <alvherre@alvh.no-ip.org>
2025-04-05 [749a9e20c] Add modern SHA-2 based password hashes to pgcrypto.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=c61f672fe935cfc9e954829f6c76114a sig_cn_org=cb93d116af31ab3166f3f290ea8a3335 source=18.3 
      <para>
      Add <application>pgcrypto</application> algorithms <link
      linkend="pgcrypto-crypt-algorithms"><literal>sha256crypt</literal></link>
      and <link
      linkend="pgcrypto-crypt-algorithms"><literal>sha512crypt</literal></link>
      (Bernd Helmle)
      <ulink url="&commit_baseurl;749a9e20c">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加 <application>pgcrypto</application> 算法 <link
      linkend="pgcrypto-crypt-algorithms"><literal>sha256crypt</literal></link>
      和 <link
      linkend="pgcrypto-crypt-algorithms"><literal>sha512crypt</literal></link>
      (Bernd Helmle)
      <ulink url="&commit_baseurl;749a9e20c">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=c61f672fe935cfc9e954829f6c76114a -->
      </listitem>

<!--
Author: Daniel Gustafsson <dgustafsson@postgresql.org>
2025-02-14 [9ad1b3d01] pgcrypto: Add support for CFB mode in AES encryption
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=97bdb7848221ab9c923a6b2b3e73c2f9 sig_cn_org=9e48bd53910fd2f79b8cc9d3a495fea6 source=18.3 
      <para>
      Add <link
      linkend="pgcrypto-raw-enc-funcs"><acronym>CFB</acronym></link> mode
      to <application>pgcrypto</application> encryption and decryption
      (Umar Hayat)
      <ulink url="&commit_baseurl;9ad1b3d01">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加 <link
      linkend="pgcrypto-raw-enc-funcs"><acronym>CFB</acronym></link> 模式
      到 <application>pgcrypto</application> 加密和解密
      (Umar Hayat)
      <ulink url="&commit_baseurl;9ad1b3d01">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=97bdb7848221ab9c923a6b2b3e73c2f9 -->
      </listitem>

<!--
Author: Daniel Gustafsson <dgustafsson@postgresql.org>
2025-01-24 [924d89a35] pgcrypto: Add function to check FIPS mode
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=d2b6e5b353b9a8ddc2e67173f2c37e91 sig_cn_org=0227f67624c5378b63fbae33cfa0475b source=18.3 
      <para>
      Add function <link
      linkend="pgcrypto-openssl-support-funcs"><function>fips_mode()</function></link>
      to report the server's <acronym>FIPS</acronym> mode (Daniel
      Gustafsson)
      <ulink url="&commit_baseurl;924d89a35">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加函数 <link
      linkend="pgcrypto-openssl-support-funcs"><function>fips_mode()</function></link>
      以报告服务器的 <acronym>FIPS</acronym> 模式 (Daniel
      Gustafsson)
      <ulink url="&commit_baseurl;924d89a35">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=d2b6e5b353b9a8ddc2e67173f2c37e91 -->
      </listitem>

<!--
Author: Daniel Gustafsson <dgustafsson@postgresql.org>
2025-01-24 [035f99cbe] pgcrypto: Make it possible to disable built-in crypto
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=f0b051b223d42a007b9d61a03e538ce3 sig_cn_org=8e2986b9a70bfdb73a14d24fc3545fe5 source=18.3 
      <para>
      Add <application>pgcrypto</application> server variable <link
      linkend="pgcrypto-configuration-parameters-builtin_crypto_enabled"><varname>builtin_crypto_enabled</varname></link>
      to allow disabling builtin non-<acronym>FIPS</acronym> mode
      cryptographic functions (Daniel Gustafsson, Joe Conway)
      <ulink url="&commit_baseurl;035f99cbe">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加 <application>pgcrypto</application> 服务器变量 <link
      linkend="pgcrypto-configuration-parameters-builtin_crypto_enabled"><varname>builtin_crypto_enabled</varname></link>
      以允许禁用内置的非 <acronym>FIPS</acronym> 模式
      加密函数 (Daniel Gustafsson, Joe Conway)
      <ulink url="&commit_baseurl;035f99cbe">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=f0b051b223d42a007b9d61a03e538ce3 -->

<!-- pgdoc-cn_start sig_en=9a4267ae7048c11cdc2d54bb54d5d6fb sig_cn_org=c4224c549f16df65522944d147c6106b source=18.3 
      <para>
      This is useful for guaranteeing <acronym>FIPS</acronym> mode behavior.
      </para>
________________________________________________________-->
      <para>
      这对于保证 <acronym>FIPS</acronym> 模式行为非常有用。
      </para>
<!-- pgdoc-cn_end sig_en=9a4267ae7048c11cdc2d54bb54d5d6fb -->
      </listitem>

     </itemizedlist>
    </sect4>

   </sect3>

  </sect2>

