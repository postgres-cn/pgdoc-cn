    <listitem>
<!--
Author: Michael Paquier <michael@paquier.xyz>
Branch: master [5d95219fa] 2026-01-20 08:11:12 +0900
Branch: REL_18_STABLE [3304e97b1] 2026-01-20 08:11:16 +0900
-->
<!-- pgdoc-cn_start sig_en=9ec8a45e10030ad2f68764d9e0e9bb5a sig_cn_org=114e6efca4172690d868f54a384310ef source=18.3 
     <para>
      Avoid crash in <filename>contrib/pg_stat_statements</filename> when
      an <literal>IN</literal> list contains both constants and
      non-constant expressions (Sami Imseih)
      <ulink url="&commit_baseurl;3304e97b1">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      避免在 <filename>contrib/pg_stat_statements</filename> 中崩溃，
      当 <literal>IN</literal> 列表同时包含常量和
      非常量表达式时（Sami Imseih）
      <ulink url="&commit_baseurl;3304e97b1">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=9ec8a45e10030ad2f68764d9e0e9bb5a -->
    </listitem>

    <listitem>
