<!-- pgdoc-cn_start sig_en=4b50bea90aea285fdf516682c9f6c146 sig_cn_org=620e1037bfdd80c43ac52e5384e19577 source=18.3 
      <para>
      This is true even if the tables in different schemas have different
      column names.
      </para>
________________________________________________________-->
