<!-- pgdoc-cn_start sig_en=fb4e13596116f62de8a908fd99a9d882 sig_cn_org=09e6cd3bc2cf8b7d8e3b835cf81cda2c source=17.5 
     <para>
      This bug seems to have no consequences in standard builds, but it's
      theoretically a hazard.
     </para>
