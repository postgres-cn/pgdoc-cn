   <sect3 id="release-18-datatypes">
<!-- pgdoc-cn_start sig_en=4db1c7313abae97c18199af614e269c9 sig_cn_org=None source=14.1 
    <title>Data Types</title>
________________________________________________________-->
    <title>数据类型</title>
<!-- pgdoc-cn_end sig_en=4db1c7313abae97c18199af614e269c9 -->

    <itemizedlist>

<!--
Author: Jeff Davis <jdavis@postgresql.org>
2025-01-23 [4e7f62bc3] Add support for Unicode case folding.
Author: Jeff Davis <jdavis@postgresql.org>
2025-01-17 [286a365b9] Support Unicode full case mapping and conversion.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=c0f8410214751cf9a40a6f748bfe3278 sig_cn_org=0d672d10924faa37f147959897319392 source=18.3 
     <para>
     Improve <link linkend="collation-managing-standard">Unicode</link>
     full case mapping and conversion (Jeff Davis)
     <ulink url="&commit_baseurl;4e7f62bc3">&sect;</ulink>
     <ulink url="&commit_baseurl;286a365b9">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
     改进 <link linkend="collation-managing-standard">Unicode</link>
     完全大小写映射和转换（Jeff Davis）
     <ulink url="&commit_baseurl;4e7f62bc3">&sect;</ulink>
     <ulink url="&commit_baseurl;286a365b9">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=c0f8410214751cf9a40a6f748bfe3278 -->

<!-- pgdoc-cn_start sig_en=2b5609308bb83c86c17d3a32f8771c4d sig_cn_org=b7183fc167d084399cdc6005dc3c7fe8 source=18.3 
     <para>
     This adds the ability to do conditional and title case mapping,
     and case map single characters to multiple characters.
     </para>
________________________________________________________-->
     <para>
     这增加了进行条件和标题大小写映射的能力，
     并将单个字符的大小写映射到多个字符。
     </para>
<!-- pgdoc-cn_end sig_en=2b5609308bb83c86c17d3a32f8771c4d -->
     </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2025-01-24 [a5579a90a] Make jsonb casts to scalar types translate JSON null to
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=ea6c75ea8f7e7a3f28722d3d7cb0abc9 sig_cn_org=ded39286f3d3f65bc436d9cf0330933b source=18.3 
     <para>
     Allow <link linkend="datatype-json"><type>jsonb</type></link>
     <literal>null</literal> values to be cast to scalar types as
     <literal>NULL</literal> (Tom Lane)
     <ulink url="&commit_baseurl;a5579a90a">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
     允许 <link linkend="datatype-json"><type>jsonb</type></link>
     <literal>null</literal> 值被转换为标量类型为
     <literal>NULL</literal>（Tom Lane）
     <ulink url="&commit_baseurl;a5579a90a">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=ea6c75ea8f7e7a3f28722d3d7cb0abc9 -->

<!-- pgdoc-cn_start sig_en=beb4d45bc8a803d950fdecab0cdf07d2 sig_cn_org=d7b94ae19b483af6c9e3616add713eb0 source=18.3 
     <para>
     Previously such casts generated an error.
     </para>
________________________________________________________-->
     <para>
     之前这样的转换会产生错误。
     </para>
<!-- pgdoc-cn_end sig_en=beb4d45bc8a803d950fdecab0cdf07d2 -->
     </listitem>

<!--
Author: Andrew Dunstan <andrew@dunslane.net>
2025-03-05 [4603903d2] Allow json{b}_strip_nulls() to remove null array elements
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=6e28a4a4f16d58691ba4b9186f2834ab sig_cn_org=29dcec5cd69203ea4a05024910593102 source=18.3 
     <para>
     Add optional parameter to <link
     linkend="functions-json-processing-table"><function>json{b}_strip_nulls</function></link>
     to allow removal of null array elements (Florents Tselai)
     <ulink url="&commit_baseurl;4603903d2">&sect;</ulink>
     </para>
________________________________________________________-->
