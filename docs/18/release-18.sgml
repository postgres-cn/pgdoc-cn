 <sect1 id="release-18-1">
<!-- pgdoc-cn_start sig_en=b91502fc0978b88ccc3f026d18f94621 sig_cn_org=38dddb05ef90609787605e81fa0aace8 source=18.3 
  <title>Release 18.1</title>
________________________________________________________-->
  <title>版本 18.1</title>
<!-- pgdoc-cn_end sig_en=b91502fc0978b88ccc3f026d18f94621 -->

  <formalpara>
<!-- pgdoc-cn_start sig_en=c45e8127eac45f2347bf1713afaeffda sig_cn_org=253305b4c6dff5b87ef36e3c2d95e52e source=15.7 
  <title>Release date:</title>
________________________________________________________-->
  <title>发布日期：</title>
<!-- pgdoc-cn_end sig_en=c45e8127eac45f2347bf1713afaeffda -->
<!-- pgdoc-cn_start sig_en=d20be9b00e9e123108c6df66c3d3eb5f sig_cn_org=00f194369aa634a70777207b7afb90a4 source=18.3 
  <para>2025-11-13</para>
________________________________________________________-->
  <para>2025-11-13</para>
<!-- pgdoc-cn_end sig_en=d20be9b00e9e123108c6df66c3d3eb5f -->
  </formalpara>

<!-- pgdoc-cn_start sig_en=e65211c326c3aef91905e032d619b41f sig_cn_org=606b173dc5594b7ab092ae3dc0acef1c source=18.3 
  <para>
   This release contains a variety of fixes from 18.0.
   For information about new features in major release 18, see
   <xref linkend="release-18"/>.
  </para>
________________________________________________________-->
  <para>
   此版本包含来自 18.0 的各种修复。
   有关主要版本 18 中新功能的信息，请参见
   <xref linkend="release-18"/>.
  </para>
<!-- pgdoc-cn_end sig_en=e65211c326c3aef91905e032d619b41f -->

  <sect2 id="release-18-1-migration">
<!-- pgdoc-cn_start sig_en=00dcb7a26ab0deba4d325a00abf0d52f sig_cn_org=267e0ffe09af86d77afa9a4343bf48bb source=18.3 
   <title>Migration to Version 18.1</title>
________________________________________________________-->
   <title>迁移到版本 18.1</title>
<!-- pgdoc-cn_end sig_en=00dcb7a26ab0deba4d325a00abf0d52f -->

<!-- pgdoc-cn_start sig_en=45204236df61a22e670593ffea4a5c26 sig_cn_org=90b9a58858a643fe3fe6473b1dbe1abf source=18.3 
   <para>
    A dump/restore is not required for those running 18.X.
   </para>
________________________________________________________-->
   <para>
    对于运行 18.X 的用户，不需要进行转储/恢复。
   </para>
<!-- pgdoc-cn_end sig_en=45204236df61a22e670593ffea4a5c26 -->
  </sect2>

  <sect2 id="release-18-1-changes">
<!-- pgdoc-cn_start sig_en=e161fef38e54e54458e215e5f978ef9b sig_cn_org=f104d50dd9d4dd802f94229ebe5bc097 source=15.7 
   <title>Changes</title>
________________________________________________________-->
   <title>变更</title>
<!-- pgdoc-cn_end sig_en=e161fef38e54e54458e215e5f978ef9b -->

   <itemizedlist>

    <listitem>
<!--
Author: Nathan Bossart <nathan@postgresql.org>
Branch: master [5e4fcbe53] 2025-11-10 09:00:00 -0600
Branch: REL_18_STABLE [00eb646ea] 2025-11-10 09:00:00 -0600
Branch: REL_17_STABLE [e2fb3dfa8] 2025-11-10 09:00:00 -0600
Branch: REL_16_STABLE [d20abb587] 2025-11-10 09:00:00 -0600
Branch: REL_15_STABLE [2393d374a] 2025-11-10 09:00:00 -0600
Branch: REL_14_STABLE [95cce5669] 2025-11-10 09:00:00 -0600
Branch: REL_13_STABLE [8a2530ebc] 2025-11-10 09:00:00 -0600
-->
<!-- pgdoc-cn_start sig_en=7f97828392820f64b15ca0bbd6ae9610 sig_cn_org=4ba0dcf500d281fede7d416ac4736555 source=18.3 
     <para>
      Check for <literal>CREATE</literal> privileges on the schema
      in <command>CREATE STATISTICS</command> (Jelte Fennema-Nio)
      <ulink url="&commit_baseurl;00eb646ea">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      检查在 <command>CREATE STATISTICS</command> 中对模式的
      <literal>CREATE</literal> 权限（Jelte Fennema-Nio）
      <ulink url="&commit_baseurl;00eb646ea">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=7f97828392820f64b15ca0bbd6ae9610 -->

<!-- pgdoc-cn_start sig_en=f805c43560c369b2a80ce7331c045eaa sig_cn_org=129789206139f71bd6f0243995028fe7 source=18.3 
     <para>
      This omission allowed table owners to create statistics in any
      schema, potentially leading to unexpected naming conflicts.
     </para>
________________________________________________________-->
     <para>
      这个遗漏允许表的拥有者在任何模式中创建统计信息，
      可能导致意外的命名冲突。
     </para>
<!-- pgdoc-cn_end sig_en=f805c43560c369b2a80ce7331c045eaa -->

<!-- pgdoc-cn_start sig_en=76c7e72694081784bd1dd55aa7f77427 sig_cn_org=4531edf657c9c1070949d17dd4782819 source=18.3 
     <para>
      The <productname>PostgreSQL</productname> Project thanks
      Jelte Fennema-Nio for reporting this problem.
      (CVE-2025-12817)
     </para>
________________________________________________________-->
     <para>
      <productname>PostgreSQL</productname> 项目感谢
      Jelte Fennema-Nio 报告此问题。
      （CVE-2025-12817）
     </para>
<!-- pgdoc-cn_end sig_en=76c7e72694081784bd1dd55aa7f77427 -->
    </listitem>

    <listitem>
<!--
Author: Jacob Champion <jchampion@postgresql.org>
Branch: master [600086f47] 2025-11-10 06:20:33 -0800
Branch: REL_18_STABLE [7eb8fcad8] 2025-11-10 06:03:01 -0800
Branch: REL_17_STABLE [f5999f018] 2025-11-10 06:03:03 -0800
Branch: REL_16_STABLE [585fd9b3c] 2025-11-10 06:03:04 -0800
Branch: REL_15_STABLE [91421565f] 2025-11-10 06:03:05 -0800
Branch: REL_14_STABLE [96d2c7e96] 2025-11-10 06:03:05 -0800
Branch: REL_13_STABLE [d6f0c0d6d] 2025-11-10 06:03:06 -0800
-->
<!-- pgdoc-cn_start sig_en=e294353dad2e8e7cf714bfab07ec78cd sig_cn_org=2328b894e3280ec6e33051b681649e58 source=18.3 
     <para>
      Avoid integer overflow in allocation-size calculations
      within <application>libpq</application> (Jacob Champion)
      <ulink url="&commit_baseurl;7eb8fcad8">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      避免在 <application>libpq</application> 中的分配大小计算
      中发生整数溢出（Jacob Champion）
      <ulink url="&commit_baseurl;7eb8fcad8">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=e294353dad2e8e7cf714bfab07ec78cd -->

<!-- pgdoc-cn_start sig_en=3bb718dd02f927769666715fd15a3fff sig_cn_org=23b91e4a99738ef657328b1dd39b8bb3 source=18.3 
     <para>
      Several places in <application>libpq</application> were not
      sufficiently careful about computing the required size of a memory
      allocation.  Sufficiently large inputs could cause integer overflow,
      resulting in an undersized buffer, which would then lead to writing
      past the end of the buffer.
     </para>
________________________________________________________-->
     <para>
      <application>libpq</application> 中的几个地方在计算内存
      分配所需大小时不够小心。足够大的输入可能导致
      整数溢出，从而导致缓冲区大小不足，进而导致写入
      超出缓冲区的末尾。
     </para>
<!-- pgdoc-cn_end sig_en=3bb718dd02f927769666715fd15a3fff -->

<!-- pgdoc-cn_start sig_en=2076a9aff2193045036dd22a92b37dde sig_cn_org=2e53e9b3040f42ee66e6dec84f7ebbc1 source=18.3 
     <para>
      The <productname>PostgreSQL</productname> Project thanks Aleksey
      Solovev of Positive Technologies for reporting this problem.
      (CVE-2025-12818)
     </para>
________________________________________________________-->
     <para>
      <productname>PostgreSQL</productname> 项目感谢 Aleksey
      Solovev of Positive Technologies 报告此问题。
      （CVE-2025-12818）
     </para>
<!-- pgdoc-cn_end sig_en=2076a9aff2193045036dd22a92b37dde -->
    </listitem>

    <listitem>
<!--
Author: Amit Langote <amitlan@postgresql.org>
Branch: master [ef5e60a9d] 2025-10-09 01:07:59 -0400
Branch: REL_18_STABLE [dc9125111] 2025-10-09 01:07:52 -0400
Branch: REL_17_STABLE [09f86a42f] 2025-10-09 01:07:36 -0400
Author: Peter Eisentraut <peter@eisentraut.org>
Branch: master [c09a06918] 2025-11-04 12:25:04 +0100
Branch: REL_18_STABLE [1baae827e] 2025-11-04 12:25:14 +0100
Branch: REL_17_STABLE [1e6dfdaa0] 2025-11-04 12:25:20 +0100
-->
<!-- pgdoc-cn_start sig_en=55caad776036a0fdd70410e3505555e9 sig_cn_org=fc2674baaaef780d50d56f065e7edbae source=18.3 
     <para>
      Prevent <quote>unrecognized node type</quote> errors when a SQL/JSON
      function such as <function>JSON_VALUE</function> has
      a <literal>DEFAULT</literal> clause containing
      a <literal>COLLATE</literal> expression (Jian He)
      <ulink url="&commit_baseurl;dc9125111">&sect;</ulink>
      <ulink url="&commit_baseurl;1baae827e">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      防止在 SQL/JSON 函数如 <function>JSON_VALUE</function> 中出现
      <quote>未识别的节点类型</quote> 错误，当其具有包含
      <literal>DEFAULT</literal> 子句的 <literal>COLLATE</literal>
      表达式时（Jian He）
      <ulink url="&commit_baseurl;dc9125111">&sect;</ulink>
      <ulink url="&commit_baseurl;1baae827e">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=55caad776036a0fdd70410e3505555e9 -->
    </listitem>

    <listitem>
<!--
Author: Richard Guo <rguo@postgresql.org>
Branch: master [18d261409] 2025-10-21 12:35:36 +0900
Branch: REL_18_STABLE [40c242830] 2025-10-21 12:38:16 +0900
Branch: REL_18_STABLE [ee49f2cf4] 2025-10-21 14:12:13 +0900
-->
<!-- pgdoc-cn_start sig_en=fb738922cae7d94ee45cb54febf64299 sig_cn_org=3c95988a946be859e724bf3677b7f9fb source=18.3 
     <para>
      Avoid incorrect optimization of
      variable-free <literal>HAVING</literal> clauses with grouping sets
      (Richard Guo)
      <ulink url="&commit_baseurl;40c242830">&sect;</ulink>
      <ulink url="&commit_baseurl;ee49f2cf4">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      避免对不含变量的 <literal>HAVING</literal> 子句与分组集的错误优化
      （Richard Guo）
      <ulink url="&commit_baseurl;40c242830">&sect;</ulink>
      <ulink url="&commit_baseurl;ee49f2cf4">&sect;</ulink>
</para>
<!-- pgdoc-cn_end sig_en=fb738922cae7d94ee45cb54febf64299 -->
    </listitem>

    <listitem>
<!--
Author: Richard Guo <rguo@postgresql.org>
Branch: master [257ee7834] 2025-10-30 11:58:45 +0900
Branch: REL_18_STABLE [ef6168baf] 2025-10-30 12:03:15 +0900
-->
<!-- pgdoc-cn_start sig_en=e50cda420294fe9a6f0822db3756c8df sig_cn_org=7e52250734f0d05a75b9c0e78214a378 source=18.3 
     <para>
      Do not use parallelism in hash right semi joins (Richard Guo)
      <ulink url="&commit_baseurl;ef6168baf">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      不要在哈希右半连接中使用并行性（Richard Guo）
      <ulink url="&commit_baseurl;ef6168baf">&sect;</ulink>
</para>
<!-- pgdoc-cn_end sig_en=e50cda420294fe9a6f0822db3756c8df -->

<!-- pgdoc-cn_start sig_en=1053ef3d88b9b50972fde8e6e69c8d15 sig_cn_org=1531f29e3f5f48fd94019306a616d517 source=18.3 
     <para>
      The case does not work reliably due to a race condition in updating
      the join's shared hash table.
     </para>
________________________________________________________-->
     <para>
      由于更新连接的共享哈希表时发生竞争条件，该情况无法可靠工作。
</para>
<!-- pgdoc-cn_end sig_en=1053ef3d88b9b50972fde8e6e69c8d15 -->
    </listitem>

    <listitem>
<!--
Author: Richard Guo <rguo@postgresql.org>
Branch: master [c1777f2d6] 2025-11-05 18:09:21 +0900
Branch: REL_18_STABLE [500f64636] 2025-11-05 18:15:02 +0900
-->
<!-- pgdoc-cn_start sig_en=3db467908b8ca4a847989549f6ad2300 sig_cn_org=286c005cfc89436c03cf8637d1bec08f source=18.3 
     <para>
      Avoid possible division-by-zero when creating ordered-append plans
      (Richard Guo)
      <ulink url="&commit_baseurl;500f64636">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      在创建有序追加计划时，避免可能的零除错误
      （Richard Guo）
      <ulink url="&commit_baseurl;500f64636">&sect;</ulink>
</para>
<!-- pgdoc-cn_end sig_en=3db467908b8ca4a847989549f6ad2300 -->

<!-- pgdoc-cn_start sig_en=9c5b9a0c5c9d604ba1735662aa9de9f1 sig_cn_org=a982e33b3bdd2beb4dda51734ef1667c source=18.3 
     <para>
      This mistake could result in incorrect selection of the cheapest
      path, or in an assertion failure in debug builds.
     </para>
________________________________________________________-->
     <para>
      这个错误可能导致选择最便宜路径的错误，或者在调试构建中导致断言失败。
</para>
<!-- pgdoc-cn_end sig_en=9c5b9a0c5c9d604ba1735662aa9de9f1 -->
    </listitem>

    <listitem>
<!--
Author: Peter Eisentraut <peter@eisentraut.org>
Branch: master [35e53b684] 2025-10-28 10:07:29 +0100
Branch: REL_18_STABLE [74197bdc8] 2025-10-28 10:11:35 +0100
-->
<!-- pgdoc-cn_start sig_en=c4920c03b3e297a111c7387a8ed3a4d7 sig_cn_org=62effca66ebc9eae41ac9ae9edb1eebf source=18.3 
     <para>
      Fix planner failure with index types that can do ordered access but
      not index-only scans (Maxime Schoemans)
      <ulink url="&commit_baseurl;74197bdc8">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      修复规划器在可以进行有序访问但不能进行索引仅扫描的索引类型上的失败
      （Maxime Schoemans）
      <ulink url="&commit_baseurl;74197bdc8">&sect;</ulink>
</para>
<!-- pgdoc-cn_end sig_en=c4920c03b3e297a111c7387a8ed3a4d7 -->

<!-- pgdoc-cn_start sig_en=e662f0bca832c752acbbcfa669e6ad91 sig_cn_org=ac5cc6b39bb65ce7254b00700552ebfd source=18.3 
     <para>
      This oversight resulted in errors like <quote>no data returned for
      index-only scan</quote>.  The case does not arise with any in-core
      index type, but some extensions encountered the problem.
     </para>
________________________________________________________-->
     <para>
      这个疏忽导致了类似 <quote>索引仅扫描未返回数据</quote> 的错误。该情况在任何内核索引类型中都不会出现，但一些扩展遇到了这个问题。
</para>
<!-- pgdoc-cn_end sig_en=e662f0bca832c752acbbcfa669e6ad91 -->
    </listitem>

    <listitem>
<!--
Author: Peter Geoghegan <pg@bowt.ie>
