-->
<!-- pgdoc-cn_start sig_en=1696e28e0d12f4b2a9b9fa4900c39b3b sig_cn_org=5181e949f8aaeefd0e52bc70f84d75e1 source=18.3 
     <para>
      Fix <function>pg_stat_get_backend_wait_event()</function>
      and <function>pg_stat_get_backend_wait_event_type()</function>
      to report values for auxiliary processes (Heikki Linnakangas)
      <ulink url="&commit_baseurl;53463b4b2">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      修复 <function>pg_stat_get_backend_wait_event()</function>
      和 <function>pg_stat_get_backend_wait_event_type()</function>
      以报告辅助进程的值 (Heikki Linnakangas)
      <ulink url="&commit_baseurl;53463b4b2">&sect;</ulink>
</para>
<!-- pgdoc-cn_end sig_en=1696e28e0d12f4b2a9b9fa4900c39b3b -->

<!-- pgdoc-cn_start sig_en=9dc856b20d7af74950b1873b2b874154 sig_cn_org=c55af14ada4592e1f224dbcad92c6c84 source=18.3 
     <para>
      Previously these functions returned NULL for auxiliary processes,
      but that's inconsistent with
      the <structname>pg_stat_activity</structname> view.
     </para>
________________________________________________________-->
     <para>
      之前这些函数对辅助进程返回 NULL，
      但这与 <structname>pg_stat_activity</structname> 视图不一致。
     </para>
<!-- pgdoc-cn_end sig_en=9dc856b20d7af74950b1873b2b874154 -->
    </listitem>

    <listitem>
<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
Branch: master [9863c9075] 2026-02-11 16:53:14 -0500
Branch: REL_18_STABLE [ce4b7e3a1] 2026-02-11 16:53:14 -0500
Branch: REL_17_STABLE [dfd850980] 2026-02-11 16:53:14 -0500
Branch: REL_16_STABLE [c66f4cff1] 2026-02-11 16:53:14 -0500
Branch: REL_15_STABLE [254b15cbf] 2026-02-11 16:53:14 -0500
Branch: REL_14_STABLE [2b93d3820] 2026-02-11 16:53:14 -0500
-->
<!-- pgdoc-cn_start sig_en=79e0d2d6902bd0d5d164fc728fecdaf3 sig_cn_org=5bf010d74d4b6f355d720472a06e6f3c source=18.3 
     <para>
      Fix casting a composite-type variable to a domain type when
      returning its value from a PL/pgSQL function (Tom Lane)
      <ulink url="&commit_baseurl;ce4b7e3a1">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      修复从 PL/pgSQL 函数返回复合类型变量的值时
      将其转换为域类型的问题（Tom Lane）
      <ulink url="&commit_baseurl;ce4b7e3a1">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=79e0d2d6902bd0d5d164fc728fecdaf3 -->

<!-- pgdoc-cn_start sig_en=89e65f2e4615b5e5ad864ccce7ec9d62 sig_cn_org=e2806484567328b630ec6fc210cfdc21 source=18.3 
     <para>
      If the variable's value is NULL, a <quote>cache lookup failed for
      type 0</quote> error resulted.
     </para>
________________________________________________________-->
     <para>
      如果变量的值为 NULL，将导致 <quote>cache lookup failed for
      type 0</quote> 错误。
     </para>
<!-- pgdoc-cn_end sig_en=89e65f2e4615b5e5ad864ccce7ec9d62 -->
    </listitem>

    <listitem>
<!--
Author: Michael Paquier <michael@paquier.xyz>
Branch: master [a6f823e77] 2026-02-17 08:41:26 +0900
Branch: REL_18_STABLE [4a0843c53] 2026-02-17 08:41:30 +0900
Branch: REL_17_STABLE [0dfbe42da] 2026-02-17 08:41:32 +0900
Branch: REL_16_STABLE [31d0b917d] 2026-02-17 08:41:34 +0900
Branch: REL_15_STABLE [63c05e03b] 2026-02-17 08:41:35 +0900
Branch: REL_14_STABLE [f604cc695] 2026-02-17 08:41:37 +0900
-->
<!-- pgdoc-cn_start sig_en=cd05428b908e915a0d4569c5d5414bfe sig_cn_org=320bb66aad9787b2c818299c2901cc41 source=18.3 
     <para>
      Fix potential null pointer dereference
      in <filename>contrib/hstore</filename>'s binary input function
      (Michael Paquier)
      <ulink url="&commit_baseurl;4a0843c53">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      修复 <filename>contrib/hstore</filename> 的二进制输入函数中
      可能出现的空指针解引用问题（Michael Paquier）
      <ulink url="&commit_baseurl;4a0843c53">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=cd05428b908e915a0d4569c5d5414bfe -->

<!-- pgdoc-cn_start sig_en=184b5420ad6292040704532b1ae4ce32 sig_cn_org=bc269c9e0f5f5e3bbf748ef348aef4dc source=18.3 
     <para>
      <type>hstore</type>'s receive function crashed on input containing
      duplicate keys.  <type>hstore</type> values generated by Postgres
      would never contain duplicate keys, so this mistake has gone
      unnoticed.  The crash could be provoked by malicious or corrupted
      data.
     </para>
________________________________________________________-->
     <para>
      <type>hstore</type> 的接收函数在输入包含
      重复键时崩溃。<type>hstore</type> 由 Postgres 生成的值
      永远不会包含重复键，因此这个错误一直未被注意。
      崩溃可能是由恶意或损坏的数据引起的。
     </para>
<!-- pgdoc-cn_end sig_en=184b5420ad6292040704532b1ae4ce32 -->
    </listitem>

   </itemizedlist>

  </sect2>
 </sect1>

 <sect1 id="release-18-2">
<!-- pgdoc-cn_start sig_en=305b722a70d335419e864341dd1f9773 sig_cn_org=0c917ed8b0e09fcc50e9dbaa3e2220fa source=18.3 
  <title>Release 18.2</title>
________________________________________________________-->
  <title>版本 18.2</title>
<!-- pgdoc-cn_end sig_en=305b722a70d335419e864341dd1f9773 -->

  <formalpara>
<!-- pgdoc-cn_start sig_en=c45e8127eac45f2347bf1713afaeffda sig_cn_org=253305b4c6dff5b87ef36e3c2d95e52e source=15.7 
  <title>Release date:</title>
________________________________________________________-->
  <title>发布日期：</title>
<!-- pgdoc-cn_end sig_en=c45e8127eac45f2347bf1713afaeffda -->
<!-- pgdoc-cn_start sig_en=ef77042f06c30e99b97c52ff8e5ddbb7 sig_cn_org=dc37d4f050d45b314b5ef34951754829 source=18.3 
  <para>2026-02-12</para>
________________________________________________________-->
  <para>2026-02-12</para>
<!-- pgdoc-cn_end sig_en=ef77042f06c30e99b97c52ff8e5ddbb7 -->
  </formalpara>

<!-- pgdoc-cn_start sig_en=f2b272ccf4cdd1f1e8798823fbc6459c sig_cn_org=863e1d71e3003dce5758e80bf688367f source=18.3 
  <para>
   This release contains a variety of fixes from 18.1.
   For information about new features in major release 18, see
   <xref linkend="release-18"/>.
  </para>
________________________________________________________-->
  <para>
   此版本包含来自 18.1 的各种修复。
   有关主要版本 18 中新功能的信息，请参见
   <xref linkend="release-18"/>。
  </para>
<!-- pgdoc-cn_end sig_en=f2b272ccf4cdd1f1e8798823fbc6459c -->

  <sect2 id="release-18-2-migration">
<!-- pgdoc-cn_start sig_en=9f24d7cf895ae707859baa4f02238074 sig_cn_org=e5a9719514b854dbf4b803c59d21a0aa source=18.3 
   <title>Migration to Version 18.2</title>
________________________________________________________-->
   <title>迁移到版本 18.2</title>
<!-- pgdoc-cn_end sig_en=9f24d7cf895ae707859baa4f02238074 -->

<!-- pgdoc-cn_start sig_en=45204236df61a22e670593ffea4a5c26 sig_cn_org=90b9a58858a643fe3fe6473b1dbe1abf source=18.3 
   <para>
    A dump/restore is not required for those running 18.X.
   </para>
________________________________________________________-->
   <para>
    对于运行 18.X 的用户，不需要进行转储/恢复。
   </para>
<!-- pgdoc-cn_end sig_en=45204236df61a22e670593ffea4a5c26 -->

<!-- pgdoc-cn_start sig_en=f75e2fb79d1236aa4666845848f54ad3 sig_cn_org=67a3a0d2fce1b47aef636410418c34ee source=18.3 
   <para>
    However, if you have any indexes on <type>ltree</type> columns, it may
    be necessary to reindex them after updating.  See the sixth changelog
    entry below.
   </para>
________________________________________________________-->
   <para>
    然而，如果您在 <type>ltree</type> 列上有任何索引，
    更新后可能需要重新索引它们。请参见下面的第六个变更日志条目。
   </para>
<!-- pgdoc-cn_end sig_en=f75e2fb79d1236aa4666845848f54ad3 -->
  </sect2>

  <sect2 id="release-18-2-changes">
<!-- pgdoc-cn_start sig_en=e161fef38e54e54458e215e5f978ef9b sig_cn_org=f104d50dd9d4dd802f94229ebe5bc097 source=15.7 
   <title>Changes</title>
________________________________________________________-->
   <title>变更</title>
<!-- pgdoc-cn_end sig_en=e161fef38e54e54458e215e5f978ef9b -->

   <itemizedlist>

    <listitem>
<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
Branch: master [60e7ae41a] 2026-02-09 09:57:43 -0500
Branch: REL_18_STABLE [3b6588cd9] 2026-02-09 09:57:44 -0500
Branch: REL_17_STABLE [3d160401b] 2026-02-09 09:57:44 -0500
Branch: REL_16_STABLE [595956fc7] 2026-02-09 09:57:44 -0500
Branch: REL_15_STABLE [429aeaebd] 2026-02-09 09:57:44 -0500
Branch: REL_14_STABLE [b39d38139] 2026-02-09 09:57:44 -0500
-->
<!-- pgdoc-cn_start sig_en=c5597282a95d1df42515a064c4ba5075 sig_cn_org=577f0355985f17d4dc7bb3c21e65def0 source=18.3 
     <para>
      Guard against unexpected dimensions
      of <type>oidvector</type>/<type>int2vector</type> (Tom Lane)
      <ulink url="&commit_baseurl;3b6588cd9">&sect;</ulink>
     </para>
________________________________________________________-->
     <para>
      防止 <type>oidvector</type>/<type>int2vector</type> 的意外维度
      （Tom Lane）
      <ulink url="&commit_baseurl;3b6588cd9">&sect;</ulink>
     </para>
<!-- pgdoc-cn_end sig_en=c5597282a95d1df42515a064c4ba5075 -->

<!-- pgdoc-cn_start sig_en=12f415d2f8e8bdf6fe45db91c16c4eb3 sig_cn_org=9623a82cf8acc1d293bbead5d6d460f4 source=18.3 
     <para>
      These data types are expected to be 1-dimensional arrays containing
      no nulls, but there are cast pathways that permit violating those
      expectations.  Add checks to some functions that were depending on
      those expectations without verifying them, and could misbehave in
      consequence.
     </para>
________________________________________________________-->
     <para>
      这些数据类型预计是包含
      无 NULL 的一维数组，但存在允许违反这些
      预期的类型转换路径。对一些依赖于
      这些预期而未进行验证的函数添加检查，可能会因此出现异常行为。
     </para>
<!-- pgdoc-cn_end sig_en=12f415d2f8e8bdf6fe45db91c16c4eb3 -->

<!-- pgdoc-cn_start sig_en=b63e9f39b8b40d28ae4f142e4769df38 sig_cn_org=87659e85a8b71747db79a5e7bb8954f1 source=18.3 
     <para>
      The <productname>PostgreSQL</productname> Project thanks
      Altan Birler for reporting this problem.
      (CVE-2026-2003)
     </para>
________________________________________________________-->
     <para>
      <productname>PostgreSQL</productname> 项目感谢
      Altan Birler 报告此问题。
      （CVE-2026-2003）
     </para>
<!-- pgdoc-cn_end sig_en=b63e9f39b8b40d28ae4f142e4769df38 -->
    </listitem>

    <listitem>
<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
Branch: master [841d42cc4] 2026-02-09 10:07:31 -0500
Branch: REL_18_STABLE [66ddac698] 2026-02-09 10:07:31 -0500
