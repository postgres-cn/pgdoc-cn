<!--
Author: Richard Guo <rguo@postgresql.org>
2024-07-05 [aa86129e1] Support "Right Semi Join" plan shapes
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=8d04a8728637d66a233796a9ff90b549 sig_cn_org=995bac37452eb092ec2c61c82f0c16f8 source=18.3 
