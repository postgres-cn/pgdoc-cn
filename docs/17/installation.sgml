________________________________________________________-->
        <para>
         用于处理源代码的<command>clang</command>程序的路径，在使用<literal>--with-llvm</literal>编译时进行内联处理
        </para>
<!-- pgdoc-cn_end sig_en=97b99f6d9321e2a3a52005bceaa77e6b -->
