<!-- pgdoc-cn_start sig_en=f0de94ee375cfd86e9243ff12061471c sig_cn_org=50d423d9435a070799710ae0a2ff5b5c source=16.8 
    <para>
     At every level, even with full normalization off, basic normalization is
     performed. For example, <literal>'á'</literal> may be composed of the
     code points <literal>U&amp;'\0061\0301'</literal> or the single code
     point <literal>U&amp;'\00E1'</literal>, and those sequences will be
     considered equal even at the <literal>identic</literal> level. To treat
     any difference in code point representation as distinct, use a collation
     created with <symbol>deterministic</symbol> set to
     <literal>true</literal>.
    </para>
________________________________________________________-->
    <para>
     在每个级别，即使完全关闭规范化，也会执行基本的规范化。例如，
     <literal>'á'</literal>可能由代码点<literal>U&amp;'\0061\0301'</literal>
     或单个代码点<literal>U&amp;'\00E1'</literal>组成，这些序列即使在
     <literal>identic</literal>级别也会被视为相等。要将代码点表示中的
     任何差异视为不同，请使用设置了<symbol>deterministic</symbol>
     为<literal>true</literal>的排序规则。
    </para>
<!-- pgdoc-cn_end sig_en=f0de94ee375cfd86e9243ff12061471c -->

    <sect4 id="icu-collation-level-examples">
<!-- pgdoc-cn_start sig_en=4e024e2d282413f6f96d09640b5fa729 sig_cn_org=6913331c6020df7591c8ef5bf16bca20 source=16.8 
     <title>Collation Level Examples</title>
________________________________________________________-->
     <title>排序级别示例</title>
<!-- pgdoc-cn_end sig_en=4e024e2d282413f6f96d09640b5fa729 -->

<!-- pgdoc-cn_start sig_en=0ab995058cf3dadce90a97137b66f8fb sig_cn_org=0ab995058cf3dadce90a97137b66f8fb source=16.8 
<programlisting>
CREATE COLLATION level3 (provider = icu, deterministic = false, locale = 'und-u-ka-shifted-ks-level3');
CREATE COLLATION level4 (provider = icu, deterministic = false, locale = 'und-u-ka-shifted-ks-level4');
CREATE COLLATION identic (provider = icu, deterministic = false, locale = 'und-u-ka-shifted-ks-identic');

-&minus; invisible separator ignored at all levels except identic
SELECT 'ab' = U&amp;'a\2063b' COLLATE level4; -&minus; true
SELECT 'ab' = U&amp;'a\2063b' COLLATE identic; -&minus; false

-&minus; punctuation ignored at level3 but not at level 4
SELECT 'x-y' = 'x_y' COLLATE level3; -&minus; true
SELECT 'x-y' = 'x_y' COLLATE level4; -&minus; false
</programlisting>
________________________________________________________-->
<programlisting>
CREATE COLLATION level3 (provider = icu, deterministic = false, locale = 'und-u-ka-shifted-ks-level3');
CREATE COLLATION level4 (provider = icu, deterministic = false, locale = 'und-u-ka-shifted-ks-level4');
CREATE COLLATION identic (provider = icu, deterministic = false, locale = 'und-u-ka-shifted-ks-identic');

-- invisible separator ignored at all levels except identic
SELECT 'ab' = U&amp;'a\2063b' COLLATE level4; -- true
SELECT 'ab' = U&amp;'a\2063b' COLLATE identic; -- false

-- punctuation ignored at level3 but not at level 4
SELECT 'x-y' = 'x_y' COLLATE level3; -- true
SELECT 'x-y' = 'x_y' COLLATE level4; -- false
</programlisting>
<!-- pgdoc-cn_end sig_en=0ab995058cf3dadce90a97137b66f8fb -->

    </sect4>
   </sect3>

   <sect3 id="icu-collation-settings">
<!-- pgdoc-cn_start sig_en=315b193a30cdbc8870fd8abef471584d sig_cn_org=645a157eed98830879e5168878b19dfe source=16.8 
    <title>Collation Settings for an ICU Locale</title>
________________________________________________________-->
    <title>ICU区域设置的排序规则设置</title>
<!-- pgdoc-cn_end sig_en=315b193a30cdbc8870fd8abef471584d -->

<!-- pgdoc-cn_start sig_en=456813b468f97fbdd9b575d440854c52 sig_cn_org=4846ba298db7e190ff4d43b0680b98b9 source=16.8 
    <para>
     <xref linkend="icu-collation-settings-table"/> shows the available
     collation settings, which can be used as part of a language tag to
     customize a collation.
    </para>
________________________________________________________-->
    <para>
     <xref linkend="icu-collation-settings-table"/>显示了可用的排序设置，
     这些设置可以作为语言标签的一部分，用于自定义排序。
    </para>
<!-- pgdoc-cn_end sig_en=456813b468f97fbdd9b575d440854c52 -->

     <table id="icu-collation-settings-table">
<!-- pgdoc-cn_start sig_en=a0abfda893898e1573f53c4d162a3027 sig_cn_org=cc29ba859492dcc1a14b3e70529332a1 source=16.8 
      <title>ICU Collation Settings</title>
________________________________________________________-->
      <title>ICU 排序设置</title>
<!-- pgdoc-cn_end sig_en=a0abfda893898e1573f53c4d162a3027 -->
      <tgroup cols="4">
       <colspec colname="col1" colwidth="1*"/>
       <colspec colname="col2" colwidth="2*"/>
       <colspec colname="col3" colwidth="2*"/>
       <colspec colname="col4" colwidth="5*"/>

       <thead>
<!-- pgdoc-cn_start sig_en=ebdf461795733c97f0c0afffb70d4285 sig_cn_org=4c04b598b5a1afcb009ad8ab970ac168 source=16.8 
        <row>
         <entry>Key</entry>
         <entry>Values</entry>
         <entry>Default</entry>
         <entry>Description</entry>
        </row>
________________________________________________________-->
        <row>
         <entry>键</entry>
         <entry>值</entry>
         <entry>默认值</entry>
         <entry>描述</entry>
</row>
<!-- pgdoc-cn_end sig_en=ebdf461795733c97f0c0afffb70d4285 -->
       </thead>

       <tbody>
<!-- pgdoc-cn_start sig_en=db9a443aa5374f6f0f401d673c29e110 sig_cn_org=de0a79e1146b5277f855fc0422bb2937 source=16.8 
        <row>
         <entry><literal>co</literal></entry>
         <entry><literal>emoji</literal>, <literal>phonebk</literal>, <literal>standard</literal>, <replaceable>...</replaceable></entry>
         <entry><literal>standard</literal></entry>
         <entry>
          Collation type. See <xref linkend="icu-external-references"/> for additional options and details.
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>co</literal></entry>
         <entry><literal>emoji</literal>, <literal>phonebk</literal>, <literal>standard</literal>, <replaceable>...</replaceable></entry>
         <entry><literal>standard</literal></entry>
         <entry>
          排序类型。有关其他选项和详细信息，请参阅
          <xref linkend="icu-external-references"/>。
         </entry>
</row>
<!-- pgdoc-cn_end sig_en=db9a443aa5374f6f0f401d673c29e110 -->

<!-- pgdoc-cn_start sig_en=5def9387f799091637c4e9d8aaa87939 sig_cn_org=ae4ba96ec94a365b0eea97b342262060 source=16.8 
        <row>
         <entry><literal>ka</literal></entry>
         <entry><literal>noignore</literal>, <literal>shifted</literal></entry>
         <entry><literal>noignore</literal></entry>
         <entry>
          If set to <literal>shifted</literal>, causes some characters
          (e.g. punctuation or space) to be ignored in comparison. Key
          <literal>ks</literal> must be set to <literal>level3</literal> or
          lower to take effect. Set key <literal>kv</literal> to control which
          character classes are ignored.
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>ka</literal></entry>
         <entry><literal>noignore</literal>, <literal>shifted</literal></entry>
         <entry><literal>noignore</literal></entry>
         <entry>
          如果设置为<literal>shifted</literal>，会导致某些字符（例如标点符号或空格）
          在比较中被忽略。键<literal>ks</literal>必须设置为<literal>level3</literal>
          或更低才能生效。设置键<literal>kv</literal>以控制忽略哪些字符类别。
         </entry>
</row>
<!-- pgdoc-cn_end sig_en=5def9387f799091637c4e9d8aaa87939 -->

<!-- pgdoc-cn_start sig_en=74a631b3693261b5010820b6ba43d12a sig_cn_org=472ff3e6b0f247fab1b5d94f34c6c508 source=16.8 
        <row>
         <entry><literal>kb</literal></entry>
         <entry><literal>true</literal>, <literal>false</literal></entry>
         <entry><literal>false</literal></entry>
         <entry>
          Backwards comparison for the level 2 differences. For example,
          locale <literal>und-u-kb</literal> sorts <literal>'àe'</literal>
          before <literal>'aé'</literal>.
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>kb</literal></entry>
         <entry><literal>true</literal>, <literal>false</literal></entry>
         <entry><literal>false</literal></entry>
         <entry>
          对于第二级差异的反向比较。例如，区域设置
          <literal>und-u-kb</literal>将<literal>'àe'</literal>排在
          <literal>'aé'</literal>之前。
         </entry>
</row>
<!-- pgdoc-cn_end sig_en=74a631b3693261b5010820b6ba43d12a -->

<!-- pgdoc-cn_start sig_en=8b4cdb7835b66da0d88d3cdb30498cc4 sig_cn_org=154f3bdd9c060c9b6532099fa444acf2 source=16.8 
        <row>
         <entry><literal>kc</literal></entry>
         <entry><literal>true</literal>, <literal>false</literal></entry>
         <entry><literal>false</literal></entry>
         <entry>
          <para>
           Separates case into a "level 2.5" that falls between accents and
           other level 3 features.
          </para>
          <para>
           If set to <literal>true</literal> and <literal>ks</literal> is set
           to <literal>level1</literal>, will ignore accents but take case
           into account.
          </para>
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>kc</literal></entry>
         <entry><literal>true</literal>, <literal>false</literal></entry>
         <entry><literal>false</literal></entry>
         <entry>
          <para>
           将大小写分隔为“2.5级”，介于重音和其他3级特性之间。
          </para>
          <para>
           如果设置为<literal>true</literal>并且<literal>ks</literal>设置为
           <literal>level1</literal>，将忽略重音但考虑大小写。
          </para>
         </entry>
</row>
<!-- pgdoc-cn_end sig_en=8b4cdb7835b66da0d88d3cdb30498cc4 -->

<!-- pgdoc-cn_start sig_en=b522100493f57cf9bf9288773d53d22b sig_cn_org=72f58606af8692233504af662ccdf0a6 source=16.8 
        <row>
         <entry><literal>kf</literal></entry>
         <entry>
          <literal>upper</literal>, <literal>lower</literal>,
          <literal>false</literal>
         </entry>
         <entry><literal>false</literal></entry>
         <entry>
          If set to <literal>upper</literal>, upper case sorts before lower
          case. If set to <literal>lower</literal>, lower case sorts before
          upper case. If set to <literal>false</literal>, the sort depends on
          the rules of the locale.
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>kf</literal></entry>
         <entry>
          <literal>upper</literal>, <literal>lower</literal>,
          <literal>false</literal>
         </entry>
         <entry><literal>false</literal></entry>
         <entry>
          如果设置为<literal>upper</literal>，大写字母会排在小写字母之前。
          如果设置为<literal>lower</literal>，小写字母会排在大写字母之前。
          如果设置为<literal>false</literal>，排序取决于区域设置的规则。
         </entry>
</row>
<!-- pgdoc-cn_end sig_en=b522100493f57cf9bf9288773d53d22b -->

<!-- pgdoc-cn_start sig_en=32e99288ebc81ef94227f3acd366b573 sig_cn_org=53d0777d2d6bc0aba90b95c3dde87d5f source=16.8 
        <row>
         <entry><literal>kn</literal></entry>
         <entry><literal>true</literal>, <literal>false</literal></entry>
         <entry><literal>false</literal></entry>
         <entry>
          If set to <literal>true</literal>, numbers within a string are
          treated as a single numeric value rather than a sequence of
          digits. For example, <literal>'id-45'</literal> sorts before
          <literal>'id-123'</literal>.
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>kn</literal></entry>
         <entry><literal>true</literal>, <literal>false</literal></entry>
         <entry><literal>false</literal></entry>
         <entry>
          如果设置为<literal>true</literal>，字符串中的数字将被视为单个数值，
          而不是一串数字。例如，<literal>'id-45'</literal>会排在
          <literal>'id-123'</literal>之前。
         </entry>
</row>
<!-- pgdoc-cn_end sig_en=32e99288ebc81ef94227f3acd366b573 -->

<!-- pgdoc-cn_start sig_en=ad378e25d7e7e884f4d1cde6b369487a sig_cn_org=b2b639bd6c0c219960b64e37819c6c38 source=16.8 
        <row>
         <entry><literal>kk</literal></entry>
         <entry><literal>true</literal>, <literal>false</literal></entry>
         <entry><literal>false</literal></entry>
         <entry>
          <para>
           Enable full normalization; may affect performance. Basic
           normalization is performed even when set to
           <literal>false</literal>. Locales for languages that require full
           normalization typically enable it by default.
          </para>
          <para>
           Full normalization is important in some cases, such as when
           multiple accents are applied to a single character. For example,
           the code point sequences <literal>U&amp;'\0065\0323\0302'</literal>
           and <literal>U&amp;'\0065\0302\0323'</literal> represent
           an <literal>e</literal> with circumflex and dot-below accents
           applied in different orders. With full normalization
           on, these code point sequences are treated as equal; otherwise they
           are unequal.
          </para>
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>kk</literal></entry>
         <entry><literal>true</literal>, <literal>false</literal></entry>
         <entry><literal>false</literal></entry>
         <entry>
          <para>
           启用完全规范化；可能会影响性能。即使设置为
           <literal>false</literal>，也会执行基本规范化。需要完全规范化的语言的区域
           通常默认启用此功能。
          </para>
          <para>
           在某些情况下，完全规范化非常重要，例如当多个重音应用于单个字符时。
           例如，代码点序列<literal>U&amp;'\0065\0323\0302'</literal>和
           <literal>U&amp;'\0065\0302\0323'</literal>表示一个带有抑扬符和下点重音的
           <literal>e</literal>，但应用顺序不同。启用完全规范化时，这些代码点序列
           被视为相等；否则它们是不相等的。
          </para>
         </entry>
        </row>
<!-- pgdoc-cn_end sig_en=ad378e25d7e7e884f4d1cde6b369487a -->

<!-- pgdoc-cn_start sig_en=6d09090300a1b279f92008f88ebbdf93 sig_cn_org=b1581a0b34e8826b920b9952cd747b71 source=16.8 
        <row>
         <entry><literal>kr</literal></entry>
         <entry>
          <literal>space</literal>, <literal>punct</literal>,
          <literal>symbol</literal>, <literal>currency</literal>,
          <literal>digit</literal>, <replaceable>script-id</replaceable>
         </entry>
         <entry></entry>
         <entry>
          <para>
           Set to one or more of the valid values, or any BCP 47
           <replaceable>script-id</replaceable>, e.g. <literal>latn</literal>
           ("Latin") or <literal>grek</literal> ("Greek"). Multiple values are
           separated by "<literal>-</literal>".
          </para>
          <para>
           Redefines the ordering of classes of characters; those characters
           belonging to a class earlier in the list sort before characters
           belonging to a class later in the list. For instance, the value
           <literal>digit-currency-space</literal> (as part of a language tag
           like <literal>und-u-kr-digit-currency-space</literal>) sorts
           punctuation before digits and spaces.
          </para>
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>kr</literal></entry>
         <entry>
          <literal>space</literal>, <literal>punct</literal>,
          <literal>symbol</literal>, <literal>currency</literal>,
          <literal>digit</literal>, <replaceable>script-id</replaceable>
         </entry>
         <entry></entry>
         <entry>
          <para>
           设置为一个或多个有效值，或任何 BCP 47
           <replaceable>script-id</replaceable>，例如 <literal>latn</literal>
           （“拉丁”）或 <literal>grek</literal>（“希腊”）。多个值用
           "<literal>-</literal>" 分隔。
          </para>
          <para>
           重新定义字符类别的排序；属于列表中较早类别的字符在属于较晚类别的
           字符之前排序。例如，值 <literal>digit-currency-space</literal>
           （作为语言标签的一部分，如 <literal>und-u-kr-digit-currency-space</literal>）
           会将标点符号排序在数字和空格之前。
          </para>
         </entry>
</row>
<!-- pgdoc-cn_end sig_en=6d09090300a1b279f92008f88ebbdf93 -->

<!-- pgdoc-cn_start sig_en=ce4696d9bf47ed0445bb40cf39fd5b21 sig_cn_org=ceca0febe5e2752234527b1f604faedb source=16.8 
        <row>
         <entry><literal>ks</literal></entry>
         <entry><literal>level1</literal>, <literal>level2</literal>, <literal>level3</literal>, <literal>level4</literal>, <literal>identic</literal></entry>
         <entry><literal>level3</literal></entry>
         <entry>
          Sensitivity (or "strength") when determining equality, with
          <literal>level1</literal> the least sensitive to differences and
          <literal>identic</literal> the most sensitive to differences. See
          <xref linkend="icu-collation-levels"/> for details.
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>ks</literal></entry>
         <entry><literal>level1</literal>, <literal>level2</literal>, <literal>level3</literal>, 
         <literal>level4</literal>, <literal>identic</literal></entry>
         <entry><literal>level3</literal></entry>
         <entry>
          敏感度（或“强度”）在确定相等性时，<literal>level1</literal>对差异的敏感度最低，
          而<literal>identic</literal>对差异的敏感度最高。详见
          <xref linkend="icu-collation-levels"/>。
         </entry>
</row>
<!-- pgdoc-cn_end sig_en=ce4696d9bf47ed0445bb40cf39fd5b21 -->

<!-- pgdoc-cn_start sig_en=b7acf722090643b724c6c3f5d629720d sig_cn_org=45c807c46314e2803c0a83ca6c81b247 source=16.8 
        <row>
         <entry><literal>kv</literal></entry>
         <entry>
          <literal>space</literal>, <literal>punct</literal>,
          <literal>symbol</literal>, <literal>currency</literal>
         </entry>
         <entry><literal>punct</literal></entry>
         <entry>
          Classes of characters ignored during comparison at level 3. Setting
          to a later value includes earlier values;
          e.g. <literal>symbol</literal> also includes
          <literal>punct</literal> and <literal>space</literal> in the
          characters to be ignored. Key <literal>ka</literal> must be set to
          <literal>shifted</literal> and key <literal>ks</literal> must be set
          to <literal>level3</literal> or lower to take effect.
         </entry>
        </row>
________________________________________________________-->
        <row>
         <entry><literal>kv</literal></entry>
         <entry>
          <literal>space</literal>，<literal>punct</literal>，
          <literal>symbol</literal>，<literal>currency</literal>
         </entry>
         <entry><literal>punct</literal></entry>
         <entry>
          在第3级比较时忽略的字符类别。设置为更高的值时会包含较低的值；
          例如，<literal>symbol</literal>还包括<literal>punct</literal>和
          <literal>space</literal>在要忽略的字符中。键<literal>ka</literal>必须
          设置为<literal>shifted</literal>，键<literal>ks</literal>必须设置为
          <literal>level3</literal>或更低才能生效。
         </entry>
</row>
<!-- pgdoc-cn_end sig_en=b7acf722090643b724c6c3f5d629720d -->
       </tbody>
      </tgroup>
     </table>

<!-- pgdoc-cn_start sig_en=017320b1adf4238a1d0117c57c7a8de8 sig_cn_org=be8239b96334eb8dca0dc4f3ab844d21 source=16.8 
    <para>
     Defaults may depend on locale. The above table is not meant to be
     complete. See <xref linkend="icu-external-references"/> for additional
     options and details.
    </para>
________________________________________________________-->
    <para>
     默认值可能取决于区域设置。上表并不意味着是完整的。请参阅
     <xref linkend="icu-external-references"/>以获取更多选项和详细信息。
    </para>
<!-- pgdoc-cn_end sig_en=017320b1adf4238a1d0117c57c7a8de8 -->

    <note>
<!-- pgdoc-cn_start sig_en=0fbdd7599ab6a520a2595ccd69a5f9c2 sig_cn_org=3a18cc026c0b2073b9e44b23ecfd8d50 source=16.8 
     <para>
      For many collation settings, you must create the collation with
      <option>deterministic</option> set to <literal>false</literal> for the
      setting to have the desired effect (see <xref
      linkend="collation-nondeterministic"/>). Additionally, some settings
      only take effect when the key <literal>ka</literal> is set to
      <literal>shifted</literal> (see <xref
      linkend="icu-collation-settings-table"/>).
     </para>
________________________________________________________-->
     <para>
      对于许多排序设置，您必须将<option>deterministic</option>设置为
      <literal>false</literal>来创建排序，以实现所需的效果（请参阅
      <xref linkend="collation-nondeterministic"/>）。此外，某些设置仅在
      键<literal>ka</literal>设置为<literal>shifted</literal>时生效
      （请参阅<xref linkend="icu-collation-settings-table"/>）。
     </para>
<!-- pgdoc-cn_end sig_en=0fbdd7599ab6a520a2595ccd69a5f9c2 -->
    </note>
   </sect3>

   <sect3 id="icu-locale-examples">
<!-- pgdoc-cn_start sig_en=6a01bc506f2996948e5a3eb6703c3965 sig_cn_org=b478ad9cc654233efb0e1bd76d652ecf source=16.8 
    <title>Collation Settings Examples</title>
________________________________________________________-->
    <title>排序设置示例</title>
<!-- pgdoc-cn_end sig_en=6a01bc506f2996948e5a3eb6703c3965 -->

     <variablelist>
      <varlistentry id="collation-managing-create-icu-de-u-co-phonebk-x-icu">
       <term><literal>CREATE COLLATION "de-u-co-phonebk-x-icu" (provider = icu, locale = 'de-u-co-phonebk');</literal></term>
       <listitem>
<!-- pgdoc-cn_start sig_en=b5e39a2c81645f2630229f1256199a18 sig_cn_org=5baf13aef6eb6040b89b21939cdf6d33 source=16.8 
        <para>German collation with phone book collation type</para>
________________________________________________________-->
        <para>带有电话簿排序类型的德语排序</para>
<!-- pgdoc-cn_end sig_en=b5e39a2c81645f2630229f1256199a18 -->
       </listitem>
      </varlistentry>

      <varlistentry id="collation-managing-create-icu-und-u-co-emoji-x-icu">
       <term><literal>CREATE COLLATION "und-u-co-emoji-x-icu" (provider = icu, locale = 'und-u-co-emoji');</literal></term>
       <listitem>
<!-- pgdoc-cn_start sig_en=7d23583ff5bf1d3b89113bd24b164755 sig_cn_org=295ce9405b96b184c0143eb118546b93 source=16.8 
        <para>
         Root collation with Emoji collation type, per Unicode Technical Standard #51
        </para>
________________________________________________________-->
        <para>
         根排序使用表情符号排序类型，根据 Unicode 技术标准 #51
        </para>
<!-- pgdoc-cn_end sig_en=7d23583ff5bf1d3b89113bd24b164755 -->
       </listitem>
      </varlistentry>

      <varlistentry id="collation-managing-create-icu-en-u-kr-grek-latn">
       <term><literal>CREATE COLLATION latinlast (provider = icu, locale = 'en-u-kr-grek-latn');</literal></term>
       <listitem>
<!-- pgdoc-cn_start sig_en=7b3f9b51f4e3b0fe594375506c947e97 sig_cn_org=a3760836317598f94913c3ade170143f source=16.8 
        <para>
         Sort Greek letters before Latin ones.  (The default is Latin before Greek.)
        </para>
________________________________________________________-->
        <para>
         在拉丁字母之前排序希腊字母。（默认是拉丁字母在希腊字母之前。）
        </para>
<!-- pgdoc-cn_end sig_en=7b3f9b51f4e3b0fe594375506c947e97 -->
       </listitem>
      </varlistentry>

      <varlistentry id="collation-managing-create-icu-en-u-kf-upper">
       <term><literal>CREATE COLLATION upperfirst (provider = icu, locale = 'en-u-kf-upper');</literal></term>
       <listitem>
<!-- pgdoc-cn_start sig_en=e217e6f7644a445c157c854e40c73f2f sig_cn_org=40b1dfa84efdea96789aaf3704294ab9 source=16.8 
        <para>
         Sort upper-case letters before lower-case letters.  (The default is
         lower-case letters first.)
        </para>
________________________________________________________-->
        <para>
         将大写字母排在小写字母之前。（默认是小写字母优先。）
        </para>
<!-- pgdoc-cn_end sig_en=e217e6f7644a445c157c854e40c73f2f -->
       </listitem>
      </varlistentry>

      <varlistentry id="collation-managing-create-icu-en-u-kf-upper-kr-grek-latn">
       <term><literal>CREATE COLLATION special (provider = icu, locale = 'en-u-kf-upper-kr-grek-latn');</literal></term>
       <listitem>
<!-- pgdoc-cn_start sig_en=7ac712776cd815c208589c74c1608b34 sig_cn_org=5073f2029fceb7865a8ffe4aa38364e5 source=16.8 
        <para>
         Combines both of the above options.
        </para>
________________________________________________________-->
        <para>
         结合了以上两种选项。
        </para>
<!-- pgdoc-cn_end sig_en=7ac712776cd815c208589c74c1608b34 -->
       </listitem>
      </varlistentry>
     </variablelist>
   </sect3>

   <sect3 id="icu-tailoring-rules">
<!-- pgdoc-cn_start sig_en=d10dcb72794ccf8f25ee1362da5d3721 sig_cn_org=b4df36010a198869c03079c0abc5fa67 source=16.8 
    <title>ICU Tailoring Rules</title>
________________________________________________________-->
    <title>ICU 定制规则</title>
<!-- pgdoc-cn_end sig_en=d10dcb72794ccf8f25ee1362da5d3721 -->

<!-- pgdoc-cn_start sig_en=a5ba8d99ce7f13dd6b2129193ecd74e4 sig_cn_org=261623bf1785f6503c6f67e45076bbcf source=16.8 
    <para>
     If the options provided by the collation settings shown above are not
     sufficient, the order of collation elements can be changed with tailoring
     rules, whose syntax is detailed at <ulink
     url="https://unicode-org.github.io/icu/userguide/collation/customization/"></ulink>.
    </para>
________________________________________________________-->
    <para>
     如果上述排序设置提供的选项不够充分，可以通过定制规则更改排序
     元素的顺序，其语法详见<ulink
     url="https://unicode-org.github.io/icu/userguide/collation/customization/"></ulink>。
    </para>
<!-- pgdoc-cn_end sig_en=a5ba8d99ce7f13dd6b2129193ecd74e4 -->

<!-- pgdoc-cn_start sig_en=2c981fca5dbc8a1738448396be766a64 sig_cn_org=df4f5dde669c958aef4928dd08fe3a89 source=16.8 
    <para>
     This small example creates a collation based on the root locale with a
     tailoring rule:
<programlisting>
<![CDATA[CREATE COLLATION custom (provider = icu, locale = 'und', rules = '&V << w <<< W');]]>
</programlisting>
     With this rule, the letter <quote>W</quote> is sorted after
     <quote>V</quote>, but is treated as a secondary difference similar to an
     accent.  Rules like this are contained in the locale definitions of some
     languages.  (Of course, if a locale definition already contains the
     desired rules, then they don't need to be specified again explicitly.)
    </para>
________________________________________________________-->
    <para>
     这个小例子基于根区域设置创建了一个排序规则，并使用了以下定制规则：
<programlisting>
<![CDATA[CREATE COLLATION custom (provider = icu, locale = 'und', rules = '&V << w <<< W');]]>
</programlisting>
     根据这个规则，字母<quote>W</quote>被排序在<quote>V</quote>之后，
     但被视为类似于重音的次要差异。这类规则包含在某些语言的区域设置定义中。
     （当然，如果区域设置定义已经包含了所需的规则，那么就不需要再次显式指定了。）
    </para>
<!-- pgdoc-cn_end sig_en=2c981fca5dbc8a1738448396be766a64 -->

<!-- pgdoc-cn_start sig_en=263fb4a2f1bf1ee31d08724aa4303af4 sig_cn_org=9e67c1caade46e1bdc2f9d2c0cc04be5 source=16.8 
    <para>
     Here is a more complex example.  The following statement sets up a
     collation named <literal>ebcdic</literal> with rules to sort US-ASCII
     characters in the order of the EBCDIC encoding.

<programlisting>
<![CDATA[CREATE COLLATION ebcdic (provider = icu, locale = 'und',
rules = $$
& ' ' < '.' < '<' < '(' < '+' < \|
< '&' < '!' < '$' < '*' < ')' < ';'
< '-' < '/' < ',' < '%' < '_' < '>' < '?'
< '`' < ':' < '#' < '@' < \' < '=' < '"'
<*a-r < '~' <*s-z < '^' < '[' < ']'
< '{' <*A-I < '}' <*J-R < '\' <*S-Z <*0-9
$$);]]>

SELECT c
FROM (VALUES ('a'), ('b'), ('A'), ('B'), ('1'), ('2'), ('!'), ('^')) AS x(c)
ORDER BY c COLLATE ebcdic;
 c
-&minus;-
 !
 a
 b
 ^
 A
 B
 1
 2
</programlisting>
    </para>
________________________________________________________-->
    <para>
     这里是一个更复杂的示例。以下语句设置了一个名为
     <literal>ebcdic</literal>的排序规则，用于按照EBCDIC编码的顺序对
     US-ASCII字符进行排序。

<programlisting>
<![CDATA[CREATE COLLATION ebcdic (provider = icu, locale = 'und',
rules = $$
& ' ' < '.' < '<' < '(' < '+' < \|
< '&' < '!' < '$' < '*' < ')' < ';'
< '-' < '/' < ',' < '%' < '_' < '>' < '?'
< '`' < ':' < '#' < '@' < \' < '=' < '"'
<*a-r < '~' <*s-z < '^' < '[' < ']'
< '{' <*A-I < '}' <*J-R < '\' <*S-Z <*0-9
$$);]]>

SELECT c
FROM (VALUES ('a'), ('b'), ('A'), ('B'), ('1'), ('2'), ('!'), ('^')) AS x(c)
ORDER BY c COLLATE ebcdic;
 c
---
 !
 a
 b
 ^
 A
 B
 1
 2
</programlisting>
    </para>
<!-- pgdoc-cn_end sig_en=263fb4a2f1bf1ee31d08724aa4303af4 -->
   </sect3>

   <sect3 id="icu-external-references">
<!-- pgdoc-cn_start sig_en=31e414e3d6161886881cefea07f44ec7 sig_cn_org=8b08ebfdbf2b61ae0bdf207c2206a7af source=16.8 
    <title>External References for ICU</title>
________________________________________________________-->
    <title>ICU的外部参考</title>
<!-- pgdoc-cn_end sig_en=31e414e3d6161886881cefea07f44ec7 -->

<!-- pgdoc-cn_start sig_en=e624897f087cf570da96975e745decb2 sig_cn_org=3433fcb311035c51458d6d61e28bcdae source=16.8 
    <para>
     This section (<xref linkend="icu-custom-collations"/>) is only a brief
     overview of ICU behavior and language tags. Refer to the following
     documents for technical details, additional options, and new behavior:
    </para>
________________________________________________________-->
    <para>
     本节 (<xref linkend="icu-custom-collations"/>) 只是对ICU行为和语言标签的简要
     概述。有关技术细节、附加选项和新行为，请参阅以下文档：
    </para>
<!-- pgdoc-cn_end sig_en=e624897f087cf570da96975e745decb2 -->

    <itemizedlist>
     <listitem>
<!-- pgdoc-cn_start sig_en=cfe16274035643e5c91e12fb94c972ad sig_cn_org=878d3b262ebfed8b730e57f9c97bddb0 source=16.8 
      <para>
       <ulink url="https://www.unicode.org/reports/tr35/tr35-collation.html">Unicode Technical Standard #35</ulink>
      </para>
________________________________________________________-->
