<!-- doc/src/sgml/pgbuffercache.sgml -->

<sect1 id="pgbuffercache" xreflabel="pg_buffercache">
<!-- pgdoc-cn_start sig_en=15facf023ef6f4e9d2d7ddc7c112a051 sig_cn_org=7b11774ddc47e4f7fc85746d5a780b9d source=16.8 
 <title>pg_buffercache &mdash; inspect <productname>PostgreSQL</productname>
    buffer cache state</title>
________________________________________________________-->
 <title>pg_buffercache &mdash; 检查<productname>PostgreSQL</productname>
    缓冲区缓存状态</title>
<!-- pgdoc-cn_end sig_en=15facf023ef6f4e9d2d7ddc7c112a051 -->

<!-- pgdoc-cn_start sig_en=c4f460124da0c56a87c0a42668731858 sig_cn_org=None source=14.1 
 <indexterm zone="pgbuffercache">
  <primary>pg_buffercache</primary>
 </indexterm>
________________________________________________________-->
 <indexterm zone="pgbuffercache">
  <primary>pg_buffercache</primary>
 </indexterm>
<!-- pgdoc-cn_end sig_en=c4f460124da0c56a87c0a42668731858 -->

<!-- pgdoc-cn_start sig_en=7e9f2ee0882d39c1f9374606fa222d11 sig_cn_org=1edc082b3dc71ff7efd021fcc3dada59 source=17.5 
 <para>
  The <filename>pg_buffercache</filename> module provides a means for
  examining what's happening in the shared buffer cache in real time.
  It also offers a low-level way to evict data from it, for testing
  purposes.
 </para>
________________________________________________________-->
 <para>
  <filename>pg_buffercache</filename>模块提供了一种实时检查共享缓冲区缓存中
  发生情况的方法。它还提供了一种低级方式来驱逐其中的数据，用于测试目的。
 </para>
<!-- pgdoc-cn_end sig_en=7e9f2ee0882d39c1f9374606fa222d11 -->

<!-- pgdoc-cn_start sig_en=c48c67d811fbb856a32741845201e625 sig_cn_org=None source=14.1 
 <indexterm>
  <primary>pg_buffercache_pages</primary>
 </indexterm>
________________________________________________________-->
 <indexterm>
  <primary>pg_buffercache_pages</primary>
 </indexterm>
<!-- pgdoc-cn_end sig_en=c48c67d811fbb856a32741845201e625 -->

<!-- pgdoc-cn_start sig_en=a1fa29dad8daa134122e9f4a557b0cf2 sig_cn_org=7a7f6a88229c1859990bba8c616067c1 source=16.8 
 <indexterm>
  <primary>pg_buffercache_summary</primary>
 </indexterm>
________________________________________________________-->
 <indexterm>
  <primary>pg_buffercache_summary</primary>
 </indexterm>
<!-- pgdoc-cn_end sig_en=a1fa29dad8daa134122e9f4a557b0cf2 -->

<!-- pgdoc-cn_start sig_en=981332e303fd9e3c91925632aeb3e911 sig_cn_org=981332e303fd9e3c91925632aeb3e911 source=17.5 
 <indexterm>
  <primary>pg_buffercache_evict</primary>
 </indexterm>
________________________________________________________-->
 <indexterm>
  <primary>pg_buffercache_evict</primary>
 </indexterm>
<!-- pgdoc-cn_end sig_en=981332e303fd9e3c91925632aeb3e911 -->

<!-- pgdoc-cn_start sig_en=84e1477ab95bd1bba1e0f9a9cd6f0464 sig_cn_org=dec21c32d4001baa305fe7ade03a2aca source=17.5 
 <para>
  This module provides the <function>pg_buffercache_pages()</function>
  function (wrapped in the <structname>pg_buffercache</structname> view),
  the <function>pg_buffercache_summary()</function> function, the
  <function>pg_buffercache_usage_counts()</function> function and
  the <function>pg_buffercache_evict()</function> function.
 </para>
________________________________________________________-->
 <para>
  本模块提供了<function>pg_buffercache_pages()</function>函数（封装在
  <structname>pg_buffercache</structname>视图中）、<function>pg_buffercache_summary()</function>函数、
  <function>pg_buffercache_usage_counts()</function>函数以及<function>pg_buffercache_evict()</function>函数。
 </para>
<!-- pgdoc-cn_end sig_en=84e1477ab95bd1bba1e0f9a9cd6f0464 -->

<!-- pgdoc-cn_start sig_en=5001cfa9df70d73d93cc0206e4fb3041 sig_cn_org=8ce62be5f29faf7720261353c09d52b5 source=16.8 
 <para>
  The <function>pg_buffercache_pages()</function> function returns a set of
  records, each row describing the state of one shared buffer entry. The
  <structname>pg_buffercache</structname> view wraps the function for
  convenient use.
 </para>
________________________________________________________-->
 <para>
  <function>pg_buffercache_pages()</function>函数返回一组记录，每行描述一个共享缓冲区
  条目的状态。<structname>pg_buffercache</structname>视图封装了该函数以便于使用。
 </para>
<!-- pgdoc-cn_end sig_en=5001cfa9df70d73d93cc0206e4fb3041 -->

<!-- pgdoc-cn_start sig_en=967e6b91104c0af4b8d755e24e4946fa sig_cn_org=a9dfb5cf10d1b454de283277c0724d5b source=16.8 
 <para>
  The <function>pg_buffercache_summary()</function> function returns a single
  row summarizing the state of the shared buffer cache.
 </para>
________________________________________________________-->
 <para>
  <function>pg_buffercache_summary()</function> 函数返回一行摘要，概述共享缓冲区缓存的状态。
 </para>
<!-- pgdoc-cn_end sig_en=967e6b91104c0af4b8d755e24e4946fa -->

<!-- pgdoc-cn_start sig_en=482fffce98d688f1db805b62dcb0de96 sig_cn_org=dad754e33e1af34027b3463c9d13de0c source=16.8 
 <para>
  The <function>pg_buffercache_usage_counts()</function> function returns a set
  of records, each row describing the number of buffers with a given usage
  count.
 </para>
________________________________________________________-->
 <para>
  <function>pg_buffercache_usage_counts()</function> 函数返回一组记录，每行描述具有
  给定使用计数的缓冲区数量。
 </para>
<!-- pgdoc-cn_end sig_en=482fffce98d688f1db805b62dcb0de96 -->

<!-- pgdoc-cn_start sig_en=268c242d12fcb3f7f13398311370c0d5 sig_cn_org=d17a4ee69cf4b11fef74a1b88b919998 source=17.5 
 <para>
  By default, use of the above functions is restricted to superusers and roles
  with privileges of the <literal>pg_monitor</literal> role. Access may be
  granted to others using <command>GRANT</command>.
 </para>
________________________________________________________-->
 <para>
  默认情况下，上述函数的使用仅限于超级用户和具有<literal>pg_monitor</literal>角色权限的角色。
  访问权限可以通过<command>GRANT</command>授予其他用户。
 </para>
<!-- pgdoc-cn_end sig_en=268c242d12fcb3f7f13398311370c0d5 -->

<!-- pgdoc-cn_start sig_en=58d031c89f7915527b6f93a0bb530604 sig_cn_org=131aa71c221b50a46183934fd30cce9e source=17.5 
 <para>
  The <function>pg_buffercache_evict()</function> function allows a block to
  be evicted from the buffer pool given a buffer identifier.  Use of this
  function is restricted to superusers only.
 </para>
________________________________________________________-->
 <para>
  <function>pg_buffercache_evict()</function>函数允许根据缓冲区标识符将块从缓冲池中驱逐。
  该函数的使用仅限于超级用户。
 </para>
<!-- pgdoc-cn_end sig_en=58d031c89f7915527b6f93a0bb530604 -->

