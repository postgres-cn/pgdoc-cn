 <refmeta>
  <refentrytitle>ALTER OPERATOR</refentrytitle>
  <manvolnum>7</manvolnum>
  <refmiscinfo>SQL - Language Statements</refmiscinfo>
 </refmeta>

<!-- pgdoc-cn_start sig_en=e2c8c36e88147dc091e5cba04f47ca31 sig_cn_org=None source=14.1 
 <refnamediv>
  <refname>ALTER OPERATOR</refname>
  <refpurpose>change the definition of an operator</refpurpose>
 </refnamediv>
________________________________________________________-->
 <refnamediv>
  <refname>ALTER OPERATOR</refname>
  <refpurpose>更改操作符的定义</refpurpose>
 </refnamediv>
<!-- pgdoc-cn_end sig_en=e2c8c36e88147dc091e5cba04f47ca31 -->

 <refsynopsisdiv>
<!-- pgdoc-cn_start sig_en=fc1c427ad956c562f2cd3be205a302de sig_cn_org=fc1c427ad956c562f2cd3be205a302de source=17.5 
<synopsis>
ALTER OPERATOR <replaceable>name</replaceable> ( { <replaceable>left_type</replaceable> | NONE } , <replaceable>right_type</replaceable> )
    OWNER TO { <replaceable>new_owner</replaceable> | CURRENT_ROLE | CURRENT_USER | SESSION_USER }

ALTER OPERATOR <replaceable>name</replaceable> ( { <replaceable>left_type</replaceable> | NONE } , <replaceable>right_type</replaceable> )
    SET SCHEMA <replaceable>new_schema</replaceable>

ALTER OPERATOR <replaceable>name</replaceable> ( { <replaceable>left_type</replaceable> | NONE } , <replaceable>right_type</replaceable> )
    SET ( {  RESTRICT = { <replaceable class="parameter">res_proc</replaceable> | NONE }
           | JOIN = { <replaceable class="parameter">join_proc</replaceable> | NONE }
           | COMMUTATOR = <replaceable class="parameter">com_op</replaceable>
           | NEGATOR = <replaceable class="parameter">neg_op</replaceable>
           | HASHES
           | MERGES
          } [, ... ] )
</synopsis>
________________________________________________________-->
<synopsis>
ALTER OPERATOR <replaceable>name</replaceable> ( { <replaceable>left_type</replaceable> | NONE } , <replaceable>right_type</replaceable> )
    OWNER TO { <replaceable>new_owner</replaceable> | CURRENT_ROLE | CURRENT_USER | SESSION_USER }

ALTER OPERATOR <replaceable>name</replaceable> ( { <replaceable>left_type</replaceable> | NONE } , <replaceable>right_type</replaceable> )
    SET SCHEMA <replaceable>new_schema</replaceable>

ALTER OPERATOR <replaceable>name</replaceable> ( { <replaceable>left_type</replaceable> | NONE } , <replaceable>right_type</replaceable> )
    SET ( {  RESTRICT = { <replaceable class="parameter">res_proc</replaceable> | NONE }
           | JOIN = { <replaceable class="parameter">join_proc</replaceable> | NONE }
           | COMMUTATOR = <replaceable class="parameter">com_op</replaceable>
           | NEGATOR = <replaceable class="parameter">neg_op</replaceable>
           | HASHES
           | MERGES
          } [, ... ] )
</synopsis>
<!-- pgdoc-cn_end sig_en=fc1c427ad956c562f2cd3be205a302de -->
 </refsynopsisdiv>

 <refsect1>
<!-- pgdoc-cn_start sig_en=59d6e86f3a60db4f1e08d0d6e639924e sig_cn_org=None source=14.1 
  <title>Description</title>
________________________________________________________-->
  <title>描述</title>
<!-- pgdoc-cn_end sig_en=59d6e86f3a60db4f1e08d0d6e639924e -->

<!-- pgdoc-cn_start sig_en=77888d48aef4f84d7e235e8da18b801d sig_cn_org=None source=14.1 
  <para>
   <command>ALTER OPERATOR</command> changes the definition of
   an operator.
  </para>
________________________________________________________-->
  <para>
   <command>ALTER OPERATOR</command>更改操作符的定义。
  </para>
<!-- pgdoc-cn_end sig_en=77888d48aef4f84d7e235e8da18b801d -->

<!-- pgdoc-cn_start sig_en=7ff33071e3c640a7700b1965d8c6a843 sig_cn_org=ebddfe6df6cd3917d424533e7ec3a760 source=16.8 
  <para>
   You must own the operator to use <command>ALTER OPERATOR</command>.
   To alter the owner, you must be able to <literal>SET ROLE</literal> to the
   new owning role, and that role must have <literal>CREATE</literal>
   privilege on the operator's schema.
   (These restrictions enforce that altering the owner
   doesn't do anything you couldn't do by dropping and recreating the operator.
   However, a superuser can alter ownership of any operator anyway.)
  </para>
________________________________________________________-->
  <para>
   您必须拥有该操作符才能使用<command>ALTER OPERATOR</command>。
   要更改所有者，您必须能够<literal>SET ROLE</literal>为新的所有角色，
   并且该角色必须对操作符的模式具有<literal>CREATE</literal>权限。
   （这些限制确保更改所有者不会做任何您不能通过删除和重新创建操作符
   来完成的事情。然而，超级用户仍然可以更改任何操作符的所有权。）
</para>
<!-- pgdoc-cn_end sig_en=7ff33071e3c640a7700b1965d8c6a843 -->
 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=55f21f3bddee6a8d223aa24ab57d80dc sig_cn_org=None source=14.1 
  <title>Parameters</title>
________________________________________________________-->
  <title>参数</title>
<!-- pgdoc-cn_end sig_en=55f21f3bddee6a8d223aa24ab57d80dc -->

  <variablelist>
   <varlistentry>
    <term><replaceable class="parameter">name</replaceable></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=9520445a8aac180fe8620493a152d32f sig_cn_org=None source=14.1 
     <para>
      The name (optionally schema-qualified) of an existing operator.
     </para>
________________________________________________________-->
     <para>
      一个现有操作符的名称（可以是模式限定的）。
     </para>
<!-- pgdoc-cn_end sig_en=9520445a8aac180fe8620493a152d32f -->
    </listitem>
   </varlistentry>

   <varlistentry>
    <term><replaceable class="parameter">left_type</replaceable></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=48aaf92d77d4ba9c81c110ce0173a8a2 sig_cn_org=None source=14.1 
     <para>
      The data type of the operator's left operand; write
      <literal>NONE</literal> if the operator has no left operand.
     </para>
________________________________________________________-->
     <para>
      该操作符左操作数的数据类型，如果该操作符没有左操作数就可以写成
      <literal>NONE</literal>。
     </para>
<!-- pgdoc-cn_end sig_en=48aaf92d77d4ba9c81c110ce0173a8a2 -->
    </listitem>
   </varlistentry>

   <varlistentry>
    <term><replaceable class="parameter">right_type</replaceable></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=914e162e70ac09ee4e99abe4b7e4d433 sig_cn_org=None source=14.1 
     <para>
      The data type of the operator's right operand.
     </para>
________________________________________________________-->
     <para>
      该操作符右操作数的数据类型。
     </para>
<!-- pgdoc-cn_end sig_en=914e162e70ac09ee4e99abe4b7e4d433 -->
    </listitem>
   </varlistentry>

   <varlistentry>
    <term><replaceable class="parameter">new_owner</replaceable></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=43ec8489885e059344c9264b8b092bb7 sig_cn_org=None source=14.1 
     <para>
      The new owner of the operator.
     </para>
________________________________________________________-->
     <para>
      该操作符的新拥有者。
     </para>
<!-- pgdoc-cn_end sig_en=43ec8489885e059344c9264b8b092bb7 -->
    </listitem>
   </varlistentry>

   <varlistentry>
    <term><replaceable class="parameter">new_schema</replaceable></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=d6181a1a0a773fc26a0f862b200a28ca sig_cn_org=None source=14.1 
     <para>
      The new schema for the operator.
     </para>
________________________________________________________-->
     <para>
      该操作符的新模式。
     </para>
<!-- pgdoc-cn_end sig_en=d6181a1a0a773fc26a0f862b200a28ca -->
    </listitem>
   </varlistentry>

   <varlistentry>
     <term><replaceable class="parameter">res_proc</replaceable></term>
     <listitem>
<!-- pgdoc-cn_start sig_en=94ad51d8498532eb4b5048f3e01e0dcf sig_cn_org=None source=14.1 
       <para>
         The restriction selectivity estimator function for this operator; write NONE to remove existing selectivity estimator.
       </para>
________________________________________________________-->
       <para>
         这个操作符的约束选择度估算器函数，写成 NONE 可以移除现有的选择度估算器。
       </para>
<!-- pgdoc-cn_end sig_en=94ad51d8498532eb4b5048f3e01e0dcf -->
      </listitem>
   </varlistentry>

   <varlistentry>
     <term><replaceable class="parameter">join_proc</replaceable></term>
     <listitem>
<!-- pgdoc-cn_start sig_en=6f608ac46c2783297a60073435297da4 sig_cn_org=None source=14.1 
       <para>
         The join selectivity estimator function for this operator; write NONE to remove existing selectivity estimator.
       </para>
________________________________________________________-->
       <para>
         这个操作符的连接选择度估算器函数，写成 NONE 可以移除现有的选择度估算器。
       </para>
<!-- pgdoc-cn_end sig_en=6f608ac46c2783297a60073435297da4 -->
     </listitem>
   </varlistentry>

   <varlistentry>
    <term><replaceable class="parameter">com_op</replaceable></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=05cb982c7b16204cb5f391c579476f4b sig_cn_org=f64689ecda6adbc923efe4e7b28ec752 source=17.5 
     <para>
      The commutator of this operator. Can only be changed if the operator
      does not have an existing commutator.
     </para>
________________________________________________________-->
     <para>
      该算子的对易子。只有当算子没有现有的对易子时，才能更改。
     </para>
<!-- pgdoc-cn_end sig_en=05cb982c7b16204cb5f391c579476f4b -->
    </listitem>
   </varlistentry>

   <varlistentry>
    <term><replaceable class="parameter">neg_op</replaceable></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=43b07c096424c83d935a0a9508f11841 sig_cn_org=3342a2d393e61b199fddd34a9e3c9f8c source=17.5 
     <para>
      The negator of this operator. Can only be changed if the operator does
      not have an existing negator.
     </para>
________________________________________________________-->
     <para>
      该操作符的否定符。只有当操作符没有现有的否定符时，才能更改。
     </para>
<!-- pgdoc-cn_end sig_en=43b07c096424c83d935a0a9508f11841 -->
    </listitem>
   </varlistentry>

   <varlistentry>
    <term><literal>HASHES</literal></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=ffa5087224b3d0b11bf1fa6d58184239 sig_cn_org=71b9c5e5f20952887180e48a7822f2ef source=17.5 
     <para>
      Indicates this operator can support a hash join. Can only be enabled and
      not disabled.
     </para>
________________________________________________________-->
     <para>
      表示此操作符支持哈希连接。只能启用，不能禁用。
     </para>
<!-- pgdoc-cn_end sig_en=ffa5087224b3d0b11bf1fa6d58184239 -->
    </listitem>
   </varlistentry>

   <varlistentry>
    <term><literal>MERGES</literal></term>
    <listitem>
<!-- pgdoc-cn_start sig_en=6e10eaf2ff2a7accda94acd9239fb1c3 sig_cn_org=18c42973f7278d4311552a2e1e979c4a source=17.5 
     <para>
      Indicates this operator can support a merge join. Can only be enabled
      and not disabled.
     </para>
________________________________________________________-->
     <para>
      表示此操作符支持合并连接。只能启用，不能禁用。
     </para>
<!-- pgdoc-cn_end sig_en=6e10eaf2ff2a7accda94acd9239fb1c3 -->
    </listitem>
   </varlistentry>

  </variablelist>
 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=c44fa43baeb4f69a8a2aa1ea108c6e97 sig_cn_org=b23be51e9f479e0921e170111e08319e source=15.7 
  <title>Notes</title>
________________________________________________________-->
  <title>笔记</title>
<!-- pgdoc-cn_end sig_en=c44fa43baeb4f69a8a2aa1ea108c6e97 -->

<!-- pgdoc-cn_start sig_en=87ab44e6779c0959d136721e538957a6 sig_cn_org=87ab44e6779c0959d136721e538957a6 source=17.5 
  <para>
   Refer to <xref linkend="xoper"/> and
   <xref linkend="xoper-optimization"/> for further information.
  </para>
________________________________________________________-->
  <para>
   更多信息请参考 <xref linkend="xoper"/> 和
   <xref linkend="xoper-optimization"/>。
  </para>
<!-- pgdoc-cn_end sig_en=87ab44e6779c0959d136721e538957a6 -->

<!-- pgdoc-cn_start sig_en=3dca4db50ed08f11ab6f8926c33bfbbe sig_cn_org=e6c4ec0620f3e7bf61893ace04c29622 source=17.5 
  <para>
   Since commutators come in pairs that are commutators of each other,
   <literal>ALTER OPERATOR SET COMMUTATOR</literal> will also set the
   commutator of the <replaceable class="parameter">com_op</replaceable>
   to be the target operator.  Likewise, <literal>ALTER OPERATOR SET
   NEGATOR</literal> will also set the negator of
   the <replaceable class="parameter">neg_op</replaceable> to be the
   target operator.  Therefore, you must own the commutator or negator
   operator as well as the target operator.
  </para>
________________________________________________________-->
  <para>
   由于换位子成对出现，且彼此互为换位子，<literal>ALTER OPERATOR SET COMMUTATOR</literal>也会设置
   <replaceable class="parameter">com_op</replaceable>的换位子为目标操作符。同样，<literal>ALTER OPERATOR SET
   NEGATOR</literal>也会将<replaceable class="parameter">neg_op</replaceable>的否定子设置为目标操作符。
   因此，您必须同时拥有换位子或否定子操作符以及目标操作符的所有权。
  </para>
<!-- pgdoc-cn_end sig_en=3dca4db50ed08f11ab6f8926c33bfbbe -->
 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=8f24ed0a9e4d47ffa2be9a1f3e09fa6d sig_cn_org=None source=14.1 
  <title>Examples</title>
________________________________________________________-->
  <title>示例</title>
<!-- pgdoc-cn_end sig_en=8f24ed0a9e4d47ffa2be9a1f3e09fa6d -->

<!-- pgdoc-cn_start sig_en=bcaa8339280a0a185aecf768a3e53927 sig_cn_org=1d4bc5fe89ff2558f994b15ff95305d5 source=17.5 
  <para>
   Change the owner of a custom operator <literal>a @@ b</literal> for type <type>text</type>:
<programlisting>
ALTER OPERATOR @@ (text, text) OWNER TO joe;
</programlisting>
  </para>
________________________________________________________-->
  <para>
   更改自定义操作符 <literal>a @@ b</literal> 在类型 <type>text</type> 上的所有者：
<programlisting>
ALTER OPERATOR @@ (text, text) OWNER TO joe;
</programlisting>
  </para>
<!-- pgdoc-cn_end sig_en=bcaa8339280a0a185aecf768a3e53927 -->

<!-- pgdoc-cn_start sig_en=429ccaca6d1bec37c0cdb65c991165ae sig_cn_org=4ef9bba2cb6a9a192123882649bf27dc source=17.5 
  <para>
   Change the restriction and join selectivity estimator functions of a
   custom operator <literal>a &amp;&amp; b</literal> for
   type <type>int[]</type>:
<programlisting>
ALTER OPERATOR &amp;&amp; (int[], int[]) SET (RESTRICT = _int_contsel, JOIN = _int_contjoinsel);
</programlisting>
  </para>
________________________________________________________-->
  <para>
   更改自定义运算符 <literal>a &amp;&amp; b</literal> 的限制和连接选择性估算函数，
   该运算符适用于类型 <type>int[]</type>：
<programlisting>
ALTER OPERATOR &amp;&amp; (int[], int[]) SET (RESTRICT = _int_contsel, JOIN = _int_contjoinsel);
</programlisting>
  </para>
<!-- pgdoc-cn_end sig_en=429ccaca6d1bec37c0cdb65c991165ae -->

<!-- pgdoc-cn_start sig_en=5978e4b065c23a2ed3e535f06eb3f44c sig_cn_org=ed97564fb5fe3b5961594df793d5ca26 source=17.5 
  <para>
   Mark the <literal>&amp;&amp;</literal> operator as being its own
   commutator:
<programlisting>
ALTER OPERATOR &amp;&amp; (int[], int[]) SET (COMMUTATOR = &amp;&amp;);
</programlisting>
  </para>
________________________________________________________-->
  <para>
   标记<literal>&amp;&amp;</literal>运算符为其自身的交换子：
<programlisting>
ALTER OPERATOR &amp;&amp; (int[], int[]) SET (COMMUTATOR = &amp;&amp;);
</programlisting>
  </para>
<!-- pgdoc-cn_end sig_en=5978e4b065c23a2ed3e535f06eb3f44c -->

 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=b38d493f3c2d2d5d9a7a49d257da9811 sig_cn_org=None source=14.1 
  <title>Compatibility</title>
________________________________________________________-->
  <title>兼容性</title>
<!-- pgdoc-cn_end sig_en=b38d493f3c2d2d5d9a7a49d257da9811 -->

<!-- pgdoc-cn_start sig_en=127f4ccd201bff42816bd2b7dfb825a0 sig_cn_org=None source=14.1 
  <para>
   There is no <command>ALTER OPERATOR</command> statement in
   the SQL standard.
  </para>
________________________________________________________-->
  <para>
   在 SQL 标准中没有<command>ALTER OPERATOR</command>语句。
  </para>
<!-- pgdoc-cn_end sig_en=127f4ccd201bff42816bd2b7dfb825a0 -->
 </refsect1>

