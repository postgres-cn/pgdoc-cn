<!-- pgdoc-cn_start sig_en=f075600dddcef7f5305316e778b44fc6 sig_cn_org=None source=14.1 
 <refnamediv>
  <refname>CREATE ROLE</refname>
  <refpurpose>define a new database role</refpurpose>
