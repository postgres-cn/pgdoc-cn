<!--
doc/src/sgml/ref/pg_combinebackup.sgml
PostgreSQL documentation
-->

<refentry id="app-pgcombinebackup">
<!-- pgdoc-cn_start sig_en=8c89575f4754353a26a4731c4c725ee6 sig_cn_org=8c89575f4754353a26a4731c4c725ee6 source=17.5 
 <indexterm zone="app-pgcombinebackup">
  <primary>pg_combinebackup</primary>
 </indexterm>
________________________________________________________-->
 <indexterm zone="app-pgcombinebackup">
  <primary>pg_combinebackup</primary>
 </indexterm>
<!-- pgdoc-cn_end sig_en=8c89575f4754353a26a4731c4c725ee6 -->

 <refmeta>
  <refentrytitle><application>pg_combinebackup</application></refentrytitle>
  <manvolnum>1</manvolnum>
  <refmiscinfo>Application</refmiscinfo>
 </refmeta>

<!-- pgdoc-cn_start sig_en=a0466827d42e0368f2948c7cc969e83a sig_cn_org=b81238934cb0fb865a388efad51d66e2 source=17.5 
 <refnamediv>
  <refname>pg_combinebackup</refname>
  <refpurpose>reconstruct a full backup from an incremental backup and dependent backups</refpurpose>
 </refnamediv>
________________________________________________________-->
 <refnamediv>
  <refname>pg_combinebackup</refname>
  <refpurpose>从增量备份和依赖备份重建完整备份</refpurpose>
 </refnamediv>
<!-- pgdoc-cn_end sig_en=a0466827d42e0368f2948c7cc969e83a -->

 <refsynopsisdiv>
  <cmdsynopsis>
   <command>pg_combinebackup</command>
   <arg rep="repeat"><replaceable>option</replaceable></arg>
   <arg rep="repeat"><replaceable>backup_directory</replaceable></arg>
  </cmdsynopsis>
 </refsynopsisdiv>

 <refsect1>
<!-- pgdoc-cn_start sig_en=59d6e86f3a60db4f1e08d0d6e639924e sig_cn_org=None source=14.1 
  <title>Description</title>
________________________________________________________-->
  <title>描述</title>
<!-- pgdoc-cn_end sig_en=59d6e86f3a60db4f1e08d0d6e639924e -->
<!-- pgdoc-cn_start sig_en=c92caba81935a9afdffe8684eef8eee7 sig_cn_org=71c01144ee1142f070a92d7b456fc48a source=17.5 
  <para>
   <application>pg_combinebackup</application> is used to reconstruct a
   synthetic full backup from an
   <link linkend="backup-incremental-backup">incremental backup</link> and the
   earlier backups upon which it depends.
  </para>
________________________________________________________-->
  <para>
   <application>pg_combinebackup</application> 用于从
   <link linkend="backup-incremental-backup">增量备份</link>及其依赖的早期备份中重建一个合成的完整备份。
  </para>
<!-- pgdoc-cn_end sig_en=c92caba81935a9afdffe8684eef8eee7 -->

<!-- pgdoc-cn_start sig_en=fa10084c63375f1ae952d5f5b17cca02 sig_cn_org=ec504ec890ab02f7cda99bebcb785688 source=17.5 
  <para>
   Specify all of the required backups on the command line from oldest to newest.
   That is, the first backup directory should be the path to the full backup, and
   the last should be the path to the final incremental backup
   that you wish to restore. The reconstructed backup will be written to the
   output directory specified by the <option>-o</option> option.
  </para>
________________________________________________________-->
  <para>
   指定命令行上所有必需的备份，顺序从最旧到最新。也就是说，第一个备份目录应是完整备份的路径，
   最后一个应是您希望恢复的最终增量备份的路径。重建的备份将写入由
   <option>-o</option> 选项指定的输出目录。
  </para>
<!-- pgdoc-cn_end sig_en=fa10084c63375f1ae952d5f5b17cca02 -->

<!-- pgdoc-cn_start sig_en=00f90e97c91b4ae3a62babd688f339bb sig_cn_org=89f4f5c39fdc4ed122306b3f2ac036e2 source=17.5 
  <para>
   <application>pg_combinebackup</application> will attempt to verify
   that the backups you specify form a legal backup chain from which a correct
   full backup can be reconstructed. However, it is not designed to help you
   keep track of which backups depend on which other backups. If you remove
   one or more of the previous backups upon which your incremental
   backup relies, you will not be able to restore it. Moreover,
   <application>pg_combinebackup</application> only attempts to verify that the
   backups have the correct relationship to each other, not that each
   individual backup is intact; for that, use
   <xref linkend="app-pgverifybackup" />.
  </para>
________________________________________________________-->
  <para>
   <application>pg_combinebackup</application> 将尝试验证您指定的备份是否构成一个合法的备份链，
   从中可以重建正确的完整备份。然而，它并不用于帮助您跟踪哪些备份依赖于其他备份。
   如果您删除了增量备份所依赖的一个或多个先前备份，您将无法恢复该增量备份。此外，
   <application>pg_combinebackup</application> 仅尝试验证备份之间的关系是否正确，而不保证每个
   单独备份的完整性；如需此功能，请使用
   <xref linkend="app-pgverifybackup" />。
  </para>
<!-- pgdoc-cn_end sig_en=00f90e97c91b4ae3a62babd688f339bb -->

<!-- pgdoc-cn_start sig_en=d0e817af82402b4818237df8a76539c8 sig_cn_org=4c59329bb16cd56f1012e472ba5fb3f7 source=17.5 
  <para>
   Since the output of <application>pg_combinebackup</application> is a
   synthetic full backup, it can be used as an input to a future invocation of
   <application>pg_combinebackup</application>. The synthetic full backup would
   be specified on the command line in lieu of the chain of backups from which
   it was reconstructed.
  </para>
________________________________________________________-->
  <para>
   由于<application>pg_combinebackup</application>的输出是一个合成的完整备份，
   它可以作为未来调用<application>pg_combinebackup</application>的输入。
   合成的完整备份将在命令行中指定，代替用于重建它的备份链。
  </para>
<!-- pgdoc-cn_end sig_en=d0e817af82402b4818237df8a76539c8 -->
 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=ee3f399228d18d2103d5b7f4e0aeeba8 sig_cn_org=None source=14.1 
  <title>Options</title>
________________________________________________________-->
  <title>选项</title>
<!-- pgdoc-cn_end sig_en=ee3f399228d18d2103d5b7f4e0aeeba8 -->

   <para>
    <variablelist>
     <varlistentry>
      <term><option>-d</option></term>
      <term><option>--debug</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=eb6e2bf430ad40fd62e4604eb7b39f73 sig_cn_org=913803d22b83c0c2dfe9a4f11517410c source=17.5 
       <para>
        Print lots of debug logging output on <filename>stderr</filename>.
       </para>
________________________________________________________-->
       <para>
        在<filename>stderr</filename>上打印大量调试日志输出。
       </para>
<!-- pgdoc-cn_end sig_en=eb6e2bf430ad40fd62e4604eb7b39f73 -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>-n</option></term>
      <term><option>--dry-run</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=de673bea0880f9d80d580b14e785f70a sig_cn_org=dd5acd0ce1a88f61d9f9270621d5b819 source=17.5 
       <para>
        The <option>-n</option>/<option>-&minus;dry-run</option> option instructs
        <command>pg_combinebackup</command> to figure out what would be done
        without actually creating the target directory or any output files.
        It is particularly useful in combination with <option>-&minus;debug</option>.
       </para>
________________________________________________________-->
       <para>
        <option>-n</option>/<option>--dry-run</option> 选项指示
        <command>pg_combinebackup</command> 计算将会执行的操作，
        但实际上不会创建目标目录或任何输出文件。
        该选项在与 <option>--debug</option> 结合使用时特别有用。
       </para>
<!-- pgdoc-cn_end sig_en=de673bea0880f9d80d580b14e785f70a -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>-N</option></term>
      <term><option>--no-sync</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=98ee34a974ba2d096fc22e641474c4e1 sig_cn_org=7603d750bfdea71da776f45e1f9c08b7 source=17.5 
       <para>
        By default, <command>pg_combinebackup</command> will wait for all files
        to be written safely to disk.  This option causes
        <command>pg_combinebackup</command> to return without waiting, which is
        faster, but means that a subsequent operating system crash can leave
        the output backup corrupt.  Generally, this option is useful for testing
        but should not be used when creating a production installation.
       </para>
________________________________________________________-->
       <para>
        默认情况下，<command>pg_combinebackup</command> 会等待所有文件安全写入磁盘。
        该选项使得 <command>pg_combinebackup</command> 在不等待的情况下返回，速度更快，
        但这意味着后续的操作系统崩溃可能导致输出备份损坏。通常，该选项适用于测试，
        但在创建生产环境时不应使用。
       </para>
<!-- pgdoc-cn_end sig_en=98ee34a974ba2d096fc22e641474c4e1 -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>-o <replaceable class="parameter">outputdir</replaceable></option></term>
      <term><option>--output=<replaceable class="parameter">outputdir</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=7afe5c6e88c27095aaa9d0f436f47f1b sig_cn_org=f2b1581c0d893d7d8fcffe793ba9e0a2 source=17.5 
       <para>
        Specifies the output directory to which the synthetic full backup
        should be written. Currently, this argument is required.
       </para>
________________________________________________________-->
       <para>
        指定应写入合成完整备份的输出目录。目前，此参数是必需的。
       </para>
<!-- pgdoc-cn_end sig_en=7afe5c6e88c27095aaa9d0f436f47f1b -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>-T <replaceable class="parameter">olddir</replaceable>=<replaceable class="parameter">newdir</replaceable></option></term>
      <term><option>--tablespace-mapping=<replaceable class="parameter">olddir</replaceable>=<replaceable class="parameter">newdir</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=461615eeb9722773aca18a352d161c38 sig_cn_org=c990ead26558960fadd2d8b258976fd9 source=17.5 
       <para>
        Relocates the tablespace in directory <replaceable>olddir</replaceable>
        to <replaceable>newdir</replaceable> during the backup.
        <replaceable>olddir</replaceable> is the absolute path of the tablespace
        as it exists in the final backup specified on the command line,
        and <replaceable>newdir</replaceable> is the absolute path to use for the
        tablespace in the reconstructed backup.  If either path needs to contain
        an equal sign (<literal>=</literal>), precede that with a backslash.
        This option can be specified multiple times for multiple tablespaces.
       </para>
________________________________________________________-->
       <para>
        在备份过程中，将表空间从目录 <replaceable>olddir</replaceable> 
        重新定位到 <replaceable>newdir</replaceable>。<replaceable>olddir</replaceable> 是
        命令行指定的最终备份中表空间的绝对路径，<replaceable>newdir</replaceable> 是
        用于重建备份中表空间的绝对路径。如果任一路径中需要包含等号
        (<literal>=</literal>)，请在其前加反斜杠。此选项可多次指定以处理多个表空间。
       </para>
<!-- pgdoc-cn_end sig_en=461615eeb9722773aca18a352d161c38 -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>--clone</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=eecd57f5b34a25905bf362f24d9934d1 sig_cn_org=14b6ca1459af3975d283e9b73cba27e8 source=17.5 
       <para>
        Use efficient file cloning (also known as <quote>reflinks</quote> on
        some systems) instead of copying files to the new data directory,
        which can result in near-instantaneous copying of the data files.
       </para>
________________________________________________________-->
       <para>
        使用高效的文件克隆（在某些系统上也称为<quote>reflinks</quote>）代替将文件复制到新的数据目录，
        这可以实现数据文件的几乎瞬时复制。
       </para>
<!-- pgdoc-cn_end sig_en=eecd57f5b34a25905bf362f24d9934d1 -->

<!-- pgdoc-cn_start sig_en=a072aff047ecf08b701e6ab3b18d4685 sig_cn_org=c8cc1384e31abd2b3ccb10ab73582362 source=17.5 
       <para>
        If a backup manifest is not available or does not contain checksum of
        the right type, file cloning will be used to copy the file, but the
        file will be also read block-by-block for the checksum calculation.
       </para>
________________________________________________________-->
       <para>
        如果备份清单不可用或不包含正确类型的校验和，将使用文件克隆来复制文件，
        但文件也会被逐块读取以计算校验和。
       </para>
<!-- pgdoc-cn_end sig_en=a072aff047ecf08b701e6ab3b18d4685 -->

<!-- pgdoc-cn_start sig_en=599c4053884669ea61abe3e680f2019b sig_cn_org=ef47b2d7040e1ab947462f4820ee3094 source=17.5 
       <para>
        File cloning is only supported on some operating systems and file
        systems.  If it is selected but not supported, the
        <application>pg_combinebackup</application> run will error.  At present,
        it is supported on Linux (kernel 4.5 or later) with Btrfs and XFS (on
        file systems created with reflink support), and on macOS with APFS.
       </para>
________________________________________________________-->
       <para>
        文件克隆仅在某些操作系统和文件系统上受支持。如果选择了该功能但不被支持，
        <application>pg_combinebackup</application> 运行时将报错。目前，它在 Linux（内核
        4.5 或更高版本）上支持 Btrfs 和 XFS（在支持 reflink 的文件系统上创建），以及
        macOS 上的 APFS。
       </para>
<!-- pgdoc-cn_end sig_en=599c4053884669ea61abe3e680f2019b -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>--copy</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=22fc41b6465f1c9db56b477367ccfc2b sig_cn_org=655eb992caaf3a98ee9627acc21dbd0a source=17.5 
       <para>
        Perform regular file copy.  This is the default.  (See also
        <option>-&minus;copy-file-range</option> and <option>-&minus;clone</option>.)
       </para>
________________________________________________________-->
       <para>
        执行常规文件复制。这是默认操作。（另请参见
        <option>--copy-file-range</option> 和 <option>--clone</option>。）
       </para>
<!-- pgdoc-cn_end sig_en=22fc41b6465f1c9db56b477367ccfc2b -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>--copy-file-range</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=c982660546a392b221b262669c0966b0 sig_cn_org=cc6fa9a29d51f6e9a1a1744b40d9223f source=17.5 
       <para>
        Use the <function>copy_file_range</function> system call for efficient
        copying.  On some file systems this gives results similar to
        <option>-&minus;clone</option>, sharing physical disk blocks, while on others
        it may still copy blocks, but do so via an optimized path.  At present,
        it is supported on Linux and FreeBSD.
       </para>
________________________________________________________-->
       <para>
        使用<function>copy_file_range</function>系统调用进行高效复制。在某些文件系统上，
        这会产生类似于<option>--clone</option>的效果，共享物理磁盘块，而在其他文件系统上，
        它可能仍然复制块，但通过优化路径完成。目前，该功能在Linux和FreeBSD上得到支持。
       </para>
<!-- pgdoc-cn_end sig_en=c982660546a392b221b262669c0966b0 -->

<!-- pgdoc-cn_start sig_en=cdf358b3e1049e4db88ab7e8e1464b77 sig_cn_org=64993ff379d2ac3a613fb0ae61208a65 source=17.5 
       <para>
        If a backup manifest is not available or does not contain checksum of
        the right type, <function>copy_file_range</function> will be used to
        copy the file, but the file will be also read block-by-block for the
        checksum calculation.
       </para>
________________________________________________________-->
       <para>
        如果备份清单不可用或不包含正确类型的校验和，<function>copy_file_range</function>将被用来
        复制文件，但文件也会被逐块读取以计算校验和。
       </para>
<!-- pgdoc-cn_end sig_en=cdf358b3e1049e4db88ab7e8e1464b77 -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>--manifest-checksums=<replaceable class="parameter">algorithm</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=360f1a2910d9e7fb219e093ba77e8467 sig_cn_org=c5010a8b35406c1bddd1ea8044d6e420 source=17.5 
       <para>
        Like <xref linkend="app-pgbasebackup"/>,
        <application>pg_combinebackup</application> writes a backup manifest
        in the output directory. This option specifies the checksum algorithm
        that should be applied to each file included in the backup manifest.
        Currently, the available algorithms are <literal>NONE</literal>,
        <literal>CRC32C</literal>, <literal>SHA224</literal>,
        <literal>SHA256</literal>, <literal>SHA384</literal>,
        and <literal>SHA512</literal>.  The default is <literal>CRC32C</literal>.
       </para>
________________________________________________________-->
       <para>
        像 <xref linkend="app-pgbasebackup"/> 一样，
        <application>pg_combinebackup</application> 会在输出目录中写入备份清单。
        此选项指定应应用于备份清单中每个文件的校验和算法。
        目前，可用的算法有 <literal>NONE</literal>、
        <literal>CRC32C</literal>、<literal>SHA224</literal>、
        <literal>SHA256</literal>、<literal>SHA384</literal> 和
        <literal>SHA512</literal>。默认值是 <literal>CRC32C</literal>。
       </para>
<!-- pgdoc-cn_end sig_en=360f1a2910d9e7fb219e093ba77e8467 -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>--no-manifest</option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=93066fe77c039358038025eda621f003 sig_cn_org=df539a2f6e9720e128481b670e17e49a source=17.5 
       <para>
        Disables generation of a backup manifest. If this option is not
        specified, a backup manifest for the reconstructed backup will be
        written to the output directory.
       </para>
________________________________________________________-->
       <para>
        禁用备份清单的生成。如果未指定此选项，将会在输出目录中写入
        重建备份的备份清单。
       </para>
<!-- pgdoc-cn_end sig_en=93066fe77c039358038025eda621f003 -->
      </listitem>
     </varlistentry>

     <varlistentry>
      <term><option>--sync-method=<replaceable class="parameter">method</replaceable></option></term>
      <listitem>
<!-- pgdoc-cn_start sig_en=9cabb204f71aa162cf1af20c8e21275a sig_cn_org=4aa54caa3e704ec7fa0c7fd381d1c978 source=17.5 
       <para>
        When set to <literal>fsync</literal>, which is the default,
        <command>pg_combinebackup</command> will recursively open and synchronize
        all files in the backup directory.  When the plain format is used, the
        search for files will follow symbolic links for the WAL directory and
        each configured tablespace.
       </para>
________________________________________________________-->
       <para>
        当设置为<literal>fsync</literal>（默认值）时，<command>pg_combinebackup</command>将递归打开并同步
        备份目录中的所有文件。当使用纯格式时，文件搜索将遵循WAL目录和每个配置的表空间的符号链接。
       </para>
<!-- pgdoc-cn_end sig_en=9cabb204f71aa162cf1af20c8e21275a -->
<!-- pgdoc-cn_start sig_en=06abdaebbd495da9d768a6220e0dca30 sig_cn_org=09d25131de4d5f803c06a9b91ad7c10e source=17.5 
       <para>
        On Linux, <literal>syncfs</literal> may be used instead to ask the
        operating system to synchronize the whole file system that contains the
        backup directory.  When the plain format is used,
        <command>pg_combinebackup</command> will also synchronize the file systems
        that contain the WAL files and each tablespace.  See
        <xref linkend="guc-recovery-init-sync-method"/> for information about
        the caveats to be aware of when using <literal>syncfs</literal>.
       </para>
________________________________________________________-->
       <para>
        在 Linux 上，可以使用 <literal>syncfs</literal> 来请求操作系统同步包含备份目录的整个文件系统。
        当使用纯格式时，<command>pg_combinebackup</command> 还会同步包含 WAL 文件和每个表空间的文件系统。
        有关使用 <literal>syncfs</literal> 时需要注意的事项，请参见
        <xref linkend="guc-recovery-init-sync-method"/>。
       </para>
<!-- pgdoc-cn_end sig_en=06abdaebbd495da9d768a6220e0dca30 -->
<!-- pgdoc-cn_start sig_en=c8f83ad21c712d02d30350232983d842 sig_cn_org=f1b27cbdd0dec21274cfe639a7712bfa source=17.5 
       <para>
        This option has no effect when <option>-&minus;no-sync</option> is used.
       </para>
________________________________________________________-->
       <para>
        当使用<option>--no-sync</option>时，此选项无效。
       </para>
<!-- pgdoc-cn_end sig_en=c8f83ad21c712d02d30350232983d842 -->
      </listitem>
     </varlistentry>

     <varlistentry>
       <term><option>-V</option></term>
       <term><option>--version</option></term>
       <listitem>
<!-- pgdoc-cn_start sig_en=eb2abccd7cc11a77d24a4afb97c24620 sig_cn_org=1621892682d4c5a5ccd4b976c3d04c08 source=17.5 
       <para>
        Prints the <application>pg_combinebackup</application> version and
        exits.
       </para>
________________________________________________________-->
       <para>
        打印<application>pg_combinebackup</application>的版本并退出。
       </para>
<!-- pgdoc-cn_end sig_en=eb2abccd7cc11a77d24a4afb97c24620 -->
       </listitem>
     </varlistentry>

     <varlistentry>
       <term><option>-?</option></term>
       <term><option>--help</option></term>
       <listitem>
<!-- pgdoc-cn_start sig_en=943488e541d0f2b3b84df75d21101910 sig_cn_org=6818ea585d6c434b0b2187955c2c1763 source=17.5 
       <para>
        Shows help about <application>pg_combinebackup</application> command
        line arguments, and exits.
       </para>
________________________________________________________-->
       <para>
        显示关于 <application>pg_combinebackup</application> 命令行参数的帮助信息，并退出。
       </para>
<!-- pgdoc-cn_end sig_en=943488e541d0f2b3b84df75d21101910 -->
       </listitem>
     </varlistentry>

    </variablelist>
   </para>

 </refsect1>

 <refsect1 id="app-pgcombinebackup-limitations">
<!-- pgdoc-cn_start sig_en=6f5b22a932265c21e464df6dcbb347ec sig_cn_org=None source=14.1 
  <title>Limitations</title>
________________________________________________________-->
  <title>限制</title>
<!-- pgdoc-cn_end sig_en=6f5b22a932265c21e464df6dcbb347ec -->

<!-- pgdoc-cn_start sig_en=f4f277535fc8561a609abec77670e2e4 sig_cn_org=fc56e7e621d8dcf9dceea6662cc61af4 source=17.5 
  <para>
   <literal>pg_combinebackup</literal> does not recompute page checksums when
   writing the output directory. Therefore, if any of the backups used for
   reconstruction were taken with checksums disabled, but the final backup was
   taken with checksums enabled, the resulting directory may contain pages
   with invalid checksums.
  </para>
________________________________________________________-->
  <para>
   <literal>pg_combinebackup</literal> 在写入输出目录时不会重新计算页面校验和。
   因此，如果用于重建的任何备份是在禁用校验和的情况下进行的，但最终备份是在启用
   校验和的情况下进行的，则生成的目录可能包含校验和无效的页面。
  </para>
<!-- pgdoc-cn_end sig_en=f4f277535fc8561a609abec77670e2e4 -->

<!-- pgdoc-cn_start sig_en=40f1e956ed94363306f7dac83b78e0c0 sig_cn_org=9ab2634dc688fcb79cb5371f40f1d00e source=17.5 
  <para>
   To avoid this problem, taking a new full backup after changing the checksum
   state of the cluster using <xref linkend="app-pgchecksums "/> is
   recommended. Otherwise, you can disable and then optionally reenable
   checksums on the directory produced by <literal>pg_combinebackup</literal>
   in order to correct the problem.
  </para>
________________________________________________________-->
  <para>
   为避免此问题，建议在使用 <xref linkend="app-pgchecksums "/> 更改集群的校验和状态后，
   进行一次新的完整备份。否则，您可以禁用然后（可选地）重新启用由
   <literal>pg_combinebackup</literal> 生成的目录上的校验和，以纠正该问题。
  </para>
<!-- pgdoc-cn_end sig_en=40f1e956ed94363306f7dac83b78e0c0 -->
 </refsect1>

 <refsect1>
<!-- pgdoc-cn_start sig_en=3b1cdb4e9f7c411322dc1c76ca7f31f3 sig_cn_org=None source=14.1 
  <title>Environment</title>
________________________________________________________-->
  <title>环境</title>
<!-- pgdoc-cn_end sig_en=3b1cdb4e9f7c411322dc1c76ca7f31f3 -->

<!-- pgdoc-cn_start sig_en=df87a49e7afda6b9e5b4e0213a1ba7c3 sig_cn_org=None source=14.1 
  <para>
   This utility, like most other <productname>PostgreSQL</productname> utilities,
   uses the environment variables supported by <application>libpq</application>
   (see <xref linkend="libpq-envars"/>).
  </para>
________________________________________________________-->
  <para>
   此实用程序与大多数其他 <productname>PostgreSQL</productname> 实用程序一样，使用 <application>libpq</application> 支持的环境变量（见 <xref linkend="libpq-envars"/>）。
  </para>
<!-- pgdoc-cn_end sig_en=df87a49e7afda6b9e5b4e0213a1ba7c3 -->

<!-- pgdoc-cn_start sig_en=72e83e1224b576d8f1aff7fc7c381f83 sig_cn_org=None source=14.1 
  <para>
   The environment variable <envar>PG_COLOR</envar> specifies whether to use
   color in diagnostic messages. Possible values are
   <literal>always</literal>, <literal>auto</literal> and
   <literal>never</literal>.
  </para>
________________________________________________________-->
  <para>
   环境变量 <envar>PG_COLOR</envar> 指定是否在诊断消息中使用颜色。可能的值是 <literal>always</literal>、<literal>auto</literal> 和
   <literal>never</literal>。
   </para>
<!-- pgdoc-cn_end sig_en=72e83e1224b576d8f1aff7fc7c381f83 -->
 </refsect1>

 <refsect1>
