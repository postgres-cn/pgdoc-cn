<!--
Author: Nathan Bossart <nathan@postgresql.org>
2024-01-19 [8b2bcf3f2] Introduce the dynamic shared memory registry.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=8912ce5f4c8918ac44ad5678b8bc866c sig_cn_org=3faa04aba05f41a4fe2d4ea532cd8fa4 source=17.5 
      <para>
      Add dynamic shared memory registry (Nathan Bossart)
      <ulink url="&commit_baseurl;8b2bcf3f2">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加动态共享内存注册表（Nathan Bossart）
      <ulink url="&commit_baseurl;8b2bcf3f2">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=8912ce5f4c8918ac44ad5678b8bc866c -->

<!-- pgdoc-cn_start sig_en=1d761b2e98cf80cfbc27d800b3116959 sig_cn_org=584427ff20ebba3db883e42799994611 source=17.5 
      <para>
       This allows shared libraries which are not initialized at startup
       to coordinate dynamic shared memory access.
      </para>
________________________________________________________-->
      <para>
       这允许未在启动时初始化的共享库协调动态共享内存访问。
      </para>
<!-- pgdoc-cn_end sig_en=1d761b2e98cf80cfbc27d800b3116959 -->
     </listitem>

