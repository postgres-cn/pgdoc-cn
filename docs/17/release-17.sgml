<!-- pgdoc-cn_start sig_en=5811a12e1e1a4c1e5d994358a8c49ad2 sig_cn_org=e4dcbb45838af7f0614871f6aa05d120 source=17.5 
      <para>
      Allow the use of an <link
      linkend="datatype-enum"><type>ENUM</type></link> added via <link
      linkend="sql-altertype"><command>ALTER TYPE</command></link> if
      the type was created in the same transaction (Tom Lane)
      <ulink url="&commit_baseurl;af1d39584">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      允许使用通过<link
      linkend="sql-altertype"><command>ALTER TYPE</command></link>添加的<link
      linkend="datatype-enum"><type>ENUM</type></link>类型，如果该类型是在同一事务中创建的（Tom Lane）
      <ulink url="&commit_baseurl;af1d39584">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=5811a12e1e1a4c1e5d994358a8c49ad2 -->

<!-- pgdoc-cn_start sig_en=d4ec7e83c5deb8addec1e2ff05a344af sig_cn_org=c1bc90ea79a4c81425934e172639a060 source=17.5 
      <para>
      This was previously disallowed.
      </para>
________________________________________________________-->
      <para>
      这以前是不允许的。
      </para>
<!-- pgdoc-cn_end sig_en=d4ec7e83c5deb8addec1e2ff05a344af -->
     </listitem>

    </itemizedlist>

   </sect3>

