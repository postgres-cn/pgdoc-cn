<!--
Author: Peter Eisentraut <peter@eisentraut.org>
2023-07-12 [8c852ba9a] Allow some exclusion constraints on partitions
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=dfde8eef342af932f63520f7d484fc7f sig_cn_org=7eb36902ce60bb4f424d901c4e21ffc3 source=17.5 
      <para>
      Allow <link linkend="ddl-constraints-exclusion">exclusion
      constraints</link> on partitioned tables (Paul A. Jungwirth)
      <ulink url="&commit_baseurl;8c852ba9a">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      允许在分区表上使用<link linkend="ddl-constraints-exclusion">排除约束</link>（Paul A. Jungwirth）
      <ulink url="&commit_baseurl;8c852ba9a">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=dfde8eef342af932f63520f7d484fc7f -->

<!-- pgdoc-cn_start sig_en=aec1adf04acf709f8c906ddf99929d2d sig_cn_org=1e50bee62ab44b53698aaa61d65353d5 source=17.5 
      <para>
      As long as exclusion constraints compare partition key columns
      for equality, other columns can use exclusion constraint-specific
      comparisons.
      </para>
________________________________________________________-->
      <para>
      只要排除约束比较分区键列的相等性，其他列可以使用排除约束特定的比较。
      </para>
<!-- pgdoc-cn_end sig_en=aec1adf04acf709f8c906ddf99929d2d -->
     </listitem>

<!--
Author: Peter Eisentraut <peter@eisentraut.org>
2024-01-13 [4f622503d] Make attstattarget nullable
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=f167e43adc3a8f4470a127541d56c9b3 sig_cn_org=3a31c35ae4ea548fbaf3ad81b603d0a2 source=17.5 
      <para>
      Add clearer <link linkend="sql-altertable"><command>ALTER
      TABLE</command></link> method to set a column to the default
      statistics target (Peter Eisentraut)
      <ulink url="&commit_baseurl;4f622503d">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加更清晰的<link linkend="sql-altertable"><command>ALTER
      TABLE</command></link> 方法，用于将列设置为默认的统计目标（Peter Eisentraut）
      <ulink url="&commit_baseurl;4f622503d">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=f167e43adc3a8f4470a127541d56c9b3 -->

<!-- pgdoc-cn_start sig_en=d86d671968b1bb9028c6f586e48624b3 sig_cn_org=47b2842a22a9526caafb674b2b33ed51 source=17.5 
      <para>
      The new syntax is <literal>ALTER TABLE ... SET STATISTICS
      DEFAULT</literal>; using <literal>SET STATISTICS -1</literal>
      is still supported.
      </para>
________________________________________________________-->
      <para>
      新语法是 <literal>ALTER TABLE ... SET STATISTICS
      DEFAULT</literal>；仍然支持使用 <literal>SET STATISTICS -1</literal>。
      </para>
<!-- pgdoc-cn_end sig_en=d86d671968b1bb9028c6f586e48624b3 -->
