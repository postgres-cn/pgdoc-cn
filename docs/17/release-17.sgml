     <itemizedlist>

<!--
Author: Robert Haas <rhaas@postgresql.org>
2024-01-11 [ee1bfd168] Add new pg_walsummary tool.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=c914634427126c3932bf0d014e33c946 sig_cn_org=ec148fe8e65cdee116b0be43499a6656 source=17.5 
      <para>
      Add application <link
      linkend="app-pgwalsummary"><application>pg_walsummary</application></link>
      to dump <acronym>WAL</acronym> summary files (Robert Haas)
      <ulink url="&commit_baseurl;ee1bfd168">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加应用程序 <link
      linkend="app-pgwalsummary"><application>pg_walsummary</application></link>
      用于转储 <acronym>WAL</acronym> 汇总文件（Robert Haas）
      <ulink url="&commit_baseurl;ee1bfd168">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=c914634427126c3932bf0d014e33c946 -->
     </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2024-04-01 [a45c78e32] Rearrange pg_dump's handling of large objects for better
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=b9c5b2b134748c674614abdcea9760fe sig_cn_org=2940732251ec9692ae08d2336bbb4238 source=17.5 
      <para>
      Allow <link
      linkend="app-pgdump"><application>pg_dump</application></link>'s
      large objects to be restorable in batches (Tom Lane)
      <ulink url="&commit_baseurl;a45c78e32">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      允许<link
      linkend="app-pgdump"><application>pg_dump</application></link>的大对象可以分批恢复（Tom Lane）
      <ulink url="&commit_baseurl;a45c78e32">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=b9c5b2b134748c674614abdcea9760fe -->

<!-- pgdoc-cn_start sig_en=601f7d356d57a25ed68697b4124ae130 sig_cn_org=bf021c045cbb140e7725e3c0bc621f8f source=17.5 
      <para>
      This allows the restoration of many large objects to avoid
      transaction limits and to be restored in parallel.
      </para>
________________________________________________________-->
      <para>
      这允许恢复许多大型对象，以避免事务限制并实现并行恢复。
      </para>
<!-- pgdoc-cn_end sig_en=601f7d356d57a25ed68697b4124ae130 -->
     </listitem>

<!--
Author: Dean Rasheed <dean.a.rasheed@gmail.com>
2024-03-20 [522ed12f7] Add "- -exclude-extension" to pg_dump's options.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=14d090efc8be08e3142de4d8ab66bf8a sig_cn_org=ded70a00e3523e1b2d9207869041907b source=17.5 
      <para>
      Add <application>pg_dump</application> option
      <option>-&minus;exclude-extension</option> (Ayush Vatsa)
      <ulink url="&commit_baseurl;522ed12f7">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加 <application>pg_dump</application> 选项
      <option>--exclude-extension</option>（Ayush Vatsa）
      <ulink url="&commit_baseurl;522ed12f7">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=14d090efc8be08e3142de4d8ab66bf8a -->
     </listitem>

<!--
Author: Daniel Gustafsson <dgustafsson@postgresql.org>
2023-11-29 [a5cf808be] Read include/exclude commands for dump/restore from file
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=354ffe38f30d92ad6174a5efd331c68f sig_cn_org=12df16fcd7f4402f0826f0844e270c79 source=17.5 
      <para>
      Allow <link
      linkend="app-pgdump"><application>pg_dump</application></link>, <link
      linkend="app-pg-dumpall"><application>pg_dumpall</application></link>,
      and <link
      linkend="app-pgrestore"><application>pg_restore</application></link>
      to specify include/exclude objects in a file (Pavel Stehule,
      Daniel Gustafsson)
      <ulink url="&commit_baseurl;a5cf808be">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      允许<link
      linkend="app-pgdump"><application>pg_dump</application></link>、<link
      linkend="app-pg-dumpall"><application>pg_dumpall</application></link>和<link
      linkend="app-pgrestore"><application>pg_restore</application></link>在文件中指定包含/排除对象（Pavel Stehule，
      Daniel Gustafsson）
      <ulink url="&commit_baseurl;a5cf808be">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=354ffe38f30d92ad6174a5efd331c68f -->

<!-- pgdoc-cn_start sig_en=22d42b35ac7b0db9d1f50bdfef05133a sig_cn_org=0e79f3e6a807c2315e3ee6fbae4aca6d source=17.5 
      <para>
      The option is called <option>-&minus;filter</option>.
      </para>
________________________________________________________-->
      <para>
      该选项称为<option>--filter</option>。
      </para>
<!-- pgdoc-cn_end sig_en=22d42b35ac7b0db9d1f50bdfef05133a -->
     </listitem>

<!--
Author: Nathan Bossart <nathan@postgresql.org>
2023-09-06 [8c16ad3b4] Allow using syncfs() in frontend utilities.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=6b7dde9917702a1e4c5462a27edbbde8 sig_cn_org=f711da31c135ee0613f0114ac3a45667 source=17.5 
      <para>
      Add the <option>-&minus;sync-method</option> parameter to several client
      applications (Justin Pryzby, Nathan Bossart)
      <ulink url="&commit_baseurl;8c16ad3b4">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      在多个客户端应用程序中添加<option>--sync-method</option>参数（Justin Pryzby, Nathan Bossart）
      <ulink url="&commit_baseurl;8c16ad3b4">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=6b7dde9917702a1e4c5462a27edbbde8 -->

<!-- pgdoc-cn_start sig_en=d3f6a3fa34c8b364fd004730b8891ac5 sig_cn_org=489bc13ccb5c8f43d549f0afef73d2ec source=17.5 
      <para>
      The applications are <link
      linkend="app-initdb"><application>initdb</application></link>, <link
      linkend="app-pgbasebackup"><application>pg_basebackup</application></link>,
      <link
      linkend="app-pgchecksums"><application>pg_checksums</application></link>,
      <link linkend="app-pgdump"><application>pg_dump</application></link>,
      <link linkend="app-pgrewind"><application>pg_rewind</application></link>,
      and <link
      linkend="pgupgrade"><application>pg_upgrade</application></link>.
      </para>
________________________________________________________-->
      <para>
      这些应用程序包括<link
      linkend="app-initdb"><application>initdb</application></link>、<link
      linkend="app-pgbasebackup"><application>pg_basebackup</application></link>、
      <link
      linkend="app-pgchecksums"><application>pg_checksums</application></link>、
      <link linkend="app-pgdump"><application>pg_dump</application></link>、
      <link linkend="app-pgrewind"><application>pg_rewind</application></link>，
      以及<link
      linkend="pgupgrade"><application>pg_upgrade</application></link>。
      </para>
<!-- pgdoc-cn_end sig_en=d3f6a3fa34c8b364fd004730b8891ac5 -->
     </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2024-04-01 [959b38d77] Invent - -transaction-size option for pg_restore.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=e116af5860850c65dc471033b59f158b sig_cn_org=c3160cc06e69693cbe6457d114591c2b source=17.5 
      <para>
      Add <link
      linkend="app-pgrestore"><application>pg_restore</application></link>
      option <option>-&minus;transaction-size</option> to allow object restores
      in transaction batches (Tom Lane)
      <ulink url="&commit_baseurl;959b38d77">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      添加 <link
      linkend="app-pgrestore"><application>pg_restore</application></link>
      选项 <option>--transaction-size</option>，以允许在事务批处理中恢复对象（Tom Lane）
      <ulink url="&commit_baseurl;959b38d77">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=e116af5860850c65dc471033b59f158b -->

<!-- pgdoc-cn_start sig_en=58301537eb9d2c89d7bb0b6364be2edf sig_cn_org=d19273c47a0ced5df562578becfef6e7 source=17.5 
      <para>
      This allows the performance benefits of transaction batches without
      the problems of excessively large transaction blocks.
      </para>
________________________________________________________-->
      <para>
      这允许在不产生过大事务块问题的情况下，获得事务批处理的性能优势。
      </para>
<!-- pgdoc-cn_end sig_en=58301537eb9d2c89d7bb0b6364be2edf -->
     </listitem>

<!--
Author: Nathan Bossart <nathan@postgresql.org>
2024-03-25 [3ff01b2b6] Adjust pgbench option for debug mode.
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=3b216122da55dca9a1d9bf743b611ff1 sig_cn_org=558f0d94ae6382a536fe945e76027385 source=17.5 
      <para>
      Change <link
      linkend="pgbench"><application>pgbench</application></link> debug
      mode option from <option>-d</option> to <option>-&minus;debug</option>
      (Greg Sabino Mullane)
      <ulink url="&commit_baseurl;3ff01b2b6">&sect;</ulink>
      </para>
________________________________________________________-->
      <para>
      将 <link
      linkend="pgbench"><application>pgbench</application></link> 的调试模式选项从 <option>-d</option> 改为
      <option>--debug</option>（Greg Sabino Mullane）
      <ulink url="&commit_baseurl;3ff01b2b6">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=3b216122da55dca9a1d9bf743b611ff1 -->

<!-- pgdoc-cn_start sig_en=a2a79dda4906afe0cdd870170b0da02c sig_cn_org=7b43c00c1fc9b92f77d2d4a61d9682c6 source=17.5 
      <para>
      Option <option>-d</option> is now used for the database name,
      and the new <option>-&minus;dbname</option> option can be used as well.
      </para>
________________________________________________________-->
      <para>
      选项 <option>-d</option> 现在用于数据库名称，新的 <option>--dbname</option> 选项也可以使用。
