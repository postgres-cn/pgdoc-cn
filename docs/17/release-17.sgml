<!-- pgdoc-cn_start sig_en=f9ab2ff6ad6e95dbe075733afcb34049 sig_cn_org=d902ba7998fe446896f15f2720f27c15 source=16.8 
     <para>
      Add support for the legacy library
      names <filename>ssleay32</filename>
      and <filename>libeay32</filename>.
     </para>
________________________________________________________-->
     <para>
      添加对旧版库名称<filename>ssleay32</filename>和<filename>libeay32</filename>的支持。
     </para>
