      <ulink url="&commit_baseurl;f6d4c9cf1">&sect;</ulink>
      </para>
<!-- pgdoc-cn_end sig_en=27a71bfbbf0e93c1fa62115ca8780c08 -->
     </listitem>

<!--
Author: Peter Eisentraut <peter@eisentraut.org>
2024-01-16 [699586315] Support identity columns in partitioned tables
-->

     <listitem>
<!-- pgdoc-cn_start sig_en=3af64995535f189f7c56122db5e80213 sig_cn_org=33d2b04f8373463f77f661f7c7c899ae source=17.5 
