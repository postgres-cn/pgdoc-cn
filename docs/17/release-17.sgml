<!-- doc/src/sgml/release-17.sgml -->
<!-- See header comment in release.sgml about typical markup -->

 <sect1 id="release-17-5">
<!-- pgdoc-cn_start sig_en=a7b6374cbe3e0deae1edb754e25dffec sig_cn_org=6270daee86fa0dc0809f8b6ebac6189e source=17.5 
  <title>Release 17.5</title>
________________________________________________________-->
  <title>版本 17.5</title>
<!-- pgdoc-cn_end sig_en=a7b6374cbe3e0deae1edb754e25dffec -->

  <formalpara>
<!-- pgdoc-cn_start sig_en=c45e8127eac45f2347bf1713afaeffda sig_cn_org=253305b4c6dff5b87ef36e3c2d95e52e source=15.7 
  <title>Release date:</title>
________________________________________________________-->
  <title>发布日期：</title>
<!-- pgdoc-cn_end sig_en=c45e8127eac45f2347bf1713afaeffda -->
<!-- pgdoc-cn_start sig_en=668d5ac1191e9e1bfffa920016722d8a sig_cn_org=668d5ac1191e9e1bfffa920016722d8a source=17.5 
  <para>2025-05-08</para>
________________________________________________________-->
  <para>2025-05-08</para>
<!-- pgdoc-cn_end sig_en=668d5ac1191e9e1bfffa920016722d8a -->
  </formalpara>

<!-- pgdoc-cn_start sig_en=18963901ea67126d8189c451998be9dd sig_cn_org=03c22bee5f6362c969235e119be8166c source=17.5 
  <para>
   This release contains a variety of fixes from 17.4.
   For information about new features in major release 17, see
   <xref linkend="release-17"/>.
  </para>
________________________________________________________-->
  <para>
   本版本包含了来自17.4的各种修复。
   有关17大版本中新功能的信息，请参见
   <xref linkend="release-17"/>.
  </para>
<!-- pgdoc-cn_end sig_en=18963901ea67126d8189c451998be9dd -->

  <sect2 id="release-17-5-migration">
<!-- pgdoc-cn_start sig_en=33444abee408ab34fccd743b7c1341c1 sig_cn_org=226404296a479e2a1633e093e5a54747 source=17.5 
   <title>Migration to Version 17.5</title>
________________________________________________________-->
   <title>迁移到版本 17.5</title>
<!-- pgdoc-cn_end sig_en=33444abee408ab34fccd743b7c1341c1 -->

<!-- pgdoc-cn_start sig_en=e5363a119f0af3092f384dea35785515 sig_cn_org=012eec4b41a96b7ba9e089d7d12eee97 source=17.5 
   <para>
    A dump/restore is not required for those running 17.X.
   </para>
________________________________________________________-->
   <para>
    对于运行17.X的用户，不需要进行转储/恢复操作。
   </para>
<!-- pgdoc-cn_end sig_en=e5363a119f0af3092f384dea35785515 -->

<!-- pgdoc-cn_start sig_en=8583e790720a33fb5b2bf6aa7add6371 sig_cn_org=4ecbf235119546f237a7d059cdd9c7cc source=17.5 
   <para>
    However, if you have any self-referential foreign key constraints on
    partitioned tables, it may be necessary to recreate those constraints
    to ensure that they are being enforced correctly.  See the second
    changelog entry below.
   </para>
________________________________________________________-->
   <para>
    但是，如果您在分区表上有任何自引用的外键约束，可能需要重新创建这些约束，
    以确保它们被正确执行。请参见下面的第二个变更日志条目。
   </para>
<!-- pgdoc-cn_end sig_en=8583e790720a33fb5b2bf6aa7add6371 -->

<!-- pgdoc-cn_start sig_en=1192db58f207cb0f8870d173d9bd7b95 sig_cn_org=392d0e2b324944971c5810df6a34eca2 source=17.5 
   <para>
    Also, if you have any BRIN bloom indexes, it may be advisable to
    reindex them after updating.  See the third changelog entry below.
   </para>
________________________________________________________-->
   <para>
    此外，如果您有任何 BRIN bloom 索引，更新后可能需要重新索引它们。
    请参阅下面的第三个变更日志条目。
   </para>
<!-- pgdoc-cn_end sig_en=1192db58f207cb0f8870d173d9bd7b95 -->

<!-- pgdoc-cn_start sig_en=5c9bea112e531bf7cdc566cc733c923b sig_cn_org=9000df42013f5d70356c5e2bf753fe32 source=17.5 
   <para>
    Also, if you are upgrading from a version earlier than 17.1,
    see <xref linkend="release-17-1"/>.
   </para>
________________________________________________________-->
   <para>
    此外，如果您正在从早于17.1的版本升级，请参见<xref linkend="release-17-1"/>。
   </para>
<!-- pgdoc-cn_end sig_en=5c9bea112e531bf7cdc566cc733c923b -->
  </sect2>

  <sect2 id="release-17-5-changes">
<!-- pgdoc-cn_start sig_en=e161fef38e54e54458e215e5f978ef9b sig_cn_org=f104d50dd9d4dd802f94229ebe5bc097 source=15.7 
   <title>Changes</title>
________________________________________________________-->
   <title>变更</title>
<!-- pgdoc-cn_end sig_en=e161fef38e54e54458e215e5f978ef9b -->

   <itemizedlist>

    <listitem>
<!--
Author: Noah Misch <noah@leadboat.com>
Branch: master [627acc3ca] 2025-05-05 04:52:04 -0700
Branch: REL_17_STABLE [ec5f89e8a] 2025-05-05 04:52:07 -0700
