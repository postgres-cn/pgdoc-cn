  <sect2 id="release-17-changes">
<!-- pgdoc-cn_start sig_en=e161fef38e54e54458e215e5f978ef9b sig_cn_org=f104d50dd9d4dd802f94229ebe5bc097 source=15.7 
   <title>Changes</title>
________________________________________________________-->
   <title>变更</title>
<!-- pgdoc-cn_end sig_en=e161fef38e54e54458e215e5f978ef9b -->

<!-- pgdoc-cn_start sig_en=f23b843c9c34c0c4242748048ac78b1f sig_cn_org=9111e4924e5fbce96e2edf5c09755fe9 source=17.5 
    <para>
     Below you will find a detailed account of the changes between
    <productname>PostgreSQL</productname> 17 and the previous major
    release.
    </para>
________________________________________________________-->
    <para>
     下面您将找到<productname>PostgreSQL</productname> 17与之前主要版本之间变更的详细说明。
    </para>
<!-- pgdoc-cn_end sig_en=f23b843c9c34c0c4242748048ac78b1f -->

   <sect3 id="release-17-server">
<!-- pgdoc-cn_start sig_en=9189294b7a121aae803ff469797ca246 sig_cn_org=d9be102ccf075d32052f6a1c47f345a9 source=15.7 
    <title>Server</title>
________________________________________________________-->
    <title>服务器</title>
<!-- pgdoc-cn_end sig_en=9189294b7a121aae803ff469797ca246 -->

    <sect4 id="release-17-optimizer">
<!-- pgdoc-cn_start sig_en=74b6eff57a1f8c0e207b184771081be9 sig_cn_org=9a948b44ad66c389427f923daffd016d source=15.7 
     <title>Optimizer</title>
________________________________________________________-->
     <title>优化器</title>
<!-- pgdoc-cn_end sig_en=74b6eff57a1f8c0e207b184771081be9 -->

     <itemizedlist>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-11-17 [f7816aec2] Extract column statistics from CTE references, if possib
Author: Tom Lane <tgl@sss.pgh.pa.us>
2024-03-26 [a65724dfa] Propagate pathkeys from CTEs up to the outer query.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=44eef46bac710435dd7fe5df8c24da88 sig_cn_org=e1074cf5ef047de87d06860909611e17 source=17.5 
       <para>
       Allow the optimizer to improve <acronym>CTE</acronym> plans by
       considering the statistics and sort order of columns referenced in earlier row
       output clauses (Jian Guo, Richard Guo, Tom Lane)
       <ulink url="&commit_baseurl;f7816aec2">&sect;</ulink>
       <ulink url="&commit_baseurl;a65724dfa">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       允许优化器通过考虑先前行输出子句中引用列的统计信息和排序顺序来改进
       <acronym>CTE</acronym>计划（Jian Guo，Richard Guo，Tom Lane）
       <ulink url="&commit_baseurl;f7816aec2">&sect;</ulink>
       <ulink url="&commit_baseurl;a65724dfa">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=44eef46bac710435dd7fe5df8c24da88 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2024-01-23 [b262ad440] Add better handling of redundant IS [NOT] NULL quals
Author: David Rowley <drowley@postgresql.org>
2024-04-12 [3af704098] Fix IS [NOT] NULL qual optimization for inheritance tabl
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=52d67a4759250f86fd1222100c8fd644 sig_cn_org=5dc1a9a7fcf181568a1572bd400ae84e source=17.5 
       <para>
       Improve optimization of <literal>IS NOT NULL</literal> and
       <literal>IS NULL</literal> query restrictions (David Rowley,
       Richard Guo, Andy Fan)
       <ulink url="&commit_baseurl;b262ad440">&sect;</ulink>
       <ulink url="&commit_baseurl;3af704098">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       改进对 <literal>IS NOT NULL</literal> 和
       <literal>IS NULL</literal> 查询限制的优化（David Rowley,
       Richard Guo, Andy Fan）
       <ulink url="&commit_baseurl;b262ad440">&sect;</ulink>
       <ulink url="&commit_baseurl;3af704098">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=52d67a4759250f86fd1222100c8fd644 -->

<!-- pgdoc-cn_start sig_en=3a2d6fdc4379489e6d079621c220d086 sig_cn_org=a12efd9fef08a4932ce49f9e2aa2cae4 source=17.5 
       <para>
       Remove <literal>IS NOT NULL</literal> restrictions from queries on
       <literal>NOT NULL</literal> columns and eliminate scans on
       <literal>NOT NULL</literal> columns if <literal>IS NULL</literal>
       is specified.
       </para>
________________________________________________________-->
       <para>
       从对<literal>NOT NULL</literal>列的查询中移除<literal>IS NOT NULL</literal>限制，
       并且如果指定了<literal>IS NULL</literal>，则消除对<literal>NOT NULL</literal>列的扫描。
       </para>
<!-- pgdoc-cn_end sig_en=3a2d6fdc4379489e6d079621c220d086 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2024-03-04 [07c36c133] Support partition pruning on boolcol IS [NOT] UNKNOWN
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=03fb17b3f5e71066814743e65d3aa6a1 sig_cn_org=38589421dcff3c41cc8fcd4449e6c5e1 source=17.5 
       <para>
       Allow partition pruning on boolean columns on <literal>IS [NOT]
       UNKNOWN</literal> conditionals (David Rowley)
       <ulink url="&commit_baseurl;07c36c133">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       允许在布尔列上对 <literal>IS [NOT] UNKNOWN</literal> 条件进行分区裁剪（David Rowley）
       <ulink url="&commit_baseurl;07c36c133">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=03fb17b3f5e71066814743e65d3aa6a1 -->
      </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2024-01-20 [075df6b20] Add planner support functions for range operators &lt;@ and
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=36ebb2f65a63d440ee34a0ea84f644ca sig_cn_org=ea84ae3574d5e7069a32626f68babae2 source=17.5 
       <para>
       Improve optimization of range values when using containment
       operators &lt;@ and @&gt; (Kim Johan Andersson, Jian He)
       <ulink url="&commit_baseurl;075df6b20">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       改进使用包含运算符&lt;@ 和 @&gt;时范围值的优化（Kim Johan Andersson, Jian He）
       <ulink url="&commit_baseurl;075df6b20">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=36ebb2f65a63d440ee34a0ea84f644ca -->
      </listitem>

<!--
Author: Alexander Korotkov <akorotkov@postgresql.org>
2024-02-15 [9f1337639] Pull up ANY-SUBLINK with the necessary lateral support.
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=6ee1c1293c5f3e508b9659c5784a54b2 sig_cn_org=884aeb995d18724c4a3d520f0f829766 source=17.5 
       <para>
       Allow correlated <literal>IN</literal> subqueries to be transformed
       into joins (Andy Fan, Tom Lane)
       <ulink url="&commit_baseurl;9f1337639">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       允许相关的<literal>IN</literal>子查询被转换成连接（Andy Fan，Tom Lane）
       <ulink url="&commit_baseurl;9f1337639">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=6ee1c1293c5f3e508b9659c5784a54b2 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2023-10-05 [a8a968a82] Consider cheap startup paths in add_paths_to_append_rel
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=ee978a6f35fa19e92ee87cffb782b959 sig_cn_org=ead5a6226b1b7c047f49e1e765affe40 source=17.5 
       <para>
       Improve optimization of the <literal>LIMIT</literal> clause
       on partitioned tables, inheritance parents, and <literal>UNION
       ALL</literal> queries (Andy Fan, David Rowley)
       <ulink url="&commit_baseurl;a8a968a82">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       改进对分区表、继承父表以及<literal>UNION ALL</literal>查询中
       <literal>LIMIT</literal>子句的优化（Andy Fan，David Rowley）
       <ulink url="&commit_baseurl;a8a968a82">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=ee978a6f35fa19e92ee87cffb782b959 -->
      </listitem>

<!--
Author: Tom Lane <tgl@sss.pgh.pa.us>
2023-07-14 [e08d74ca1] Allow plan nodes with initPlans to be considered paralle
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=f95ce97958908a414219a49e0b1d541a sig_cn_org=2864b4efb7b479ed7725caf11330e868 source=17.5 
       <para>
       Allow query nodes to be run in parallel in more cases (Tom Lane)
       <ulink url="&commit_baseurl;e08d74ca1">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       允许在更多情况下并行运行查询节点（Tom Lane）
       <ulink url="&commit_baseurl;e08d74ca1">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=f95ce97958908a414219a49e0b1d541a -->
      </listitem>

<!--
Author: Alexander Korotkov <akorotkov@postgresql.org>
2024-01-21 [0452b461b] Explore alternative orderings of group-by pathkeys durin
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=7047141378ee5f56e2cb57c20ea52d6e sig_cn_org=4bc318db90c64f0a0f4155b79830b103 source=17.5 
       <para>
       Allow <literal>GROUP BY</literal> columns to be internally
       ordered to match <literal>ORDER BY</literal> (Andrei Lepikhov,
       Teodor Sigaev)
       <ulink url="&commit_baseurl;0452b461b">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       允许<literal>GROUP BY</literal>列内部排序以匹配<literal>ORDER BY</literal>（Andrei Lepikhov，
       Teodor Sigaev）
       <ulink url="&commit_baseurl;0452b461b">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=7047141378ee5f56e2cb57c20ea52d6e -->

<!-- pgdoc-cn_start sig_en=6030e958afbd2d60e73ac2e5acecf797 sig_cn_org=04e378faf02d4671961fb595ab781284 source=17.5 
       <para>
       This can be disabled using server variable
       <xref linkend="guc-enable-groupby-reordering"/>.
       </para>
________________________________________________________-->
       <para>
       这可以通过服务器变量
       <xref linkend="guc-enable-groupby-reordering"/>来禁用。
       </para>
<!-- pgdoc-cn_end sig_en=6030e958afbd2d60e73ac2e5acecf797 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2024-03-25 [66c0185a3] Allow planner to use Merge Append to efficiently impleme
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=575a18de854c4268971c806929a2cf82 sig_cn_org=ffb7b8e2861d209dbfdeb63eca6a8ef7 source=17.5 
       <para>
       Allow <literal>UNION</literal> (without <literal>ALL</literal>)
       to use MergeAppend (David Rowley)
       <ulink url="&commit_baseurl;66c0185a3">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       允许<literal>UNION</literal>（不带<literal>ALL</literal>）
       使用MergeAppend（David Rowley）
       <ulink url="&commit_baseurl;66c0185a3">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=575a18de854c4268971c806929a2cf82 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2024-02-01 [9d1a5354f] Fix costing bug in MergeAppend
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=fc9b84e812c1fd35b8cfb035c6d590c0 sig_cn_org=860d167fee710f6b46e8730573dd4633 source=17.5 
       <para>
       Fix MergeAppend plans to more accurately compute the number of
       rows that need to be sorted (Alexander Kuzmenkov)
       <ulink url="&commit_baseurl;9d1a5354f">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       修复 MergeAppend 计划以更准确地计算需要排序的行数（Alexander Kuzmenkov）
       <ulink url="&commit_baseurl;9d1a5354f">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=fc9b84e812c1fd35b8cfb035c6d590c0 -->
      </listitem>

<!--
Author: David Rowley <drowley@postgresql.org>
2023-07-04 [625d5b3ca] Allow Incremental Sorts on GiST and SP-GiST indexes
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=1aee60784345d5f9b610ef292d55bc32 sig_cn_org=ca44fcb9164513a381af2fc9dfea4d98 source=17.5 
       <para>
       Allow  <link linkend="gist">GiST</link> and <link
       linkend="spgist">SP-GiST</link> indexes to be part of incremental
       sorts (Miroslav Bendik)
       <ulink url="&commit_baseurl;625d5b3ca">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
       允许<link linkend="gist">GiST</link>和<link
       linkend="spgist">SP-GiST</link>索引成为增量排序的一部分（Miroslav Bendik）
       <ulink url="&commit_baseurl;625d5b3ca">&sect;</ulink>
       </para>
<!-- pgdoc-cn_end sig_en=1aee60784345d5f9b610ef292d55bc32 -->

<!-- pgdoc-cn_start sig_en=206547a652e095683a8d23f114707c7a sig_cn_org=502af9624ac26c93b570e5068da16c76 source=17.5 
       <para>
       This is particularly useful for <literal>ORDER BY</literal>
       clauses where the first column has a GiST and SP-GiST index,
       and other columns do not.
       </para>
________________________________________________________-->
       <para>
       这对于<literal>ORDER BY</literal>子句特别有用，其中第一列有GiST和SP-GiST索引，
       而其他列则没有。
       </para>
<!-- pgdoc-cn_end sig_en=206547a652e095683a8d23f114707c7a -->
      </listitem>

<!--
Author: Alexander Korotkov <akorotkov@postgresql.org>
2023-11-27 [bc3c8db8a] Display length and bounds histograms in pg_stats
-->

      <listitem>
<!-- pgdoc-cn_start sig_en=e16fc94abbf58dcb808f2fe467b0f342 sig_cn_org=9168c1328ab49a745a48f18fa1f69530 source=17.5 
       <para>
       Add columns to <link
       linkend="view-pg-stats"><structname>pg_stats</structname></link>
       to report range-type histogram information (Egor Rogov, Soumyadeep
       Chakraborty)
       <ulink url="&commit_baseurl;bc3c8db8a">&sect;</ulink>
       </para>
________________________________________________________-->
       <para>
