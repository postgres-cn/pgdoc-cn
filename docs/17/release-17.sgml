<!-- pgdoc-cn_end sig_en=a02055a8da910ead1727444557e09781 -->

<!-- pgdoc-cn_start sig_en=facf46479672bcc2737c07c6e4192104 sig_cn_org=89bc1cd57c481f9d7e7bbd9585c452c8 source=16.8 
     <para>
      Repeated use of <function>PLyPlan.execute</function>
      or <function>plpy.cursor</function> resulted in memory leakage for
      the duration of the calling PL/Python function.
     </para>
________________________________________________________-->
     <para>
      重复使用<function>PLyPlan.execute</function>或<function>plpy.cursor</function>
      会导致在调用PL/Python函数期间发生内存泄漏。
     </para>
<!-- pgdoc-cn_end sig_en=facf46479672bcc2737c07c6e4192104 -->
    </listitem>

